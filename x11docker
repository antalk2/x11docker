# function mytest() :  --experimental
#
#    This function is not called anywhere.
# 
mytest() {
  if [ "$Mytest" ] ; then
      note "Option --experimental: changed something: ${1:-"(no comment)"}"
      return 0
  fi
  return 1
}

# function unpriv( Command ) :  Run a command as unprivileged user.
#             Needed if x11docker was started by root or with sudo.
#
unpriv() {
    # $Unpriv is declared in check_hostuser: 'eval' or 'su $Hostuser -c'
    local Command
    Command="$(oneline "${1:-}")"
    $Unpriv "$Command"
    return $?
}

# function unpriv_backend( Command )
#
#   Run container backend rootful (with current privileges) or
#   rootless (dropping privileges), depending on `Backendrootless`
#
unpriv_backend() {
    local Command
    Command="$(oneline "${1:-}")"
    if [ -z "$g_Backendbin" ] ; then
        warning "Binary path for backend $g_BackendKind not set."
        return 1
    fi
    #
    case "$Backendrootless" in
        yes)   unpriv                  "$Command" ;;
        no|"") eval   "env DOCKER_HOST= $Command" ;;
    esac
    return $?
}

# function unpriv_xcbackend( Command ) : Run X container backend
#          rootful or rootless, depending on `Xcrootless`
#
unpriv_xcbackend() {
    local Command
    Command="$(oneline "${1:-}")"
    case "${Xcrootless:-no}" in
        yes) unpriv                  "$Command" ;;
        no)  eval   "env DOCKER_HOST= $Command" ;;
    esac
    return $?
}

#
# Function: main
#
main() {
    if [ "$(uname -s)" = "Darwin" ] ; then
        echo "Error: x11docker does not run on MacOS. Please use Linux." >&2 ;
        exit 64
    fi

    trap finish EXIT
    trap finish_sigint SIGINT
    
    # stderr channel for warning(), note(), debugnote() and --verbose
    exec {FDstderr}>&2

    declare_variables
    parse_options "$@"

    if [ "$Silent" = "yes" ] ; then
        # --quiet
        exec {FDstderr}>/dev/null
    fi
    
    if [ "$Debugmode" = "yes" ] ; then
        # --debug
        #
        # -E  If set, the ERR trap is inherited by shell functions.
        # -u  Treat unset variables as an error when substituting.
        set -Eu
        trap 'traperror $? $LINENO $BASH_LINENO "$BASH_COMMAND" $(printf "::%s" ${FUNCNAME[@]})'  ERR
    fi

    if [ -n "$Containeruserpassword" ] ; then
        #
        # --password  [=WORD]   Change container user password and exit.
        #
        # --password is incompatible with all other options
        #
        check_optionset                                                   \
            "--password"                                                  \
            "$(grep -v -- '--password' <<< "$g_AllAvailableLongOptions")" \
            || true
        #
        set_password "$Containeruserpassword"
        finish
        return 0
    fi

    debugnote "x11docker version $Version"
    check_host                     # get some infos about host system
    check_options_arguments        # check for valid arguments
    check_hostuser                 # find unprivileged host user                    # --hostuser
    check_console                  # check if running on console
    create_cachefiles              # create cache files owned by unprivileged user  # --cachebasedir
    setup_verbosity                # create [and show] summary logfile              # --verbose
    check_containeruser            # unprivileged user in container                 # --user
    check_containerhomebasedir     # check base dir for --home and possible rootfs  # --homebasedir

    # Special x11docker jobs
    if [ "$Createlauncher" ] ; then
        # --launcher: Create application launcher icon on desktop
        create_launcher
        finish
    fi

    check_backend  # --backend

    if [ "$Installermode" ] ; then
        # --install, --update, --update-master, --remove
        if [ "$Packagedversion" =   yes ] ; then
            case "$Installermode" in
                --install|--update|--update-master|--remove|--remove-oldprefix)
                    error_ttm \
                        "|Options --install|--update|--update-master|--remove
                         |  are not supported in packaged versions of x11docker.
                         |  Please use your package manager instead."
                    ;;
            esac
        fi
        #
        # Each $Installermode is incomatible with all other options.
        check_optionset                                                             \
            "$Installermode"                                                        \
            "$( nlsw_set_difference                                                 \
                  "$g_AllAvailableLongOptions"                                      \
                  '--install --update --update-master --remove --remove-oldprefix'  \
              )" || true
        #
        installer "$Installermode"
        finish
    fi

    if [ "$Cleanup" ] ; then
        # --cleanup: Clean up cache and orphaned x11docker containers
        # The only option comptible with --cleanup is --backend.
        check_optionset                           \
            "--cleanup"                           \
            "$( nlsw_set_difference               \
                   "$g_AllAvailableLongOptions"   \
                    '--cleanup --backend'         \
              )" || true
        #
        cleanup
        finish
    fi

    if [ "$Buildimage" ] ; then
        # --build: Build image from x11docker repository
        check_optionset                         \
            "--build"                           \
            "$( nlsw_set_difference             \
                   "$g_AllAvailableLongOptions" \
                    '--build --backend'         \
              )" || true
        #
        buildimage "$g_Imagename"
        finish
    fi

    rocknroll || return 0

    # Open message channels for container, xinitrc and watchpidlist().
    # Also start corresponding background processes.
    setup_fifo

    check_xdg_runtime_dir

    # Check X environment from host ### FIXME could use xtool()+X
    #                                   container for xauth
    check_hostxenv

    # Check if docker is installed in snap; causes restrictions
    check_snap

    # Check if x11docker/xserver can/will be used    # --xc
    check_xcontainer

    # Check chosen X server or auto-choose one
    check_xserver

    # Look for nvidia installer file                 # --gpu
    check_nvidiainstaller || true

    if [ "$Xserver" = "--xorg" ] || [ -n "$Newxvt" ] || [ "$Runsonconsole" = "yes" ] ; then
        if [ -z "$Winsubsystem" ] ; then
            check_vt   # --vt: find free tty/virtual terminal for Xorg or weston
        fi
    fi

    # Find free display
    check_newxenv

    # Internal network for --xc --xoverip
    setup_xcnetwork || true
    if [ "$Xcontainer_option" = "yes" ] ; then
        # --xc
        create_xcontainercommand
        debugnote_ttm \
            "|X container command (rootless ${Xcrootless:-undefined}):
             |  $Xcontainercommand"
        #
        start_xcontainer
    fi
    store_newxenv

    # Look for XlibNoSHM.so and libdl.so.2 / fake MIT-SHM
    check_xlibnoshm || true

    # Check options, change settings if needed
    check_options_interferences

    # Create persistent container home               # --home
    check_containerhome

    # Some messages depending on options, but not changing anything
    check_options_messages

    # --wm
    check_windowmanager

    if [ "$Sharegpu"   = "direct" ] ; then setup_gpu              || true ; fi      # --gpu
    if [ "$Sharewebcam"   = "yes" ] ; then setup_webcam                   ; fi      # --webcam
    if [ "$Sharecupsmode"         ] ; then setup_printer                  ; fi      # --printer
    if [ "$Sharepipewire" = "yes" ] ; then setup_sound_pipewire   || true ; fi      # --pipewire
    if [ "$Pulseaudiomode"        ] ; then setup_sound_pulseaudio || true ; fi      # --pulseaudio
    if [ "$Sharealsa"     = "yes" ] ; then setup_sound_alsa               ; fi      # --alsa
    if [ "$Sharehostdbus" = "yes" ] ; then setup_hostdbus                 ; fi      # --hostdbus
    if [ "$Cleanxhost"    = "yes" ] ; then clean_xhost                    ; fi      # --clean-xhost
  
    create_clipboardrc >> "$Clipboardrc"                                            # --clipboard

    # size of host X and of new X server
    check_screensize                                                                # --size

    #### Create command to run X server [and/or Wayland compositor]
    create_xcommand                # set up start command for X server              # all X server and Wayland options

    if [ "$Xcommand" ] ; then
        case "$Xwaylandrootless" in
            no)   debugnote "X server command:${NEWLINE}  $Xcommand" ;;
            yes)  debugnote "Xwayland wrapper:${NEWLINE}$(cat $Xwaylandwrapper)" ;;
        esac
    fi

    if [ "$Compositorcommand" ] ; then
        debugnote "Wayland compositor command:${NEWLINE}  $Compositorcommand"
    fi

    if [ -s "$Westonini" ] ; then
        debugnote "Generated weston.ini:${NEWLINE}$(nl -ba <$Westonini)"
    fi

    # init in container.                                            # --init
    setup_initsystem

    case "$g_BackendKind" in

        docker|podman|nerdctl)
            if [ -z "$g_Rootfs" ] ; then
                check_image
            fi

            # Add linux capabilities if needed for some options.
            # Default: --cap-drop=ALL
            setup_capabilities

            if [ "$Sharegpu" = "yes" ] ; then                         # --gpu
                setup_vaapi
            fi
            ;;
    esac

    case "$g_BackendKind" in
        proot|docker|podman|nerdctl)

            create_backendcommand           # create 'docker run' command
            echo "$Backendcommand" >> "$Backendcommandfile"
            debugnote_ttm \
                "|$g_BackendKind command (rootless ${Backendrootless:-undefined}):
              |  $Backendcommand"
            #
            if [ "$Containersetup" = "yes" ] ; then
                ## containerrootrc runs as root in container.
                #
                # Main jobs: create unprivileged container user,
                #            disable possible privilege leaks,
                #            set local time.
                #
                # Optional jobs: run init system,
                #                run DBus daemon,
                #                install nvidia driver,
                #                create language locale.
                #
                create_containerrootrc >> "$Containerrootrc"
                verbose "Generated containerrootrc:${NEWLINE}$(nl -ba <$Containerrootrc)"
            fi
            ;;
        # host) ;; # BackendKind_host
    esac

    if [ "$Containersetup" = "yes" ] ; then
        create_containerrc
        verbose "Generated containerrc:${NEWLINE}$(nl -ba <$Containerrc)"
        create_cmdrc
        verbose "Generated cmdrc:${NEWLINE}$(nl -ba <$Cmdrc)"
        create_sshenv
        verbose "Generated sshenv:${NEWLINE}$(nl -ba <$Sshenvscript)"
    fi

    storeinfo_add_kv_sh "x11dockerpid=$$"    # store pid of x11docker

    (
        # Values for the debugnote below
        local Backendbin_version="$(${g_Backendbin:-:} --version 2>&1)"
        local Host_system_to_report="$(
                grep '^PRETTY_NAME' /etc/os-release 2>/dev/null  \
                | cut -d= -f2                                    \
                || echo "$Hostsystem"
            )"
        local Container_user_will_be="$(
               if [ "$Createcontaineruser" = "yes" ] ; then
                  echo "$g_Containerusername"
               else
                  echo "(retaining USER of image)"
               fi
            )"
        local Container_user_password="$(
               if [ "$Createcontaineruser" = "yes" ] ; then
                  echo "x11docker"
               else
                   echo "(unknown)"
               fi
            )"
        #
        debugnote_ttm \
            "|x11docker version:  $Version
             |  Backend version:               ${Backendbin_version}
             |  Running rootless:              $Backendrootless
             |  OCI Runtime:                   $Runtime
             |  Host system:                   ${Host_system_to_report}
             |  Host architecture:             $Hostarchitecture
             |  Command:
             |    '$0' $(for Line in "$@"; do echo -n "'$Line' " ; done)
             |  Parsed options:
             |    $Parsedoptions_global
             |  x11docker was started by:      $Startuser
             |  As host user serves:           $Hostuser
             |  Container user will be:        ${Container_user_will_be}
             |  Container user password:       ${Container_user_password}
             |  Running in a terminal:         $Runsinterminal
             |  Running on console:            $Runsonconsole
             |  Running over SSH:              $Runsoverssh
             |  Running sourced:               $Runssourced
             |  bash \$-:                       $-"
    )

    if [ "$Winsubsystem" ] ; then
        debugnote_ttm \
            "|
             |  Running on Windows subsystem:  $Winsubsystem
             |  Path to subsystem:             $(convertpath windows "$Winsubpath")/
             |  Mount path in subsystem:       $Winsubmount/
             |  Using docker VM:               $Dockervm"
    fi

    { #### Run docker image
        #
        # For code flow logic, start_xserver() should run here first
        #                      and be moved to background.
        #
        # For technical reasons, xinit must not run in a subshell:
        #   --xorg on tty only works if xinit runs in foreground to grab the tty.
        #   Otherwise, Xwrapper.config must be edited to
        #      'allowed_users=anybody' even on console.
        #
        # Thus docker runs in this subshell after X server is ready to
        # accept connections.
        #

        # wait for X to be ready
        waitforlogentry_sh 'start_container()' $Xinitlogfile 'xinitrc is ready' "$Xiniterrorcodes"

        # --xc : softlink (or socat) to X or Wayland unix socket in container
        if [ "$Xcontainer_option" = yes ] ; then
            if [ -n "$Newdisplay" ] ; then
                if have_command socat ; then
                    unpriv "$(trim_to_mark \
                            "|socat -lf $Xinitlogfile
                             : -d   UNIX-LISTEN:/tmp/.X11-unix/X$Newdisplaynumber,ignoreeof,fork
                             : UNIX:$Cachefolder/tmp/.X11-unix/X$Newdisplaynumber"
                             )" &
                    storepid "$!" socat-X
                else
                    if [ -n "$Showdisplayenvironment" ] ;
                    then Message="note_ttm"
                    else Message="debugnote_ttm"
                    fi
                    #
                    $Message "|Option --xc --printenv: Command 'socat' not found.
                              |  Using 'ln -s' to provide X unix socket on host.
                              |  GTK3 application might fail to access X."
                    #
                    ln -s                                              \
                       "$Cachefolder/tmp/.X11-unix/X$Newdisplaynumber" \
                                   "/tmp/.X11-unix/X$Newdisplaynumber" \
                       2>>$Xinitlogfile || true
                fi
            fi

            if [ -n "$Newwaylandsocket" ] ; then
                ln -s                                               \
                   "$Cachefolder/XDG_RUNTIME_DIR/$Newwaylandsocket" \
                               "$XDG_RUNTIME_DIR/$Newwaylandsocket" \
                   2>>$Xinitlogfile || true
            fi
        fi

        if ! rocknroll ; then
            saygoodbye main-runshell
            return 1
        fi

        # xinit(?) sets variables to new display for host
        #         applications, too. This undoes it.
        unpriv "$( trim_to_mark "|dbus-update-activation-environment
                                 : --systemd
                                 : DISPLAY='$DISPLAY'
                                 : XAUTHORITY='$XAUTHORITY'
                                 :"
                 )"  >> "$Xinitlogfile" 2>&1 || true

        # Runfromhost : --runfromhost
        if [ -n "$Runfromhost" ] ; then
            while read Line; do
                # https://github.com/mviereck/x11docker/issues/578
                # --runfromhost Thunar runs Thunar twice
                if [ -n "$Line" ] ; then
                    # debugnote "main(): Runfromhost: '$Line'"
                    unpriv "env $Newxenv $Line"
                fi
            done <<< "$Runfromhost"
        fi

        # start container
        start_container
        Pid1pid="$(storeinfo_dump_sh pid1pid)"
        Containerip="$(storeinfo_dump_sh containerip)"

    # --xoverip -listen tcp: Use xhost instead of XAUTHORITY
    case "$Xoverip" in
      listentcp)
        verbose "--xoverip=listentcp: Replacing cookie authentication with host based authentication."
        case "$Xserver" in
          --runx)
          ### FIXME experimental
          #    env DISPLAY=:$Newdisplaynumber XAUTHORITY=$Xclientcookie xhost +INET:$Containerip >>$Xinitlogfile 2>&1
          #    env DISPLAY=:$Newdisplaynumber XAUTHORITY=$Xclientcookie xhost >>$Xinitlogfile 2>&1
            xtool --check "xhost" && {
              xtool "env DISPLAY=:$Newdisplaynumber XAUTHORITY=$Xclientcookie xhost +INET:$Containerip" >>$Xinitlogfile 2>&1 && truncate -s0 $Xclientcookie    
            }
          ;;
          *)
            xtool --check "xhost" && {
              xtool "env DISPLAY=:$Newdisplaynumber XAUTHORITY=$Xclientcookie xhost +INET:$Containerip" >>$Xinitlogfile 2>&1 && truncate -s0 $Xclientcookie
            } || {
              warning "--xoverip=$Xoverip: Failed to set up xhost access
  instead of using a cookie. If the container shares the cookie with others,
  others might be able to access X server $Xserver."
            }
          ;;
        esac
      ;;
    esac
    touch $Sharefolder/xhostready

    # watch container ### FIXME
    case "$Winsubsystem" in
      "")
        case "$Dockervm" in
          desktop) setonwatchpidlist "CONTAINER$g_Containername" ;;
          *)       setonwatchpidlist "${Pid1pid:-NOPID}" pid1pid ;;
        esac
      ;;
      *)           setonwatchpidlist "CONTAINER$g_Containername" ;;
    esac

    # watch xinit and X server
    case "$Xserver" in
      --tty|--hostdisplay|--hostwayland|--weston|--kwin) ;;
      *)
        Xinitpid="$(pgrep -a xinit 2>/dev/null | grep "xinit $Xinitrc" | awk '{print $1}')"
        checkpid "$Xinitpid"   && setonwatchpidlist "$Xinitpid" xinit
        Xserverpid=$($Myps ax -o pid,args | rmcr | grep "$(echo "${Xcommand:-nothingtolookfor}" | cut -d' ' -f1-2))" | grep -v grep | grep -v xinit | awk '{print $1}')
        checkpid "$Xserverpid" && setonwatchpidlist "$Xserverpid" Xserver
      ;;
    esac

    [ "$Pulseaudiomode" = "tcp" ] && start_pulseaudiotcp                          # --pulseaudio=tcp

    # some debug output
    checkpid "$Pid1pid" && debugnote "Process tree of container: (maybe not complete yet)
$(pstree -p "$Pid1pid" 2>&1 ||:)"
    debugnote "Process tree of x11docker:
$(pstree -p $$ 2>&1 ||:)"
    debugnote "storeinfo(): Stored info:
$(cat $Storeinfofile)"
    debugnote "storepid(): Stored pids:
$(cat $Storepidfile)"

    # optional info on stdout
    case "$Showinfofile" in                                                       # --printinfofile
      "") ;;
      yes) echo "$Storeinfofile" ;;
      *)   unpriv "echo '$Storeinfofile' > '$Showinfofile'"         || error "Option --printinfofile: Invalid file $Showinfofile" ;;
    esac
    case "$Showdisplayenvironment" in                                             # --printenv
      "") ;;
      yes) storeinfo_dump_sh Xenv ;;
      *)
          # Newxenv_cr : Like Newxenv, but with newlines. Was global,
          #     never set, only used here.
          #
          local Newxenv_cr="${Newxenv// /$'\n'}" # spaces_to_newlines
          unpriv "echo '$Newxenv_cr' > '$Showdisplayenvironment'"  || error "Option --printenv: Invalid file $Showdisplayenvironment" ;;
    esac
    case "$Showcontainerid" in                                                    # --printid
      "") ;;
      yes) storeinfo_dump_sh containerid ;;
      *)   unpriv "storeinfo_dump_sh containerid > '$Showcontainerid'" || error "Option --printid: Invalid file $Showcontainerid" ;;
    esac
    case "$Showcontainerpid1pid" in                                               # --printpid1
      "") ;;
      yes) echo "$Pid1pid" ;;
      *)   unpriv "echo '$Pid1pid' > '$Showcontainerpid1pid'"       || error "Option --printcontainerpid1pid: Invalid file $Showcontainerpid1pid" ;;
    esac
    storeinfo_add_kv_sh "x11docker=ready"
  } <&0 & storepid $! containershell

  rocknroll || return 1
  ## Create helper script xinitrc to set up X
  # xinitrc is started by xinit and does some setup within new X server.
  # Main job: create cookie, check xhost, set keyboard layout.
  # Optional jobs: run window manager, run xfishtank+xeyes, share clipboard, scale/rotate --xorg, create set of screen resolutions.
  create_xinitrc >> "$Xinitrc"
  verbose "Generated xinitrc:
$(nl -ba <$Xinitrc)"

  case "$Xserver" in
    --xpra*)
      {
        waitforlogentry_sh xpra $Xinitlogfile "xinitrc is ready" '' infinity
        rocknroll && start_xpra                                                   # --xpra, --xpra-xwayland
      } & storepid $! xpraloop
    ;;
  esac
  rocknroll && [ "$Compositorcommand" ] && start_compositor
  rocknroll && start_xserver
}

# Execute main() if this is run in standalone mode (i.e. not from a unit test).
if [ -z "${X11DOCKER_TESTING:-}" ]; then
    main "$@"
    saygoodbye main
fi

