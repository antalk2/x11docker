#
# Function: download
#
# Usage:
#
#   download                 # Test if at least one of curl and wget is available
#      return 1 if neither curl or wget found, 0 if at least one of them is present.

#   download URL output_file # Download file at URL and store it in output_file
#       return 0 for succees, 1 for failure.
#
download() {
    # Uses wget or curl. If both are missing, returns 1.
    # With no arguments it checks for curl/wget without downloading.
    # Download follows redirects.
    #
    local Downloader=""
    if   have_command curl ; then  Downloader="curl"
    elif have_command wget ; then  Downloader="wget"
    else                              return 1 ; fi

    if [ -z "${1:-}" ] ; then
        # Just testing Downloader availability. Success.
        return 0
    fi

    case "$Downloader" in
        wget) wget    "${1:-}"        -O       "${2:-}" || return 1 ;;
        curl) curl -L "${1:-}" --fail --output "${2:-}" || return 1 ;;
    esac
    return $? # Can only be 0
}

#
# Function: escapestring
#
# Usage: escapestring s
#
# Brief:: Escape special chars of @code{s} by inserting a backslash
#         before each.
#
# Description:
# - Escape all characters except those described in [^a-zA-Z0-9,._+@=:/-]
# - single_quote is not allowed in @code{s} :  error() if it contains one.
#
# Examples:  Backendcommand="$Backendcommand --env '$( escapestring "$Line" )'"
#            echo "export $( escapestring "SHELL=$Containerusershell" )"
#
#
escapestring() {
    if grep -q "'" <<< "${1:-}" ; then
        error_ttm "|escapestring(): x11docker cannot escape char ' in :
                   |  ${1:-}"
        return 1
    fi
    echo "${1:-}" | LC_ALL=C sed -e 's/[^a-zA-Z0-9,._+@=:/-]/\\&/g; '
}

