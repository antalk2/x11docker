# Function: store_runoption_env
# Brief: Store env for docker command
#
# Description: Store a value that will be available in
#              "$(store_runoption_dump_env)"
#
# Usage: store_runoption_env a_value
#
# Argument:
#   a_value : Often, but not always in the format "label=value"
#
#  Examples:
#    store_runoption_env "DBUS_SESSION_BUS_ADDRESS=$DBUS_SESSION_BUS_ADDRESS"
#    store_runoption_env  "${DBUS_SESSION_BUS_PID:-}"  # No name?
#    store_runoption_env "DISPLAY=$Newdisplay"
#
store_runoption_env() {
    # local Count Line Path Readwritemode
    Containerenvironmentcount="$((Containerenvironmentcount + 1))"
    ContainerenvironmentArray[$Containerenvironmentcount]="${1:-}"
    return 0
}

# Function: store_runoption_dump_env
# Brief: Emit the list of values stored using store_runoption_env
#
# stdout: The values, each followed by a newline.
#
store_runoption_dump_env() {
    # local Count Line Path Readwritemode
    local Count
    for ((Count=$Containerenvironmentcount ; Count>=1 ; Count --)) ; do
        echo "${ContainerenvironmentArray[$Count]}" ;
    done
    return 0
}

# Function: store_runoption_volume
# Brief: Store volume/device to be shared for docker command
#
#  Usage:
#    store_runoption_volume  "$Gpudevice"
#    store_runoption_volume "/run/cups"
#    store_runoption_volume "$Cupsserver"
#    store_runoption_volume "$(myrealpath "$Path")$Readwritemode"
#
# Globals:
#
#    Sharevolumescount=
#    SharevolumesArray[$Sharevolumescount]=
#
store_runoption_volume() {
    # local Count
    # local Line
    local Path Readwritemode
    #
    local ARG1="${1:-}"
    #
    Path="$( convertpath subsystem "${ARG1}" )"
    Readwritemode="$( echo "${ARG1}" | rev_cut -c1-3 )"
    if [ "$Readwritemode" != ":ro" ] ; then  Readwritemode="" ; fi
    #
    case "${Path:0:1}" in
        "/") # path on host
            Sharevolumescount="$(( Sharevolumescount + 1 ))"
            SharevolumesArray[$Sharevolumescount]="${ARG1}"
            [ -h "$Path" ] && myrealpath "$Path" >/dev/null && {
                    #
                    note_ttm \
                        "|Option --share: Shared file is a symbolic link. Sharing target, too.
                         |  Symlink: $Path
                         |  Target:  $(myrealpath "$Path")"
                    #
                    store_runoption_volume "$(myrealpath "$Path")$Readwritemode"
                }
            ;;
        *) # Docker volume
            Sharevolumescount="$((Sharevolumescount + 1))"
            SharevolumesArray[$Sharevolumescount]="${ARG1}"
            ;;
    esac
    #
    return 0
}


# Function: store_runoption_dump_volume
# Brief: List the volumes added by @code{store_runoption_volume}
#
# stdout: elements of the array SharevolumesArray, each followed by a newline.
#
# Globals:
#
#    Sharevolumescount
#    SharevolumesArray
#
store_runoption_dump_volume() {  # store volume/device for docker command
    local Count
    for ((Count=1 ; Count<=$Sharevolumescount ; Count ++)) ; do
        echo "${SharevolumesArray[$Count]}" ;
    done
    return 0
}

#
#  Function: store_runoption_cap
#  Usage: store_runoption_cap "a b c"
#
#  Brief: appends  "${NEWLINE}a${NEWLINE}b${NEWLINE}c"
#         to Capabilities
#
# Note: Capabilities may contain duplicate entries. Those are removed
#       by store_runoption_dump_cap()
#
# Note: The only capability that is not in docker_default_capabilities
#       is SYS_BOOT.
#
#       Calling store_runoption_cap() for those in
#       docker_default_capabilities have no effect (until the defaults
#       change), because store_runoption_dump_cap() will filter them.
#       They may serve as a documentation of which capabilities are
#       relied on, though.
#
#  Usage:
#    store_runoption_cap "FSETID FOWNER SETPCAP SYS_BOOT"
#    store_runoption_cap "SYS_BOOT KILL"
#    store_runoption_cap "SETUID SETGID DAC_OVERRIDE AUDIT_WRITE"
#    store_runoption_cap "CHOWN FOWNER DAC_OVERRIDE"
#
store_runoption_cap() {
    # local Count Line Path Readwritemode
    local Line
    for Line in ${1:-} ; do
        Capabilities="$Capabilities${NEWLINE}$Line"
    done
    return 0
}

# Function:  store_runoption_dump_cap
#
# Brief: Emit newline-separated list of capabilities for "docker
#        --cap-add $capability"
#
# - Called in a single location
#
# - Emit nothing if [  "$Capdropall" = yes ]
#
# - Even if [ "$Capdropall" = no ], omit docker_default_capabilities
#   from the output.
#
store_runoption_dump_cap() {
    local Line
    local docker_default_capabilities
    local normalized_Capabilities
    #
    case "$Capdropall" in
        yes)
            # echo "$Line"
            true # Emit nothing. It does not really matter, this
                 # function is not called if [  "$Capdropall" = yes ]
            ;;
        no)
            #
            # See: https://dockerlabs.collabnix.com/advanced/security/capabilities/
            # under 'The following list contains all capabilities that are enabled by default'
            #
            # docker_default_capabilities contains these
            docker_default_capabilities="$(trim_to_bar \
                        "|CHOWN DAC_OVERRIDE FSETID FOWNER MKNOD NET_RAW
                         | SETGID SETUID SETFCAP SETPCAP
                         | NET_BIND_SERVICE SYS_CHROOT KILL AUDIT_WRITE"
                         )"
            #
            # If Capdropall=no then emit a newline-separated list of
            #     capabilities from $Capabilities , omitting
            #     those in docker_default_capabilities.
            #
            nlsw_set_difference "$Capabilities" "${docker_default_capabilities}"
            #
            ;;
    esac
    return 0
}

