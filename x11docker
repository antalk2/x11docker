# convertpath share /home/antalk/.cache/x11docker/644222941101-xfce/share/container.log
# convertpath share /home/antalk/.cache/x11docker/644222941101-xfce/share/xhostready
# convertpath share /home/antalk/.cache/x11docker/644222941101-xfce/share/containerrootrc
#
#
#convertpath(){
#    SPY_STDOUT convertpath_orig "${@}"
#}
#
convertpath() {                 # convert unix and windows paths
    # $1: Mode:
    #     windows   echo Windows path                            - result: c:/path
    #     unix      echo unix path                               - result: /c/path
    #     subsystem echo path within subsystem                   - result: /cygdrive/c/path  or  /path  or /mnt/c/path
    #     volume    echo --volume compatible syntax              - result: 'unixpath':'containerpath_arg':rw  (or ":ro")
    #     container echo path of volume in container             - result: /path
    #
    #     share     echo path of $Sharefolder/file in container  - result: Sharefoldercontainer/file
    #
    #     mount     ???
    #
    # $2: Path to convert. Arbitrary syntax, can be C:/path, /c/path, /cygdrive/c/path, /path
    #     Can have suffix :rw or :ro. If none is given, return with :rw
    #
    # $3: Optional for mode volume: containerpath_arg
    #
    local Mode="${1:-}"
    local Path="${2:-}"
    local containerpath_arg="${3:-}"

    # Check path for suffix :rw or :ro
    local Readwritemode
    #    #
    #    # If the last 3 characters of Path starts with ":",
    #    # then Readwritemode is these 3 characters,
    #    #      and these are removed from Path.
    #    # otherwise Readwritemode=":rw"
    #    #
    #    if [ "${Path: -3:1}" = ":" ] ; then
    #        Readwritemode="${Path: -3}"
    #        Path="${Path:0:-3}"
    #    else
    #        Readwritemode=":rw"
    #    fi
    convertpath_split_Readwritemode  "Readwritemode" "Path" "$Path"

    # Set Readwritemode_mount based on Readwritemode
    local Readwritemode_mount
    if [ "$Readwritemode" = ":ro" ] ; then
        Readwritemode_mount=",readonly"
    else
        Readwritemode_mount=""
    fi

    #
    # convertpath_expand_tilde
    #
    # used_global: Hostuserhome
    # used_global: HOME
    #
    # Replace ~ with Hostuserhome or HOME in Path
    # was: Path="$(sed "s%~%${Hostuserhome:-${HOME:-}}%" <<< "$Path")"
    Path="${Path/[~]/${Hostuserhome:-${HOME:-}}}"

    #
    # convertpath_handle_Mode_share
    #
    # case Mode in share: Replace $Sharefolder with $Sharefoldercontainer
    if [ "$Mode" = "share" ] ; then
        if [ -z "$Path" ] ; then
            echo ""
            return 0
        else
            # Using global Sharefoldercontainer and Sharefolder
            #
            # Replace prefix Sharefolder with Sharefoldercontainer
            #
            # Note: ${parameter#pattern} removes prefix of parameter
            #       matching pattern
            #
            echo "${Sharefoldercontainer}${Path#"$Sharefolder"}"
            return 0
        fi
    fi

    #
    # Before we start to look for "/c/" unify // and backslash
    #
    # Replace // with / and  \ with /   in Path
    Path="$(sed 's%//%/%g ; s%\\%/%g' <<< "$Path")"


    # Remove possible already given mountpoint
    # used_global: Winsubmount
    Path="${Path#"$Winsubmount"}" # removes prefix Winsubmount from Path

    ## Separate "/c/" and "c:" from Path to Drive as lowercase letter (or "" if missing)
    local Drive=
    convertpath_split_Drive "Drive" "Path" "${Path}"
    #
    #
    #
    # If Path does not start with "/", then it must be a docker volume (?)
    #
    # docker volume (same for Windows and Unix)
    if [ "${Path:0:1}" != "/" ] ; then
        # Path does not start with "/"
        case "$Mode" in
            unix|subsystem|windows)
                echo "$Path" ;
                debugnote_ttm \
                    "|convertpath() $Mode:
                     : Docker volumes do not have a specified path on host: $Path"
                ;;
            volume)
                ## docker volume to volume?
                ## "'$Path':'${containerpath_arg}'${Readwritemode}"
                ## Looks like:  "'/path1':'/path2':ro"
                ##
                ## Examples: grep 'convertpath volume'
                ## docker   --volume $(convertpath volume "$Persistanthomevolume"
                ##                                        "$Containeruserhomebasefolder")"
                ## docker   --device $(convertpath volume "$Line")"
                ##
                echo "'$Path':'${containerpath_arg:-/$Path}'${Readwritemode}"
                ;;
            mount)
                ##
                trim_to_mark "|type=volume
                              :,source='$Path'
                              :,target='${containerpath_arg:-/$Path}'
                              :${Readwritemode_mount}"
                #
                ;;
            container)      echo "${containerpath_arg:-/$Path}" ;;
        esac
        return 0
    fi

    Containerpath="$Path"                            # global Containerpath
    #
    if [ "$Createcontaineruser" != "no" ] ; then     # global Createcontaineruser
        if [ "$Sharehome" != "host" ] ; then         # global Sharehome
            #                                        # global Containeruserhome
            if        [ -n "$Containeruserhome" ] \
               && grep -q "^$Containeruserhome" <<< "$Path" ; then
                #
                # Replace prefix $Containeruserhome with /home.host
                #
                # Containerpath="$(
                #       sed "s%^$Containeruserhome%/home.host%" <<< "$Containerpath"
                # )"
                #
                local old="${Containerpath}"
                local prefix="${Containeruserhome}"
                local replacement="/home.host"
                Containerpath="${old/#"$prefix"/"$replacement"}"
            fi
        fi
        #
        #                                             # global Persistanthomevolume
        #                                             # global Containeruserhome
        if [        "$Containerpath"         = "$Containeruserhosthome" ] \
               && [ "$Persistanthomevolume" != "$Containeruserhosthome" ] ; then
            Containerpath="/home.host/$Containeruser"  # global Containeruser
        fi
    fi
    #

    # not on Windows
    # global Winsubsystem
    if [ -z "$Winsubsystem" ] ; then
        case "$Mode" in
            unix|subsystem) echo "$Path" ;;
            windows)
                warning "convertpath(): Nonsense path conversion $Mode: $Path" ;
                return 1
                ;;
            #
            # volume)    echo "'$Path':'${containerpath_arg:-$Path}'$Readwritemode" ;;
            # container) echo "${containerpath_arg:-$Path}" ;;
            #
            volume)
                echo "'$Path':'${containerpath_arg:-$Containerpath}'${Readwritemode}"
                ;;
            mount)
                printf "%s"                                              \
                       "type=bind"                                       \
                       ",source='$Path'"                                 \
                       ",target='${containerpath_arg:-/$Containerpath}'" \
                       "${Readwritemode_mount}"
                ;;
            container)      echo "${containerpath_arg:-$Containerpath}" ;;
        esac
        return 0
    fi

    # Only on WSL1
    case "$Winsubsystem" in
        WSL1)
            if [ -z "$Drive" ] ; then # no drive letter
                case "$Mode" in
                    windows|unix|volume)
                        debugnote "convertpath(): Request of WSL path: $Path"
                        #
                        grep -q "$Cachefolder" <<< "$Path" || { # global Cachefolder
                            if  [ "$Readwritemode" = ":rw" ] ; then
                                warning_ttm \
                                    "|Request of Windows path to path within WSL:
                                     |  $Path
                                     |  Write access from Windows host to WSL files
                                     : can damage the WSL file system.
                                     |  Read-only access is ok.
                                     |  Option --share: You can add :ro to the path
                                     : to allow read-only access.
                                     |  Example: --share='$Path:ro'"
                            fi
                        }
                        ;;
                esac
            fi
            ;;
    esac

    case "$Drive" in
        "") # Path points into subsystem
            Path="${Path#"$Winsubpath"}" # remove prefix Winsubpath        # global Winsubpath
            #
            Drive="$(cut -c2 <<<"$Winsubpath")" # 2nd character, /c/path -> c
            # Q: Is it possible that we did not find the drive letter above?
            #
            case "$Mode" in
                windows)
                    # Uppercase Drive, colon, /path -> C:/path
                    echo "${Drive^}:$(cut -c3- <<< "$Winsubpath")$Path"
                    ;;
                unix)         echo "$Winsubpath$Path" ;;
                subsystem)    echo "$Path" ;;
                volume)
                    # global Dockervm
                    case "$Dockervm" in
                        no|desktop)
                            printf "%s"                             \
                                   "'$Path'"                        \
                                   ":'${containerpath_arg:-$Path}'" \
                                   "$Readwritemode"
                            ;;
                        moby)
                            printf "%s"                             \
                                   "'$Winsubpath$Path'"             \
                                   ":'${containerpath_arg:-$Path}'" \
                                   "$Readwritemode"
                            ;;
                    esac
                    ;;
                mount)
                    case "$Dockervm" in
                        no|desktop)
                            printf "%s"                                    \
                                   "type=bind"                             \
                                   ",source='$Path'"                       \
                                   ",target='${containerpath_arg:-$Path}'" \
                                   "$Readwritemode_mount"
                            ;;
                        moby)
                            printf "%s"                                    \
                                   "type=bind"                             \
                                   ",source='$Winsubpath$Path'"            \
                                   ",target='${containerpath_arg:-$Path}'" \
                                   "$Readwritemode_mount"
                            ;;
                    esac
                    ;;
                container)    echo "${containerpath_arg:-$Path}" ;;
            esac
            ;;
        *)  # We have a drive letter --> Path outside of subsystem
            #
            # global Winsubmount
            case "$Mode" in
                windows)      echo "${Drive^}:$Path" ;;
                unix)         echo "/$Drive$Path" ;;
                subsystem)
                    # Winsubmount : where does C:\ appear within the
                    #    subsystem? (e.g. for cygwin, we ask it from
                    #    cygpath.exe )
                    echo "$Winsubmount/$Drive$Path"
                    ;;
                volume)
                    echo "'/$Drive$Path':'${containerpath_arg:-/$Drive$Path}'$Readwritemode"
                    ;;
                mount)
                    printf "%s"                                            \
                           "type=bind"                                     \
                           ",source='/$Drive$Path'"                        \
                           ",target='${containerpath_arg:-/$Drive$Path}'"  \
                           "$Readwritemode_mount"
                    ;;
                container)    echo "${containerpath_arg:-/$Drive$Path}" ;;
            esac
            ;;
    esac

    return 0
}

#
# function createmountopt( Modus, File, Rw )
#
# Create option for docker to mount file or device, check if file exists
#
createmountopt() {
    # $1  Modus:  one of mount, device, volume
    #             Note: only used with mount and device
    #
    #             mount  -> "--mount type=bind,source=${eFile},target=${eFile}$Rw"
    #             device -> "--device ${eFile}$Rw"
    #             volume -> "--volume ${eFile}:${eFile}$Rw"
    #
    # $2  File:   file or device to share
    #             If does not exist, emit nothing and return 1
    #
    # $3  Rw:     ro, readonly (optional)
    local Modus File Rw
    Modus="${1:-}"
    File="${2:-}"
    Rw="${3:-}"

    if [ ! -e "$File" ] ; then 
        debugnote "createmountopt(): ERROR: File not found: '$File'"
        return 1
    fi
  #
  case "$Rw" in
      "ro"|"readonly")
          case "$Modus" in
              mount)         Rw=",readonly" ;;
              volume|device) Rw=":ro"       ;;
          esac
          ;;
      *)                 Rw="" ;;
  esac
  #
  local eFile
  eFile="$(escapestring "$File")"
  #
  case "$Modus" in
      # 
      mount)
          # https://docs.docker.com/engine/storage/bind-mounts/
          # To create a bind mount, you can use either the --mount or --volume flag.
          # docker run --mount type=bind,src=<host-path>,dst=<container-path>
          # 
        echo "--mount type=bind,source=${eFile},target=${eFile}$Rw"
    ;;
      device)
          # --device=/dev/host-device:/dev/container-device
          echo "--device ${eFile}$Rw"
    ;;
    volume)
      # https://docs.docker.com/engine/storage/volumes/
        # docker run --mount type=volume,src=<volume-name>,dst=<mount-path>
        # docker run --volume <volume-name>:<mount-path>
        # docker run --volume [<volume-name>:]<mount-path>[:opts]
        #   Here opts is a comma-separated list of options, like ro.
        #   The colon just separates it from <mount-path>
      echo "--volume ${eFile}:${eFile}$Rw"
    ;;
  esac
}
