wincmd() {
    MSYS2_ARG_CONV_EXCL='*' cmd.exe /C "${@//&/^&}" | rmcr
}

#
# Function: mswindowsipcheck
#
#  return 1 (false) on failure
#
# Set global Hostip and Hostipwindows
#  based on output from "ip -4 addr" and "ipconfig.exe"
#
#  Looks at the host and windows IP addresses, looks for a pair
#  where Hostip and Winip look at the same network address.
#
#  - On success, Hostip and Hostipwindows contain the matching pair found.
#  - return 1 if could not get IP addresses of ipcalc is missing.
#  - If no pair found, the return value is (???), and Hostipwindows
#    is not changed from its incoming value.
#
#  - Note: the return value is used, may be important.
#
mswindowsipcheck() {            # get WSL host IP and Windows host ip
    # thanks to @eyespore in https://github.com/mviereck/x11docker/issues/557

    local Hostips Mswindowsips Hostcidr Hostprefix Mswindowsnetwork Hostnetwork
    # global: Hostip Hostipwindows

    # Hostips:  Firstly collect all valid IPv4 addresses of the WSL2
    # distribution, excluding virtual interfaces created by Docker,
    # Podman, or other container/network tools:
    #
    # These IPs will later be used to determine which one is in the
    # same subnet as the Windows host.
    #
    Hostips=$(
        ip -4 addr show scope global \
            | awk '/inet / { if ($0 !~ /(docker|br-|veth|cni|podman)/) print $2 }'
    )

    if [[ -z "$Hostips" ]]; then 
        note "mswindowsipcheck(): Failed to check Linux host IPs"
        return 1
    fi

    #
    # Mswindowsips :
    #
    #    Since WSL can directly invoke Windows executables, we can use
    #    ipconfig.exe to obtain the IPv4 addresses of the Windows
    #    host:
    #

    # In awk, NF is a predefined variable whose value is the number of
    #            fields in the current record.
    #         So awk '{print $NF}' prints the last field (of the line)
    #
    # Q: What is the difference between   `| tr -d '\r'`   and `| rmcr`   ?
    # A: (1) rmcr has multiple definitions, can be  rmcr() { cat; }
    # A: (2) Maybe there is a subtle differemce betweeen `| tr -d '\r'`
    #        and `sed "s/$(printf "\r")//g"` (used in rmcr) ?
    #
    Mswindowsips=$(
        ipconfig.exe | grep -i 'IPv4' | awk '{print $NF}' | tr -d '\r'
    )

    if [[ -z "$Mswindowsips" ]]; then 
        note "mswindowsipcheck(): Failed to check Windows host IPs"
        return 1
    fi
    #  Mswindowsips : These IPs will then be used to find the Windows
    #    ↔ WSL IP pair that resides in the same subnet.

    if ! have_command ipcalc ; then
        note_ttm "|mswindowsipcheck(): command ipcalc not found.
                  |  Please install ipcalc"
        return 1
    fi
    # Note: ipcalc is used to check the subnet ranges. This is a
    # third-party tool. If you want to avoid using external utilities,
    # it is also possible to implement the subnet calculation and
    # comparison logic manually within the script.

    # Finally, we iterate through the WSL2 and Windows IPs to find a
    # matching pair in the same subnet:

    # https://tldp.org/LDP/abs/html/refcards.html#AEN22664
    # https://www.gnu.org/software/bash/manual/html_node/Shell-Parameter-Expansion.html
    # ${string%substring}	Strip shortest match of $substring from back of $string
    # ${string#substring}	Strip shortest match of $substring from front of $string
    #
    for Hostcidr in $Hostips; do
        # set global Hostip
        Hostip="${Hostcidr%/*}"     # n.n.n.n/24 -> n.n.n.n
        Hostprefix="${Hostcidr#*/}" # n.n.n.n/24 -> 24

        for Winip in $Mswindowsips; do
            # ipcalc  [options] ADDRESS[[/]NETMASK] [NETMASK]
            #    -n --nocolor Don't display ANSI color codes
            #
            # Mswindowsnetwork and Hostnetwork are adresses in the form 192.168.0.0/24
            # (The non-significant bits of IP addresses zeroed out)
            # 
            Mswindowsnetwork=$(ipcalc -n "$Winip/$Hostprefix"  | grep Network | awk '{print $2}')
            Hostnetwork=$(ipcalc      -n "$Hostip/$Hostprefix" | grep Network | awk '{print $2}')

            if [[ "$Mswindowsnetwork" == "$Hostnetwork" ]]; then
                Hostipwindows=$Winip      # set global Hostipwindows
                break 2 # break 2 loops # Why not return 0 here?
            fi
        done
    done
    # Once a matching pair is found, the global variables `Hostip` (WSL
    # IP) and `Hostipwindows` (Windows IP) are set. These can then be used
    # to establish xoverip connections and configure the appropriate
    # xhost permissions.
}

