longoptions_collect() {
    #
    # Starting from a space-separated list of options
    # with optional comments (starting with #),
    # create a comma-separated list.
    #
    # Also include an initial comma, to match the original
    # Longoptions value.
    #
    local L1 L2
    L1="$(trim_to_bar "$1"  )"
    #
    # drop comments
    L2=$(echo "$L1" | sed -e 's/#.*//')
    #
    # List of words, comma-separated.
    # 
    # shellcheck disable=SC2086 # (info): Double quote to prevent globbing
    #                             and word splitting. We do want word
    #                             splitting here. Not globbing, though.
    #
    # Add initial comma to match original
    L2=",$(echo $L2  | sed -e 's/[ ][ ]*/,/g'  )"
    #
    # Allow --optname, remove the -- part.
    L2="$(echo $L2 | sed -e 's/,--/,/g')"
    #
    echo "${L2}"
}


# function parse_options()
#
#   Parse cli options
#
parse_options() {
    local Shortoptions
    local Longoptions
    local Parsedoptions
    local Presetoptions
    local Presetfile

    #
    # Shortoptions and Longoptions are passed to /usr/bin/getopt
    #
    Shortoptions="aAcdDfFghHiIKlmnpPqtTvVwWxXyY"
    #
    # Deprecated short options:
    #     -e --exe is deprecated
    Shortoptions="${Shortoptions}e"
    #
    # Longoptions: Comma-separated list of long options.
    #
    # - A single colon after the name means the option has a required
    #   argument.
    #
    # -Two colons mean an optional argument.
    #
    Longoptions="$(longoptions_collect \
    "|# Influencing auto-setup of X/Wayland/x11docker
     | --auto --desktop --tty --wayland --wm:: --xc:: --xonly --xw
     |    
     |# X servers
     | --hostdisplay --nxagent --runx --xephyr --xpra --xpra2 --xorg --xvfb
     |
     |# X servers depending on a Wayland compositor
     | --weston-xwayland --xpra-xwayland --xpra2-xwayland --xwayland --satellite
     |
     |# Wayland compositors without X
     | --hostwayland --weston::
     |
     |# X/Wayland appearance options
     | --border:: --dpi: --fullscreen --output-count: --rotate: --scale: --size:
     |
     |# X/Wayland config
     | --clean-xhost --composite:: --display: --keymap: --vt:: --westonini:
     | --xauth:: --xhost:: --xoverip:: --xtest:: --xopt:
     |    
     |# x11docker config
     | --checkwindow:: --fallback:: --preset: --pull::
     |
     |# Host folders
     | --cachebasedir: --home:: --homebasedir: --share:
     |    
     |# Host integration features
     | --alsa:: --clipboard:: --gpu:: --lang:: --printer:: --pipewire --pulseaudio:: --webcam
     |
     |# Container config
     | --backend: --env: --mobyvm --name: --no-entrypoint
     | --no-setup --rootfs --rootless:: --runtime: --snap --workdir:
     |
     |# Container capabilities
     | --cap-default --ipc:: --limit:: --newprivileges:: --network::
     |
     |# Container user
     | --group-add: --hostuser: --password:: --sudouser:: --user: --shell:
     |
     |# Container init and DBus
     | --dbus:: --init:: --hostdbus --sharecgroup
     |    
     |# Container interaction
     | --stdin --interactive
     |
     |# Additional commands to execute
     | --runasuser: --runfromhost: --runasroot: --xeyes:: --xlogo --xfishtank
     |
     |# Output of vars on stdout
     | --printenv:: --printid:: --printinfofile:: --printpid1::
     |
     |# Verbose options
     | --debug --printcheck --quiet --verbose::
     |
     |# Special options without starting X or container
     | --build --cleanup --help --launcher --licence --license --version
     |
     |# Installation
     | --install --remove --remove-oldprefix --update:: --update-master::
     |
     |# Experimental
     | --experimental --keepcache --remountcgroup --xorgconf:
     |
     |# Deprecated options
     | --dbus-system --enforce-i --exe --homedir:
     | --hostipc --hostnet --iglx --kwin --kwin-xwayland --xwin
     | --no-auth --no-internet --no-xhost
     | --sharedir: --sharessh --systemd --showenv --showid --showinfofile --showpid1
     |
     |# Removed options
     | --cachedir: --no-init --nothing --no-xtest
     | --openrc --podman --pull:: --ps --pw:: --runit --silent --starter
     | --stderr --stdout --sys-admin --sysvinit --tini --trusted --untrusted --vcxsrv --xdummy
     |"  )"
    

    # default preset files
    parse_preset "default" || true

    # options from cli
    # /usr/bin/getopt
    # man getopt
    # https://linuxvox.com/blog/linux-getopt/
    #
    # getopt rearranges the arguments so that all options come before
    #   the non-option arguments. It returns a string containing the
    #   rearranged arguments, which can be used to iterate over the
    #   options and their values.
    #
    Parsedoptions="$(getopt --options "$Shortoptions" --longoptions "$Longoptions" --name "$0" -- "$@" )" \
        || error "Failed to parse options."

    ## Modify positional arguments of ...
    eval set -- "$Parsedoptions"
    
    ## Parsedoptions_global="$Parsedoptions_global${NEWLINE}$Parsedoptions"
    Parsedoptions_global+="${NEWLINE}$Parsedoptions"

    # Catch single -h for usage info, otherwise it means --hostdisplay
    if [ "$*" = "-h --" ] ; then  usage; exit 0 ; fi
    
    # x11docker without options
    if [ "$*" = "--" ] ; then  usage;  exit 0; fi

  while [ $# -gt 0 ]; do
    g_Optionset1="$g_Optionset1${NEWLINE}${1:-}"
    case "${1:-}" in
         --help)              usage ;         exit 0 ;;              # Show help/usage and exit
         --license|--licence) license ;       exit 0 ;;              # Show MIT license and exit
         --version)           echo $Version ; exit 0 ;;              # Output version number and exit
         --xonly)             BackendKind="host"                     # Only create X server # BackendKind_host
                              Containercommand="sleep infinity"
                              Showdisplayenvironment="${Showdisplayenvironment:-yes}" ;;
         --preset)                                                   # Predefined option sets
                              parse_preset "${2:-}" || error "Option --preset: File not found: ${2:-}
  Searching in:
  $Presetdirlocal
  $Presetdirsystem"
                              shift ;;

     #### Choice of X servers and Wayland compositors
         --auto)              Autochooseserver="yes" ;;              # Default: auto-choose X server or Wayland compositor
      -h|--hostdisplay)       Xserver="--hostdisplay" ;;             # Host display :0 with shared X socket
      -H|--hostwayland)       Sharehostwayland="yes" ;;              # --hostwayland, Host wayland.
      -n|--nxagent)           Xserver="--nxagent" ;;                 # nxagent
         --runx)              Xserver="--runx" ;;                    # MS Windows: Will be Xwin or VcXsrv
         --satellite)         Xserver="--satellite" ;;               # rootless Xwayland on already running Wayland. X server xwayland-satellite
      -t|--tty)               Xserver="--tty"  ;;                    # Do not provide any X nor Wayland
      -T|--weston)            Xserver="--weston"                     # Weston Wayland compositor
                              Westonarg="${2:-}"; shift ;;
      -Y|--weston-xwayland)   Xserver="--weston-xwayland" ;;         # Weston + Xwayland
      -y|--xephyr)            Xserver="--xephyr" ;;                  # Xephyr
      -a|--xpra)              Xserver="--xpra" ;;                    # xpra
         --xpra2)             Xserver="--xpra2" ;;                   # xpra server in container and client on host
      -A|--xpra-xwayland)     Xserver="--xpra-xwayland" ;;           # Xpra with vfb Xwayland
         --xpra2-xwayland)    Xserver="--xpra2-xwayland" ;;          # Xpra with vfb Xwayland
      -x|--xorg)              Xserver="--xorg" ;;                    # Xorg
         --xvfb)              Xserver="--xvfb" ;;                    # Xvfb. Invisible on host.
      -X|--xwayland)          Xserver="--xwayland" ;;                # rootfull Xwayland on already running Wayland

     #### Influencing automatic choice of X server or Wayland compositor
      -d|--desktop)           Desktopmode="yes" ;;                   # image contains a desktop environment.
      -g)                     Sharegpu="yes" ;;                      # GPU access
         --gpu)               Sharegpu="${2:-yes}" ; shift ;;        # GPU access
      -W|--wayland)           Setupwayland="yes" ;;                  # set up wayland environment, regards --desktop
      -w)                                        Windowmanagermode="auto" ; Desktopmode="yes" ;;
         --wm)                case "${2:-}" in                       # choose window manager
                                "n"|"none"|"no") Windowmanagermode="none" ;;
                                "host")          Windowmanagermode="host" ;; # Windowmanagermode_host
                                ""|"auto"|"m")   Windowmanagermode="auto" ;;
                                *)               Windowmanagermode="auto"; Windowmanagercommand="${2:-}" ;;
                              esac
                              shift ; Desktopmode="yes" ;;
         --xc)                Xcontainer_option="${2:-yes}" ; shift ;;      # Run X server in container
         --xw)                Xwogether="yes" ;;                     # Run X and Wayland side by side

     #### X and Wayland appearance
