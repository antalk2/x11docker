# Function: check_backend
# Usage: check_backend
#
# Brief: Check ...
#
# CommandlineOption:  --backend, --rootless
#
# Used-by: main()
#
# Globals:
#
#   Dockervm :rw
#   g_BackendKind :r
#   g_Backendbin= :w
#   Installermode :r
#   g_Imagename= :rw
#   g_Rootfs=    :w
#   g_Imagebasename= :w (in check_backend)
#   g_Containercommand= :rw
#   Codename=         :rw
#
#   g_Network= :w
#   Shareipc=  :w
#   Createcontaineruser= :w
#   Containersetup= :w
#   Capdropall= :w
#   Allownewprivileges= :w
#   Runtime= :w
#   Sharecgroup= :w
#   g_Limitresources= :w
#   Switchcontaineruserflag= :w
#   Sudouser= :rw
#   Sharefoldercontainer :w
#   Sharefolder :r
#
#   Sharealsa :w
#   Capdropall :w
#   Langwunsch :w
#   g_Noentrypoint :w
#   Sharecupsmode :w
#   Pulseaudiomode :w"
#   Runasroot :w
#   Runtime :w
#   SharevolumesArray :w
#   Sharewebcam :w
#
#
check_backend() {
    local Checkrootfs=""
    local l_Backendinfo=""

    if case_match "$Dockervm" 'no|desktop' ; then
        #
        case "$g_BackendKind" in
            docker|podman|nerdctl)
                g_Backendbin="$(command -v "$g_BackendKind")"
                ;;
        esac
        #
        case "$g_BackendKind" in
            docker)
                docker info | grep -q "desktop-linux"  && {
                    #
                    # Docker Desktop initial support commit: 2026-01-04
                    # https://github.com/mviereck/x11docker/commit/7fae327b63df1fee99328c3c214702b92537d1eb
                    #
                    note_ttm \
                        "|docker in version 'Docker Desktop' found.
                         |  Docker Desktop runs in a virtual machine and makes host integration
                         |  rather difficult. Support is experimental yet, feedback is appreciated.
                         |  For docker errors like 'bind source path does not exist: FILE' you can try
                         |  to allow file sharing in Docker Desktop GUI for file FILE.
                         |  Rather use native 'Docker Engine' running on your host linux kernel.
                         |  Docker Engine would allow all x11docker features and performes much better."
                    #
                    Dockervm="desktop"
                }
                ;;
        esac

    elif case_match "$Dockervm" 'moby' ; then
        # [ "$Dockervm" = moby ] implies "MS Windows" and (WSL1|WSL2)
        if ! case_match  "$g_BackendKind" 'docker | host' ; then
            error_ttm \
                "|Option --backend=$g_BackendKind is not supported on MS Windows yet.
                 |  If you need this, ask for support at https://github.com/mviereck/x11docker"
            return 1
        fi
        #
        g_Backendbin="docker.exe"
        if ! have_command  "$g_Backendbin"  ; then
            PATH="$(trim_to_mark \
                 "|${PATH:-}
                  ::$(convertpath subsystem "C:/Program Files/docker")
                  ::$(convertpath subsystem "C:/Program Files/Docker/Docker/resources/bin")"
                  )"
            export PATH
        fi
    fi

    case "$g_BackendKind" in
        docker|podman|nerdctl|proot)
            case "$Installermode" in
                "") 
                    if [ -z "$g_Backendbin" ] ; then
                        # If not in Installermode, missing g_Backendbin is an error
                        error "Option --backend=$g_BackendKind: No binary found for $g_BackendKind."
                    fi
                    ;;
                *)
                    if [ -z "$g_Backendbin" ] ; then
                        # In Installermode,  missing g_Backendbin is just a note.
                        note "Option --backend=$g_BackendKind: No binary found for $g_BackendKind."
                    fi
                    # And in Installermode, we skip the rest of check_backend()
                    return 1
                    ;;
            esac
            ;;
        host)  # BackendKind_host
            g_Backendbin=""
            ;;
    esac

    case "$g_BackendKind" in
        docker|podman|nerdctl)
            if   [ -n "$Jqbin"     ];  then debugnote "check_backend(): will parse json using $Jqbin"
            elif [ -n "$Pythonbin" ];  then debugnote "check_backend(): will parse json using $Pythonbin"
            else
                error_ttm  "|x11docker needs  'jq' or 'python' to parse output of '$g_BackendKind inspect'.
                            |  Please install 'jq' or 'python' version 2.x or 3.x."
            fi
            ;;
    esac

    # Backendrootless : rootful or rootless
    {
        if [ "$Backendrootless" = "no" ] ; then
            export DOCKER_HOST=""
        fi
        #
        if [ -z "$Backendrootless" ] ; then
            case "$g_BackendKind" in
                docker)
                    if [ "$(id -un)" = "root" ]                      ; then Backendrootless="no"
                    elif grep -q "/run/user/" <<< "${DOCKER_HOST:-}" ; then Backendrootless="yes"
                    elif word_is_in 'docker' "$(id -G -n)"           ; then Backendrootless="no"
                    else
                        : # nop
                    fi
                    ;;
                podman|nerdctl)
                    if [ "$(id -u)" = "0" ] ; then   Backendrootless="no"
                    else                             Backendrootless="yes"
                    fi
                    ;;
                proot)
                    # leave Backendrootless empty
                    ;;
                host)   # BackendKind_host
                    # leave Backendrootless empty
                    ;;
            esac
        fi
    }

    #
    # For rootless docker, set DOCKER_HOST
    #
    if case_match "$Backendrootless" 'yes' ; then
        if case_match "$g_BackendKind"  'docker' ; then
            #
            # Set DOCKER_HOST for "rootless docker"
            #
            DOCKER_HOST="${DOCKER_HOST:-/run/user/$Hostuseruid/docker.sock}"
            DOCKER_HOST="${DOCKER_HOST#unix://}"
            if [ ! -e "${DOCKER_HOST:-}" ] ; then
                error_ttm \
                    "|Option --rootless --backend=docker: docker user socket not found.
                     |  Docker user daemon not running? Try to start it with:
                     |    systemctl --user start docker"
                #
            fi
            DOCKER_HOST="unix://$DOCKER_HOST"
            export DOCKER_HOST
        else
            : # NOP
        fi
    elif  case_match "$Backendrootless" 'no' ; then
        if   case_match "$g_BackendKind" 'docker' ; then
            # rootful docker needs user root or group docker.
            if [ "$(id -un)" != "root" ]           \
            && ! word_is_in 'docker' "$(id -G -n)" ;
            then
                error_ttm  "|Option --rootless=no: Please run x11docker as root
                            |  to allow rootful $g_BackendKind."
            fi
        elif case_match "$g_BackendKind" 'podman|nerdctl' ; then
            # rootful podman and rootful nerdctl needs user root
            if [ "$(id -un)" != "root" ] ; then
                error_ttm "|Option --rootless=no: Please run x11docker as root
                           |  to allow rootful $g_BackendKind."
            fi
        fi
    fi

    #
    # check_runtime
    #
    if case_match "$g_BackendKind"  'docker|podman|nerdctl' ; then
        #
        # Check whether docker daemon is running, get backend info
        #
        l_Backendinfo="$(unpriv_backend "env LC_ALL=C $g_Backendbin info --format='{{json .}}'" 2>&1)"
        if [ "$?" != "0" ]                                \
        || grep -q "permission denied" <<< "$l_Backendinfo" \
        || [ -z "$l_Backendinfo" ]                          ;
        then
            error_ttm \
                "|Option --backend=$g_BackendKind: Error executing $g_BackendKind.
                 |  If using docker: Is docker daemon running at all?
                 |  Maybe you need root privileges to run docker?
                 |  Try to start docker daemon with 'systemctl start docker'.
                 |  Try to run x11docker as root.
                 |  Output of '$g_Backendbin info':
                 |  $l_Backendinfo"
            #
        fi
        check_runtime  "${l_Backendinfo}"  # uses $l_Backendinfo
    fi

    # g_Imagename, g_Rootfs, g_Imagebasename, Codename, g_Containercommand
    {
        if  case_match "$g_BackendKind"  'docker|podman|nerdctl|proot' ; then

            if [ "${g_Imagename:0:1}" = "/" ] ; then
                g_Rootfs="$g_Imagename"
                g_Imagename="$(basename "$g_Rootfs")"
            fi
            if [ "$g_Podmanrootfs" = "yes" ] ; then
                Checkrootfs="yes"
            fi
            #
            g_Imagebasename="$(echo "$g_Imagename" | tr / - | cut -d: -f1)"
            Codename="${Codename:-"$g_Imagename $g_Containercommand"}"
            verbose_ttm "|Image name: $g_Imagename
                         |  Container command: $g_Containercommand"
            #
        elif case_match "$g_BackendKind" 'host' ; then  # BackendKind_host

            g_Containercommand="$g_Imagename $g_Containercommand"
            if [ "$Customdockeroptions" ] ; then
                error_ttm \
                    "|Option --backend=$g_BackendKind does not take CUSTOM_RUN_OPTIONS.
                     |  If your command args contain ' -- ', run like
                     |  x11docker --backend=$g_BackendKind [OPTIONS] -- -- COMMAND -- ARGS"
                #
            fi
            g_Imagename=""
            g_Imagebasename="$(basename "$g_Containercommand" | cut -d' ' -f1)"
            Codename="${Codename:-"$g_Imagebasename"}"
        fi

        Codename="$(unspecialstring "$Codename" | cut -c1-40)"
        Codename="${Codename:-noname}"
        #
        # The replacement character in unspecialstring must be - for
        # backwards compatibility of --home
        g_Imagebasename="$(unspecialstring "$g_Imagebasename")"
        g_Imagebasename="${g_Imagebasename:-noname}"
    }

    case "$g_BackendKind" in
        docker)
            : # NOP
            ;;
        podman)
            # /proc/sys/kernel/unprivileged_userns_clone might exist on debian only.
            # https://github.com/mviereck/x11docker/issues/255#issuecomment-758014962
            if [ "$(cat /proc/sys/kernel/unprivileged_userns_clone 2>/dev/null)" = "0" ] ; then
                error_ttm "|Option --backend=podman: Linux kernel disallows
                           |  unprivileged user namespace setup. Please run as root:
                           |    sysctl -w kernel.unprivileged_userns_clone=1"
            fi
            #
            store_runoption_cap "CHOWN"
            ;;
        nerdctl)
            note_ttm "|Option --backend=nerdctl: Support of nerdctl is experimental yet.
                      |  In production rather use docker or podman for now."
            #
            Switchcontaineruserflag="yes"
            if [ "$Capdropall" = "yes" ] ; then
                note_ttm "|Option --backend=nerdctl: If you encounter issues,
                          |  please try with option --cap-default to remove some container restrictions."
                #
            fi
            ;;
        proot)
            warning_ttm "|Option --backend=$g_BackendKind: Your host system is NOT PROTECTED.
                         |  There is close to no isolation like a real container could provide.
                         |  Effectively applications in proot have the same privileges as if
                         |  they would have been installed and started directly on the host system."
            #
            check_optionset                                \
                "--backend=$g_BackendKind"                   \
                                                           \
                "$(trim_to_mark                            \
                 "|--cap-default   --hostipc
                  : --ipc --limit  --network
                  : --newprivileges
                  : --no-setup --runtime
                  : --sharecgroup
                  : --user"
                  )"  || :
            #
            if ! check_optionset "--backend=$g_BackendKind" "--user" ; then
                error_ttm "|Option --backend=$g_BackendKind: Option --user is not allowed.
                           |  Please try option --hostuser instead."
            fi
            #
            Checkrootfs="yes"
            #
            # Set defaults. Some might look misleading just to avoid
            #               later messages, but not affecting the setup.
            #
            g_Network="host" # g_Network_host
            Shareipc="host"  # Shareipc_host
            Createcontaineruser="yes"
            Containersetup="yes"
            Capdropall="yes"
            Allownewprivileges="no"
            Runtime=""
            Sharecgroup="no"
            g_Limitresources=""
            # needed
            Switchcontaineruserflag="yes"

            if [ "$Sudouser" ] ; then
                note_ttm \
                    "|Option --backend=$g_BackendKind --sudouser: sudo fails in $g_BackendKind.
                     |  Workaround: starting with user root.
                     |  You can switch to user $g_Containerusername with 'su $g_Containerusername'.
                     |  Note that root in $g_BackendKind is a fake and does not have real root privileges."
                #
            fi
            ;;

        host)  # BackendKind_host
            warning_ttm "|Option --backend=host provides no isolation at all.
                         |  It only provides an X server for a host application."
            #
            storeinfo_add_kv_sh "containerrootrc=ready"
            Sharefoldercontainer="$Sharefolder"
            # --dbus, --hostdbus, --init
            check_optionset "--backend=$g_BackendKind" \
                            "$(trim_to_mark "|--alsa --cap-default --group-add
                                             : --hostipc --ipc --limit
                                             : --home --name --network
                                             : --newprivileges --no-entrypoint
                                             : --no-setup
                                             : --printer --pulseaudio --runasroot
                                             : --runtime --share --sharecgroup
                                             : --sudouser --webcam"
                                              )" || :
            #
            #
            if ! check_optionset "--backend=$g_BackendKind" "--user" ; then
                error "|Option --backend=$g_BackendKind: Option --user is not allowed.
                       |  Please try option --hostuser instead."
            fi
            #
            # Set defaults. Some might look misleading just to avoid
            #               later messages, but not affecting the setup.
            #
            Sharealsa="no"
            Capdropall="yes"
            Shareipc="host" # Shareipc_host
            [ "$Langwunsch" ] && store_runoption_env "LANG=$Langwunsch"
            g_Limitresources=""
            g_Network="host" # g_Network_host
            Allownewprivileges="no"
            g_Noentrypoint=""
            Containersetup="yes"
            Sharecupsmode=""
            Pulseaudiomode=""
            Runasroot=""
            Runtime=""
            SharevolumesArray=""
            Sharecgroup="no"
            Sudouser=""
            Sharewebcam=""
            ;;
    esac

    if [ "$Checkrootfs" = "yes" ] ; then
        case "$g_BackendKind" in
            proot)
                : # NOP
            ;;
            podman)
                note "Option --backend=podman with --rootfs is experimental yet."
                if [ "$Containersetup" = "yes" ] ; then
                    Switchcontaineruserflag="yes"
                fi
                ;;
            *)  # BackendKind_host
                error "Option --rootfs is supported by backends proot and podman only."
                ;;
        esac

        if [ -z "$g_Rootfs" ] ; then
            if      [ -d "$Hosthomebasefolder/ROOTFS/$g_Imagebasename" ] ; then
                g_Rootfs="$Hosthomebasefolder/ROOTFS/$g_Imagebasename"
            else
                error_ttm "|Option --backend=$g_BackendKind: Did not find a rootfs for $g_Imagename
                           |  in $Hosthomebasefolder/ROOTFS/$g_Imagebasename"
            fi
        fi
        #

        if [ -z "$g_Containercommand" ] && [ -e "$g_Rootfs/start" ] ; then
            g_Containercommand="/bin/sh /start"
        fi

        if [ -z "$g_Containercommand" ] ; then
            #
            # Fallback for g_Containercommand
            #
            if   [ "$Containerusershell" != "auto" ] ; then g_Containercommand="$Containerusershell"
            elif [ -e "$g_Rootfs/bin/bash" ]         ; then g_Containercommand="/bin/bash"
            else                                            g_Containercommand="/bin/sh"
            fi
            #
            note_ttm "|Option --backend=$g_BackendKind: No command specified.
                      |Fallback: using command '$g_Containercommand' and enabling option --interactive."
            #
            check_fallback
            g_Interactive="yes"
        fi

    fi # Checkrootfs

    debugnote "Backend: $g_BackendKind, Backendbin: $g_Backendbin, Rootless: $Backendrootless"
    return 0
} # check_backend



# Function: check_image
# Brief: Get some image information
#
# Globals:
#    g_Backendbin
#    g_Imagename
#    Containerlogfile
#    g_BackendKind
#    Backendrootless
#    g_Imagearchitecture= :w
#    g_Containercommand= :w
#    g_Containerusername= :w
#    g_Workdir= :w
#
# Files:
#    2>> $Containerlogfile
#
check_image() {

    local l_Imageinspect=""
    local l_Imagecommand=""
    local l_Imageuser=""
    local l_Imageentrypoint=""
    local l_Imageworkdir=""

    # Check if image $g_Imagename is available locally
    l_Imageinspect="$(unpriv_backend "$g_Backendbin inspect $g_Imagename" 2>> $Containerlogfile)" || {
        error_ttm "|Image $g_Imagename not found locally.
                   |  Please pull or build image first. (Backend $g_BackendKind, rootless $Backendrootless)"
        #
        return 1
    }

    # Check architecture
    g_Imagearchitecture=$(parse_inspect "$l_Imageinspect" "Architecture")
    debugnote "Image architecture: $g_Imagearchitecture"

    # Check CMD
    l_Imagecommand="$(parse_inspect "$l_Imageinspect" "Config" "Cmd")"
    debugnote "Image CMD: $l_Imagecommand"
    if [ -z "$g_Containercommand" ] ; then
        g_Containercommand="$l_Imagecommand"
        if grep -q "$(convertpath share "$Containerrc")" <<< "$l_Imagecommand" ; then
            error_ttm "|Recursion error: Found CMD $l_Imagecommand in image.
                       |  Did you use 'docker commit' with an x11docker container?
                       |  Please build new images with a Dockerfile instead of using docker commit,
                       |  or provide a different container command in x11docker command."
            #
        fi
    fi

    # Check USER
    l_Imageuser="$(parse_inspect "$l_Imageinspect" "Config" "User")"
    debugnote "Image USER: $l_Imageuser"
    case "$Createcontaineruser" in
        yes)
            if [ "$l_Imageuser" ] ; then
                note_ttm \
                    "|Found 'USER $l_Imageuser' in image.
                     |  If you want to run with user $l_Imageuser instead of host user $g_Containerusername,
                     |  than run with option --user=RETAIN."
            fi
            ;;
        no)
            g_Containerusername="${l_Imageuser:-root}"
            ;;
    esac
    storeinfo_add_kv_sh "containeruser=$g_Containerusername"

    # Check ENTRYPOINT
    l_Imageentrypoint="$(parse_inspect "$l_Imageinspect" "Config" "Entrypoint")"
    debugnote "Image ENTRYPOINT: $l_Imageentrypoint"
    case "$g_Noentrypoint" in
        yes) g_Containerentrypoint="" ;;
        no)
            g_Containerentrypoint="$l_Imageentrypoint"
            case "$g_Initsystem" in
                systemd|sysvinit|runit|openrc|tini)
                    if grep -qE 'tini|init|systemd' <<< "$g_Containerentrypoint" ; then
                        note_ttm "|There seems to be an init system in ENTRYPOINT of image:
                                  |    $g_Containerentrypoint
                                  |  Will disable it as x11docker already runs an init with option --$g_Initsystem.
                                  |  To allow this ENTRYPOINT, run x11docker with option --init=none."
                        #
                        g_Containerentrypoint=""
                    fi
                    ;;
                s6-overlay)
                    if [ "$g_Containerentrypoint" = '/init' ] ; then
                        g_Containerentrypoint=""
                        if [ -z "$g_Containercommand" ] ; then
                            g_Containercommand="sh -c 'while :; do sleep 10; done'"
                        fi
                    fi
                    ;;
                none)
                    if grep -qE 'tini|init|systemd' <<< "$g_Containerentrypoint" ; then
                        note_ttm "|There seems to be an init system in ENTRYPOINT of image:
                                  |    $g_Containerentrypoint
                                  |  Returning correct exit code of container command will likely fail."
                    fi
                    ;;
            esac
            ;;
    esac

    # Check WORKDIR
    l_Imageworkdir="$(parse_inspect "$l_Imageinspect" "Config" "Workdir")"
    # It seems Config.Workdir is Config.WorkingDir in more recent
    # versions?
    if [ -z "$l_Imageworkdir" ] ; then
        l_Imageworkdir="$(parse_inspect "$l_Imageinspect" "Config" "WorkingDir")"
    fi
    debugnote "Image WORKDIR: $l_Imageworkdir"
    if [ -z "$g_Workdir" ] && [ -n "$l_Imageworkdir" ] ; then
        note_ttm "|Found 'WORKDIR $l_Imageworkdir' in image.
                  |  You can change it with option --workdir=DIR."
        #
        g_Workdir="$l_Imageworkdir"
    fi

    if [ -z "$g_Containercommand"    ] \
    && [ -z "$g_Containerentrypoint" ] ;
    then
        error 'No container command specified and no CMD or ENTRYPOINT found in image.'
    fi

    return 0
} # check_image

# Function: check_runtime
# Usage: check_runtime Backendinfo
#
# Used-by: check_backend
#
# Globals:
#
#    g_BackendKind
#    l_Backendinfo :r
#    Runtime= :rw
#
# CommandlineOption: --runtime
#
check_runtime() {

    local l_Backendinfo="${1:-}"
    local local_Defaultruntime

    if [ -z "${l_Backendinfo}" ] ; then
        error 'check_runtime(): Backendinfo ($1) is empty'
    fi
    
    case "$g_BackendKind" in
        docker)
            # l_Backendinfo / "DefaultRuntime"
            local_Defaultruntime="$( parse_inspect       \
                                       "$l_Backendinfo"  \
                                        "DefaultRuntime" \
                                     | tr -d '"'         )"
            ;;
        podman)
            # l_Backendinfo / "host" / "ociRuntime" / "name"
            # literal host
            local_Defaultruntime="$( parse_inspect                  \
                                       "$l_Backendinfo"             \
                                        "host"  "ociRuntime" "name" \
                                     | tr -d '"'                    )"
            ;;
        nerdctl)
            local_Defaultruntime=""
            ;;
    esac

    debugnote "Default runtime: $local_Defaultruntime"
    if [ -z "$Runtime" ] ; then
        Runtime="$local_Defaultruntime"
    fi

    case "$Runtime" in
        "")
            : # NOP
            ;;
        runc|crun|oci|nvidia|kata-runtime)
            : # NOP
        ;;
        sysbox-runc)
            if ! have_command sysbox-runc ; then
                debugnote_ttm "|check_runtime(): The command 'sysbox-runc' not found.
                               |May require installation.
                               |See: https://github.com/nestybox/sysbox
                               |"
            fi
            #
            # https://github.com/nestybox/sysbox
            #
            #
            # While Sysbox's default behavior for assigning
            # capabilities is beneficial in most cases, it has the
            # drawback that it does not allow fine-grained control of
            # the capabilities used by the Sysbox container init
            # process (e.g., Docker's --cap-add and --cap-drop don't
            # have any effect). In some situations, having such
            # control is beneficial.
            #
            # To overcome this, starting with Sysbox v0.5.0 it's
            # possible to configure Sysbox to honor the capabilities
            # passed to it by the higher level container manager
            # (e.g., Docker or Kubernetes) via the container's OCI
            # spec.
            #
            # The configuration can be done on a per-container basis,
            # or globally for all containers.
            #
            # To do this on a per-container basis, pass the
            # SYSBOX_HONOR_CAPS=TRUE environment variable to the
            # container, as follows: [...]
            #
            #
            store_runoption_env "SYSBOX_HONOR_CAPS=TRUE"
            check_optionset "--runtime=sysbox-runc" "--alsa --webcam" || :
            #
            if version_less_than "$(uname -r)" "5.12" ; then
                error_ttm "|Option --runtime=sysbox-runc needs at least
                           |  Linux kernel version >=5.12"
            fi
            #
            if version_less_than "$(sysbox-runc -v | grep version | tr -d ' \t'| cut -d: -f2)" "0.5" ; then
                error_ttm "|Option --runtime=sysbox-runc needs at least
                           |  Sysbox version >=0.5.0"
            fi
            ;;

        *)
            note_ttm "|Option --runtime: x11docker does not know runtime: '$Runtime'
                      |  Will try to use it anyway.
                      |  If that fails, you can try options --snap or --no-setup."
            #
            ;;
    esac

    if [ ! -z "$Runtime" ] ; then
        if ! have_command "$Runtime" ; then
            error_ttm "|check_runtime(): --runtime=\"$Runtime\"
                       |  The command '$Runtime' not found.
                       |  Probably needed.
                       |"
        fi
    fi

    return 0
} # end check_runtime

# Function: check_smallinit
# Brief: Find container init binary on host, set g_Initbinaryfile
#
# 
#
# Globals:
#    Xcontainer_option
#    Xcontainertools
#    Sharefolder
#    g_Initbinaryfile=
#    Localsharedir
#    g_Initsystem
#
# Used-by: setup_initsystem()
#
check_smallinit() {
    #
    if [ "$Xcontainer_option" = "yes" ]           \
    && grep -q "catatonit" <<< "$Xcontainertools" ;
    then
        g_Initbinaryfile="$Sharefolder/catatonit"
        return 0
    fi
    #
    # Find the first that is executable
    if [ ! -x "$g_Initbinaryfile" ] ; then  g_Initbinaryfile="$( command -v catatonit || : )"           ; fi
    if [ ! -x "$g_Initbinaryfile" ] ; then  g_Initbinaryfile="/usr/libexec/catatonit/catatonit"         ; fi
    if [ ! -x "$g_Initbinaryfile" ] ; then  g_Initbinaryfile="$(command -v docker-init || : )"          ; fi
    if [ ! -x "$g_Initbinaryfile" ] ; then  g_Initbinaryfile="/usr/local/share/x11docker/tini-static"   ; fi
    if [ ! -x "$g_Initbinaryfile" ] ; then  g_Initbinaryfile="/usr/bin/tini-static"                     ; fi
    if [ ! -x "$g_Initbinaryfile" ] ; then  g_Initbinaryfile="$Localsharedir/tini-static"               ; fi
    if [ ! -x "$g_Initbinaryfile" ] ; then  g_Initbinaryfile="/snap/docker/current/bin/docker-init"     ; fi
    if [ ! -x "$g_Initbinaryfile" ] ; then  g_Initbinaryfile="/snap/docker/current/usr/bin/docker-init" ; fi
    #
    g_Initbinaryfile="$( myrealpath "$g_Initbinaryfile" 2>/dev/null || : )"
    #
    if [ ! -x "$g_Initbinaryfile" ] ; then  g_Initbinaryfile="" ; fi

    if [ -z "$g_Initbinaryfile" ] ; then
        note_ttm "|Option --init=$g_Initsystem: Did not find a tini container init system.
                  |  Please install catatonit or tini-static.
                  |  $Wikipackagesimage"
        return 1
    fi
    return 0
} # end check_smallinit

# Function: check_cgroup
# Brief: Check [and create] cgroup mountpoint for systemd or elogind
#
# Globals:
#
#   g_Initsystem
#   g_BackendKind
#   Cgroupversion
#
check_cgroup() {
    local Remounted
    local Needcgroup

    if [ "$g_Initsystem" = "systemd" ] ;
    then Needcgroup="systemd"
    else Needcgroup="elogind"
    fi

    if [ "$g_BackendKind" = "docker" ] ; then

        case "$Cgroupversion" in
            v1) 
                Sharecgroup="yes"
                ;;
            v2)
                if [ "$g_Initsystem" =  'systemd' ] \
                && [ "$Runtime"  != 'sysbox-runc' ] ;
                then
                    g_Remountcgroup="yes"
                    warning_ttm \
                        "|Option --init=systemd: To support systemd in docker container
                         |  with cgroupv2 on host, x11docker shortly runs a privileged container
                         |  of '$g_Imagename' with 'nsenter' to remount the container's /sys/fs/cgroup.
                         |  Evil images might be set up to abuse these privileges."
                fi
                ;;
        esac

        if case_match "$g_Initsystem"  'sysvinit|openrc|runit' ; then
            Sharecgroup="yes"
        fi
    fi

    if [ "$Sharecgroup" = "yes" ] ; then
        warning "Option --init=$g_Initsystem: Sharing /sys/fs/cgroup from host."
    fi

    {
        # Needcgroup
        if findmnt "/sys/fs/cgroup/$Needcgroup" >/dev/null 2>&1 ; then
            # Exists, done.
            return 0
        else
            : # go on below
        fi

        case "$g_Initsystem" in
            systemd)
                case "$Cgroupversion" in
                    v1) 
                        if [ "$Startuser" != "root" ] ; then
                            note_ttm "|Option --init=$g_Initsystem: Did not find /sys/fs/cgroup/$Needcgroup
                                      |  Startup of container is likely to fail."
                        fi
                        ;;
                    v2)
                        Needcgroup=""
                        ;;
                esac
                ;;
            *)
                # not systemd
                note_ttm "|Option --init=$g_Initsystem: Did not find /sys/fs/cgroup/$Needcgroup
                          |  A possible elogind service in container is likely to fail."
                ;;
        esac
        
        if [ -z "$Needcgroup" ] ; then
            return 0
        fi
    }

    if [ "$Startuser" != "root" ] ; then
        note_ttm \
            "|Option --init=$g_Initsystem: To create and mount a cgroup
             |  for $Needcgroup, please run x11docker as root.
             |  Or create cgroup mountpoint on host yourself with:
             |    mount -o remount,rw cgroup /sys/fs/cgroup
             |    mkdir -p /sys/fs/cgroup/$Needcgroup
             |    mount -t cgroup cgroup /sys/fs/cgroup/$Needcgroup -o none,name=$Needcgroup"
        #
        return 1
    fi

    if [ "$Sharecgroup" = "yes" ] && [ "$Startuser" = "root" ] ; then
        note "Option --init=$g_Initsystem: Creating cgroup mountpoint on host for '$Needcgroup'."
        if findmnt /sys/fs/cgroup -O ro >/dev/null ; then
            mount -o remount,rw cgroup /sys/fs/cgroup >> "$Containerlogfile" 2>&1
            Remounted=yes
        fi
        mkdir -p /sys/fs/cgroup/$Needcgroup >> "$Containerlogfile" 2>&1
        mount -t cgroup cgroup /sys/fs/cgroup/$Needcgroup -o none,name=$Needcgroup  >> "$Containerlogfile" 2>&1
        #
        if [ "${Remounted:-}" = "yes" ] ; then
            mount -o remount,ro cgroup /sys/fs/cgroup  >> "$Containerlogfile" 2>&1
        fi
    fi
  
    return 0
} # end check_cgroup

# Function: check_containerhomebasedir
# Brief: Set Hosthomebasefolder
#
# CommandlineOption: --homebasedir, --home
#
# Globals:
#
#     g_BackendKind
#     Localsharedir
#     Hosthomebasefolder= :rw
#     Dockervm
#     Containeruserhosthome
#
check_containerhomebasedir() {
    ##
    ## option '--homebasedir': Specify base folder here to store
    ##                         container home folders for --home
    ##
    if   case_match "$g_BackendKind" 'proot' ; then
        # Q: Override, even if already set?
        Hosthomebasefolder="$Localsharedir"
        #
    elif case_match "$g_BackendKind" 'docker|podman|nerdctl' \
         &&  [ -z "$Hosthomebasefolder" ]                  ;
    then
        if   case_match "$Dockervm" 'no|desktop' ; then
            Hosthomebasefolder="$Containeruserhosthome/.local/share/x11docker"
            #
        elif case_match "$Dockervm" 'moby'       ; then
            Hosthomebasefolder="$( convertpath subsystem "$(wincmd 'echo %userprofile%')
                                ")/x11docker/home"
        else
            : # unexpected Dockervm ?
        fi
    else
        : # unexpected g_BackendKind ?
    fi
}

#
# Globals:
#
#  g_Imagebasename (in check_containerhome) 
#
check_containerhome() {         # option --home: check HOME of container user.
  ## option '--home':        Share folder ~/.local/share/x11docker/imagename with created container as its home directory
  ## option '--home=DIR':    Share custom host folder as home

  # rootless with userns-remap
  [ "$Backendrootless" = "yes" ] && {
    case "$g_BackendKind" in
      docker|nerdctl)
        [ "$Sharehome" != "no" ] && {
          note "Option --home is not supported in $g_BackendKind rootless mode.
  In rootless mode only option --backend=podman supports option --home.
  Alternatively run one of docker, podman or nerdctl in rootful mode.
  Fallback: Disabling option --home"
          check_fallback
          Sharehome="no"
        }
      ;;
    esac
  }

  case "$Sharehome" in
    yes|host) # Sharehome_host
      [ -z "$Persistanthomevolume" ] && Persistanthomevolume="$Hosthomebasefolder/$g_Imagebasename"
      Persistanthomevolume="${Persistanthomevolume//"~"/"$Hostuserhome"}"
      [ "${Persistanthomevolume:0:1}" = "/" ] && Sharehome="host" || Sharehome="volume" # Sharehome_host
    ;;
  esac

  case "$Sharehome" in
    host)
      case "$Createcontaineruser" in
        no)
          note "Option --home or --home=DIR is not supported
  with option --user=RETAIN.
  Alternatively, specify a docker volume with --home=VOLUME.
  Also you can use option --share to share host directories.
  Fallback: Disabling option --home."
          check_fallback
          Sharehome="no"
        ;;
        yes)
          grep -q "unknown" <<< "$g_Containerusername" && {
            note "Option --home: Sharing a host folder is allowed only
  for container users that also exist on host.
  You can use a docker volume with --home=VOLUME instead.
  Fallback: Disabling option --home."
            check_fallback
            Sharehome="no"
          }
        ;;
      esac
    ;;
  esac

  case "$Sharehome" in
    host)
      Containeruserhomebasefolder="/home"
      [ "$g_Containerusername" = "root" ] && Containeruserhomebasefolder="/"
      # A change can break existing configs, e.g. playonlinux
#      Containeruserhomebasefolder="/home.x11docker"
      [ "$Persistanthomevolume" = "$Containeruserhosthome" ] && {
        # --home=$HOME must be same as on host #243
        Containeruserhomebasefolder="$(dirname "$Containeruserhosthome")"
        Containeruserhome="$Containeruserhosthome"
      }
    ;;
    no)
#      Containeruserhomebasefolder="/home.tmp"
      Containeruserhomebasefolder="/home"
      [ "$g_Containerusername" = "root" ] && Containeruserhomebasefolder="/"
    ;;
    volume)
      Containeruserhomebasefolder="/home.volume/$Persistanthomevolume"
      grep -q "/" <<< "$Persistanthomevolume" && error "Option --home: Invalid argument: '$Persistanthomevolume'
  Please either specify an absolute path beginning with '/'
  or specify a docker volume without any '/'."
    ;;
  esac
  [ "$Createcontaineruser" = "yes" ] && Containeruserhome="${Containeruserhome:-$Containeruserhomebasefolder/$g_Containerusername}"
  [ "$Sharehome" != "no" ] && store_runoption_env "HOME=$Containeruserhome"

#  case "$Createcontaineruser" in
#    no)  store_runoption_env "HOME=/tmp" ;;
#  esac

  case "$Sharehome" in
    host)
      # if no home folder on host is specified (--home=DIR), create a standard one in ~/.local/share/x11docker
      [ -d "$Persistanthomevolume" ] || {
        #[ "$Startuser" = "root" ] && su "$g_Containerusername" -c "mkdir -p '$Persistanthomevolume'"
        [ "$g_Containerusername" = "$Hostuser" ] && mkfolder "$Persistanthomevolume" && {
          # create symbolic link to ~/x11docker
          echo "$Persistanthomevolume" | grep -q .local/share/x11docker && [ ! -e "$Hostuserhome/x11docker" ] && unpriv "ln -s '$Hosthomebasefolder' '$Hostuserhome/x11docker'" ||:
        }
      }
      [ -d "$Persistanthomevolume" ] || error "Option --home: Could not create persistent home folder for
  user '$g_Containerusername' on host. Can e.g. happen with option --user.
  Four possibilities to solve issue:
  1.) Run x11docker one time as user '$g_Containerusername'.
  2.) Run x11docker one time as user 'root'.
  3.) Use option --home=DIR with DIR pointing to a writeable folder.
  4.) Use option --home=VOLUME to use a docker volume."
      writeaccess "$Containeruseruid" "$Persistanthomevolume" || warning "User '$g_Containerusername' might have no write access to
  $Persistanthomevolume."
      verbose "Sharing directory $Persistanthomevolume
  with container as its home directory $Containeruserhome"
    ;;
    volume)
      debugnote "Option --home: Using docker volume $Persistanthomevolume"
    ;;
  esac

  return 0
}

check_containeruser() {         # check container user (also option --user)
  ## check container user
  [ "$g_Containerusername" = "RETAIN" ] && {
    Createcontaineruser="no"
    g_Containerusername=""
    return 0
  }

  [ -z "$g_Containerusername" ] && g_Containerusername="$Hostuser"               # default: containeruser = hostuser. can be changed with --user
  [ -n "$g_Containerusername" ] && echo "$g_Containerusername" | grep -q ':' && {  # option --user can specify a group/gid after :
    Containerusergid="$(echo "$g_Containerusername" | cut -d: -f2)"
    g_Containerusername="$(echo "$g_Containerusername" | cut -d: -f1)"
  }
  [ "$g_Containerusername" = "root" ] && g_Containerusername="0"
  [ -n "$(mygetent passwd "$g_Containerusername")" ] && {                      # user exists on host
    g_Containerusername=$(mygetent passwd "$g_Containerusername" | cut -d: -f1)      # can be name or uid -> now name
    Containeruseruid=$(mygetent passwd "$g_Containerusername" | cut -d: -f3)
    [ -z "$Containerusergid" ] && Containerusergid="$(mygetent passwd "$g_Containerusername" | cut -d: -f4)"
    [ "$g_Containerusername" = "$Hostuser" ] && Containeruserhosthome="$Hostuserhome"
    [ -z "$Containeruserhosthome" ]    && Containeruserhosthome="$(mygetent passwd "$g_Containerusername" | cut -d: -f6)"
    :
  } || {                                                   # user does not exist on host
    [[ "$g_Containerusername" =~ ^[0-9]+$ ]] || error "Option --user: Unknown host user or invalid user number '$g_Containerusername'.
  Non-host users can be specified with an UID only, not with a name."
    Containeruseruid="$g_Containerusername"
    g_Containerusername="unknown$Containeruseruid"
    [ -z "$Containerusergid" ] && Containerusergid=100
    Containeruserhosthome=""
  }

  Containerusergroup="$(mygetent group "$Containerusergid" | cut -d: -f1 || echo group_"$g_Containerusername")"
  [ "$Containeruseruid" = "0" ] && {
    g_Containerusername="root"
    Containerusergid="0"
    Containerusergroup="root"
    Containeruserhosthome="/root"
    [ "$Sudouser" = "yes" ] || [ "$Capdropall" = "no" ] || {
      note "Option --user=root: Please set option --sudouser or --cap-default
  if you want root privileges for container user root."
    }
  }

  [ -f "$Passwordfile" ] && {
    verbose "Found password file $Passwordfile"
    Containeruserpassword="$(cat "$Passwordfile")"
    case "$(stat -c '%a' "$Passwordfile")" in
      600|400) ;;
      *) warning "File $Passwordfile
  should be readable by current user only.
  Please set access permissions to 600 or 400." ;;
    esac
  }
  [ -z "$Containeruserpassword" ] && Containeruserpassword='$6$Mj$WtcqpZ7JFegW4.0Br1WM0NJcNSxVxUQXgVLxGEV5uD3ib3jWGvIM3FNg2Gcj8e//mI06yhgfZ79WoNHGVtaYw1' # password: x11docker

  storeinfo_add_kv_sh containeruser="$g_Containerusername"
  store_runoption_env "USER=$g_Containerusername"
  debugnote "container user: $g_Containerusername $Containeruseruid:$Containerusergid $Containeruserhosthome"
  Containerusergroups="$Containerusergroups $Containerusergroup"

  case "$g_BackendKind" in
    docker|podman|nerdctl|proot)
      case "$Containersetup" in
        no)  store_runoption_env "XDG_RUNTIME_DIR=/tmp" ;;
      esac
    ;;
    host) ;;  # BackendKind_host
  esac
  return 0
}

create_backendcommand() {       ### create command to run docker|podman|nerdctl ###
  local Line= Memory Initcommand= Grouplist=

  case "$g_BackendKind" in
    docker|podman|nerdctl)
      Backendcommand="$g_Backendbin run"
      unpriv_backend "$g_Backendbin run --help" 2>/dev/null | grep -q -- '--pull' && Backendcommand="$Backendcommand \\
  --pull never"
    ;;
    proot)
      Backendcommand="proot \\
  --rootfs='$g_Rootfs' \\
  --bind=/etc/host.conf \\
  --bind=/etc/nsswitch.conf \\
  --bind=/etc/resolv.conf \\
  --bind=/proc \\
  --bind=/sys \\
  --bind=/dev \\
  --bind=/run/shm"
      ;;
    host) ;; # BackendKind_host
  esac

  # --keepcache
  case "$g_BackendKind" in
    docker|podman)
      [ "$Preservecachefiles" = "no" ] && Backendcommand="$Backendcommand \\
  --rm"
    ;;
  esac

  # --sudouser
  [ "$Sudouser" = "yes" ] && {
    case "$g_BackendKind" in
      proot)
        Backendcommand="$Backendcommand \\
  --root-id"
      ;;
    esac
  }

  # --interactive
  case "$g_Interactive" in
    yes)
      case "$g_BackendKind" in
        docker|podman|nerdctl)
          Backendcommand="$Backendcommand \\
  --interactive \\
  --tty"
        ;;
      esac
    ;;
    no)
      case "$g_BackendKind" in
        docker|podman|nerdctl)
          Backendcommand="$Backendcommand \\
  --detach"
        ;;
      esac
      case "$g_BackendKind" in
        docker|podman) Backendcommand="$Backendcommand \\
  --tty" ;;
      esac
    ;;
  esac

  # --name
  [ -z "$g_Containername" ] && g_Containername="x11docker_X${Newdisplaynumber}_${Codename}_${Cachenumber}"
  case "$g_BackendKind" in
    docker|podman|nerdctl)
      Backendcommand="$Backendcommand \\
  --name $g_Containername"
      storeinfo_add_kv_sh "containername=$g_Containername"
    ;;
  esac

  # --limit
  [ "$g_Limitresources" ] && {
    case "$g_BackendKind" in
      docker|podman|nerdctl)
        Memory="$(awk "BEGIN {print int($(LC_ALL=C free -b | grep "Mem:" | awk ' {print $4 + $6}') * $g_Limitresources)}")"
        Backendcommand="$Backendcommand \\
  --cpus=$(awk "BEGIN {print $(nproc) * $g_Limitresources}") \\
  --memory=$Memory \\
  --kernel-memory=$Memory"
      ;;
    esac
  }

  # --user
  case "$g_Initsystem" in
    none|tini|dockerinit)
      case "$Switchcontaineruserflag" in
        no)
          case "$g_BackendKind" in
            docker|podman|nerdctl)
              [ "$Createcontaineruser" = "yes" ] && Backendcommand="$Backendcommand \\
  --user $Containeruseruid:$Containerusergid"
            ;;
          esac
        ;;
        yes)
          case "$g_BackendKind" in
            docker|podman|nerdctl)
              Backendcommand="$Backendcommand \\
  --user 0:0"
            ;;
          esac
        ;;
      esac
    ;;
    systemd|runit|openrc|sysvinit|s6-overlay)
      # init systems switch later from root to user.
      case "$g_BackendKind" in
        docker|podman|nerdctl)
          Backendcommand="$Backendcommand \\
  --user root"
        ;;
      esac
    ;;
  esac

  # userns
  [ "$Createcontaineruser" = "yes" ] && {
    # Disable user namespacing to avoid file permission issues with --home or --share. Files need same UID/GID.
    case "$g_BackendKind" in
      podman)
        [ "$Backendrootless" = "yes" ] && Backendcommand="$Backendcommand \\
  --userns=keep-id"
      ;;
      docker)
        case "$Runtime" in
          sysbox-runc)
          ;;
          *)
            [ "$Backendrootless" = "yes" ] || Backendcommand="$Backendcommand \\
  --userns=host"  ### FIXME option deprecated?
          ;;
        esac
      ;;
    esac
  }

  # --group-add
  [ "$Switchcontaineruserflag" = "no" ] && {
    case "$g_BackendKind" in
      docker|podman)
        for Line in $Containerusergroups; do
          mygetent group "${Line:-nonsense}" >/dev/null && Backendcommand="$Backendcommand \\
  --group-add $(mygetent group "$Line" | cut -d: -f3)"
        done
      ;;
    esac
  }

  # --runtime
  [ "$Runtime" ] && {
    case "$g_BackendKind" in
      docker|podman|nerdctl)
        Backendcommand="$Backendcommand \\
  --runtime='$Runtime'"
      ;;
    esac
  }

  # --ipc
  [ "$Shareipc" != "no" ] && {
    case "$g_BackendKind" in
      docker|podman|nerdctl)
        Backendcommand="$Backendcommand \\
  --ipc $Shareipc"
      ;;
    esac
  }

  # --network
  case "$g_BackendKind" in
    docker|podman|nerdctl)
      case "$Xcnetworkid" in
        "")
          [ -n "$g_Network" ] && Backendcommand="$Backendcommand \\
  --network $g_Network"
        ;;
        *)
          Backendcommand="$Backendcommand \\
  --network=$Xcnetworkname"
        ;;
      esac
    ;;
  esac

  # capabilities
  case "$g_BackendKind" in
    docker|podman|nerdctl)
      [ "$Capdropall" = "yes" ] && Backendcommand="$Backendcommand \\
  --cap-drop ALL"
      while read Line ; do
        Backendcommand="$Backendcommand \\
  --cap-add $Line"
      done < <(store_runoption_dump_cap)
    ;;
  esac

  # --newprivileges
  case "$g_BackendKind" in
    docker|podman|nerdctl)
      [ "$Allownewprivileges" = "no" ] && Backendcommand="$Backendcommand \\
  --security-opt no-new-privileges"
    ;;
  esac

  # SELinux restrictions for containers must be disabled to allow
  # access to X socket. Flags z or Z do not help. ### FIXME check for
  # possible change meanwhile
  #
  case "$g_BackendKind" in
    docker|podman)
      Backendcommand="$Backendcommand \\
  --security-opt label=type:container_runtime_t"
#  --security-opt label=type:container_runtime_t"
#  --security-opt label=disable"
    ;;
  esac

  # --init
  case "$g_Initsystem" in
    dockerinit)
      case "$g_BackendKind" in
        docker|podman|nerdctl)
          Backendcommand="$Backendcommand \\
  --init"
        ;;
      esac
    ;;
    tini)
      Initcommand="$Initcontainerpath -g --"
      case "$g_BackendKind" in
        docker|podman|nerdctl)
          Backendcommand="$Backendcommand \\
  --mount $(convertpath mount "$g_Initbinaryfile:ro" "$Initcontainerpath")"
        ;;
        proot)
          Backendcommand="$Backendcommand \\
  --bind=$g_Initbinaryfile:$Initcontainerpath"
          ;;
        host) ;; # BackendKind_host
      esac
    ;;
    systemd)
      Backendcommand="$Backendcommand \\
  --tmpfs /var/lib/journal"
  esac
  case "$g_Initsystem" in
    systemd|sysvinit|openrc|runit)
      case "$g_BackendKind" in
        podman)
          Backendcommand="$Backendcommand \\
  --systemd=always"
        ;;
      esac
      [ "$g_Remountcgroup" = "yes" ] && {
        unpriv_backend "$g_Backendbin run --help" | grep -q -- '--cgroupns' && Backendcommand="$Backendcommand \\
  --cgroupns private"
      }
    ;;
  esac
  
  # stop signal for some init systems
  [ "$Stopsignal" ] && {
    case "$g_BackendKind" in
      docker|podman|nerdctl)
        Backendcommand="$Backendcommand \\
  --stop-signal $Stopsignal"
      ;;
    esac
  }

  # --sharecgroup
  [ "$Sharecgroup" = "yes" ] && {
    case "$g_BackendKind" in
      docker|podman|nerdctl)
        Backendcommand="$Backendcommand \\
  --mount type=bind,source=/sys/fs/cgroup,target=/sys/fs/cgroup,readonly"
      ;;
    esac
  }

  # Needed especially for --init=systemd and --dbus=system
  case "$g_BackendKind" in
    docker|podman)
      Backendcommand="$Backendcommand \\
  --tmpfs /run:exec \\
  --tmpfs /run/lock \\
  --tmpfs /tmp"
    ;;
  esac

  # shared x11docker cache folder
  case "$g_BackendKind" in
    docker|podman|nerdctl)
      Backendcommand="$Backendcommand \\
  --mount $(convertpath mount "$Sharefolder:rw" $Sharefoldercontainer)"
    ;;
    proot)
      Backendcommand="$Backendcommand \\
  --bind=$Sharefolder:$Sharefoldercontainer"
      ;;
    host) ;; # BackendKind_host
  esac

  # --home
  case "$Sharehome" in
    host)
      case "$g_BackendKind" in
        docker|podman|nerdctl)
          Backendcommand="$Backendcommand \\
  --mount $(convertpath mount "$Persistanthomevolume:rw" "$Containeruserhome")"
        ;;
        proot)
          Backendcommand="$Backendcommand \\
  --bind=$Persistanthomevolume:$Containeruserhome"
          ;;
        host) ;; # BackendKind_host
      esac
    ;;
    volume)
      case "$g_BackendKind" in
        docker|podman|nerdctl)
          Backendcommand="$Backendcommand \\
  --volume $(convertpath volume "$Persistanthomevolume" "$Containeruserhomebasefolder")"
          ### FIXME $Containeruserhomebasefolder ?? mount/volume?
        ;;
        *) # proot|host) ;; # BackendKind_host
            error_ttm \
                "|Option --backend=$g_BackendKind: Sharing a docker volume is not supported.
                 |  Failing option: --home=$Persistanthomevolume"
        ;;
      esac
    ;;
  esac

  # --share
  while read -r Line; do
    case "$g_BackendKind" in
      docker|podman|nerdctl)
        case "$(cut -c1-5 <<< "$Line")" in
          "/dev/")
             Backendcommand="$Backendcommand \\
  --device $(convertpath volume "$Line")"
            warning "Sharing device file: $Line"
          ;;
          *)
            Backendcommand="$Backendcommand \\
  --mount $(convertpath mount "$Line")"
          ;;
        esac
      ;;
      proot)
        grep -q ':ro' <<< "$Line" && {
          warning "Option --backend=proot cannot mount read-only:
  $Line
  Fallback: mounting with r/w"
          check_fallback
        }
        Line="${Line//":ro"/""}"
        Backendcommand="$Backendcommand \\
  --bind=$Line:$Line"
        ;;
      # host) ;; # BackendKind_host
    esac
  done < <(store_runoption_dump_volume)

  # --gpu
  case "$Sharegpu" in
    direct)
      # share NVIDIA driver installer
      [ -f "$Nvidiainstallerfile" ] && {
        case "$g_BackendKind" in
          docker|podman|nerdctl)
            Backendcommand="$Backendcommand \\
  --mount $(convertpath mount "$Nvidiainstallerfile:ro" "$Nvidiacontainerfile")"
          ;;
          proot)
            Backendcommand="$Backendcommand \\
  --bind=$Nvidiainstallerfile:$Nvidiacontainerfile"
          ;;
          # host) ;; # BackendKind_host
        esac
      }
      ;;
    virgl)
      case "$g_BackendKind" in
        docker|podman|nerdctl)
          Backendcommand="$Backendcommand \\
  --mount $(convertpath mount "$Cachefolder/tmp/.virgl_test" "/tmp/.virgl_test")"
        ;;
      esac
    ;;
  esac

  # share X socket
  [ "$Xoverip" = "no" ] && case "$Xcontainer_option" in
    yes)
      [ "$Newxsocket" ] && {
        case "$g_BackendKind" in
          docker|podman|nerdctl)
            case "$Xserver" in
              --hostdisplay)
                Backendcommand="$Backendcommand \\
  --mount $(convertpath mount "$Newxsocket:ro" "$Newxsocket")"
              ;;
              *)
                Backendcommand="$Backendcommand \\
  --mount $(convertpath mount "$Cachefolder/tmp/.X11-unix/X$Newdisplaynumber:ro" "/tmp/.X11-unix/X$Newdisplaynumber")"
              ;;
            esac
            [ "$Shareipc" = "no" ] && [ "$g_Containerusername" = "$Hostuser" ] && [ "$Xcontainerbackend" = "$g_BackendKind" ] && {
              case "$Runtime" in
                kata-runtime|sysbox-runc) ;;
                *)
                  case "$g_BackendKind" in
                    docker)
                      case "$Xserver" in
                        --weston*|--xpra*-xwayland) ;; # needs ipc=host in Xcontainer_option
                        *)
                          [ "$Xcrootless" = "$Backendrootless" ] && Backendcommand="$Backendcommand \\
  --ipc=container:$Xcontainername"
                        ;;
                      esac
                    ;;
#                    podman) # disabled, should check like for docker above FIXME
#                      case "$Runtime" in
#                        crun)
#                          [ "$Xcrootless" = "$Backendrootless" ] && Backendcommand="$Backendcommand \\
#  --ipc=container:$Xcontainername"
#                        ;;
#                        *)
#                          debugnote "--xc --backend=podman: Not sharing ipc namespace using runtime $Runtime"
#                        ;;
#                      esac
#                    ;;
                  esac
                ;;
              esac
            }
          ;;
          proot)
            case "$Xserver" in
              --hostdisplay)
                Backendcommand="$Backendcommand \\
  --bind=$Newxsocket:$Newxsocket"
              ;;
              *)
                Backendcommand="$Backendcommand \\
  --bind=$Cachefolder/tmp/.X11-unix/X$Newdisplaynumber:$Newxsocket"
              ;;
            esac
            ;;
          # host) ;; # BackendKind_host
        esac
      }
    ;;
    no)
      [ "$Newxsocket" ] && {
        case "$g_BackendKind" in
          docker|podman|nerdctl)
            Backendcommand="$Backendcommand \\
  --mount $(convertpath mount "$Newxsocket:ro" "/tmp/.X11-unix/X${Newdisplaynumber}")"
          ;;
          proot)
            Backendcommand="$Backendcommand \\
  --bind=$Newxsocket:$Newxsocket"
          ;;
          # host) ;; # BackendKind_host
        esac
      }
    ;;
  esac

  # Wayland socket will be softlinked to XDG_RUNTIME_DIR in containerrc
  [ "$Setupwayland" = "yes" ] && {
    case "$Containersetup" in
      yes)
        [ "$Sharehostwayland" = "yes" ] && Backendcommand="$Backendcommand \\
  --mount $(convertpath mount "$XDG_RUNTIME_DIR/$Hostwaylandsocket" "/$Hostwaylandsocket")"
        case "$Xcontainer_option" in
          yes)
            case "$g_BackendKind" in
              docker|podman|nerdctl)
                [ "$Newwaylandsocket" ] && Backendcommand="$Backendcommand \\
  --mount $(convertpath mount "$Cachefolder/XDG_RUNTIME_DIR/$Newwaylandsocket" "/$Newwaylandsocket")"
              ;;
              proot)
                Backendcommand="$Backendcommand \\
  --bind=$Cachefolder/XDG_RUNTIME_DIR/$Newwaylandsocket:/$Newwaylandsocket"
              ;;
              # host) ;; # BackendKind_host
            esac
          ;;
          no)
            case "$g_BackendKind" in
              docker|podman|nerdctl)
                [ "$Newwaylandsocket" ] && Backendcommand="$Backendcommand \\
  --mount $(convertpath mount "$XDG_RUNTIME_DIR/$Newwaylandsocket" "/$Newwaylandsocket")"
              ;;
              proot)
                Backendcommand="$Backendcommand \\
  --bind=$XDG_RUNTIME_DIR/$Newwaylandsocket:/$Newwaylandsocket"
              ;;
              # host) ;; # BackendKind_host
            esac
          ;;
        esac
      ;;
      no)
        case "$Xcontainer_option" in
          yes)
            case "$g_BackendKind" in
              docker|podman|nerdctl)
                Backendcommand="$Backendcommand \\
  --mount $(convertpath mount "$Cachefolder/XDG_RUNTIME_DIR/$Newwaylandsocket")"
              ;;
              proot)
                Backendcommand="$Backendcommand \\
  --bind=$Cachefolder/XDG_RUNTIME_DIR/$Newwaylandsocket" ### FIXME looks wrong
              ;;
              # host) ;; # BackendKind_host
            esac
          ;;
          no)
            case "$g_BackendKind" in
              docker|podman|nerdctl)
                Backendcommand="$Backendcommand \\
  --mount $(convertpath mount "$XDG_RUNTIME_DIR/$Newwaylandsocket")"
              ;;
              proot)
                Backendcommand="$Backendcommand \\
  --bind=$XDG_RUNTIME_DIR/$Newwaylandsocket"
              ;;
              # host) ;; # BackendKind_host
            esac
          ;;
        esac
      ;;
    esac
  }

  # --pulseaudio
  case "$Pulseaudiomode" in
    socket)
      case "$g_BackendKind" in
        docker|podman|nerdctl)
          Backendcommand="$Backendcommand \\
  --mount $(convertpath mount "$Pulseaudioconf:ro" "/etc/pulse/client.conf")"
          ;;
        proot)
          Backendcommand="$Backendcommand \\
  --bind=$Pulseaudioconf:/etc/pulse/client.conf"
        ;;
        # host) ;; # BackendKind_host
      esac
    ;;
    host)
      case "$g_BackendKind" in
        docker|podman|nerdctl)
          Backendcommand="$Backendcommand \\
  --mount $(convertpath mount "$Pulseaudiosocket:ro" "/tmp/pulseaudio.socket.host") \\
  --mount $(convertpath mount "$Pulseaudioconf:ro" "/etc/pulse/client.conf")"
          ;;
        proot)
          Backendcommand="$Backendcommand \\
  --bind=$Pulseaudiosocket:/tmp/pulseaudio.socket.host \\
  --bind=$Pulseaudioconf:/etc/pulse/client.conf"
        ;;
        # host) ;; # BackendKind_host
      esac
    ;;
  esac

  # --pipewire
  case "$Sharepipewire" in
    yes)
      [ -n "$Pipewirepulseaudiosocket" ] && Backendcommand="$Backendcommand \\
  --mount $(convertpath mount "$Pipewirepulseaudiosocket:ro" "/tmp/pipewirepulseaudio.socket.host") \\
  --env PULSE_SERVER=/tmp/pipewirepulseaudio.socket.host"
    ;;
  esac

  # --workdir
  case "$Containersetup" in
    yes)
      case "$g_BackendKind" in
        docker|podman|nerdctl)
          Backendcommand="$Backendcommand \\
  --workdir '${g_Workdir:-/tmp}'"
        ;;
        proot)
          Backendcommand="$Backendcommand \\
  --cwd=${g_Workdir:-/tmp}"
        ;;
        # host) ;; # BackendKind_host
      esac
    ;;
    no)
      [ "$g_Workdir" ] && {
        case "$g_BackendKind" in
          docker|podman|nerdctl)
            Backendcommand="$Backendcommand \\
  --workdir '$g_Workdir'"
          ;;
          proot)
            Backendcommand="$Backendcommand \\
  --cwd=${g_Workdir}"
          ;;
          # host) ;; # BackendKind_host
        esac
      }
    ;;
  esac

  # --no-setup, --no-entrypoint
  case "$Containersetup" in
    yes)
      case "$g_BackendKind" in
        docker|podman|nerdctl)
          Backendcommand="$Backendcommand \\
  --entrypoint env"
        ;;
      esac
    ;;
  esac

  # --env: add environment variables. Only needed here for possible 'docker exec'. Also set in containerrc
  while read Line; do
    case "$g_BackendKind" in
      docker|podman|nerdctl)
        Backendcommand="$Backendcommand \\
  --env '$(escapestring "$Line")'"
      ;;
    esac
  done < <(store_runoption_dump_env)

  # add custom docker arguments, imagename and imagecommand
  [ "$Customdockeroptions" ] && {
    case "$g_BackendKind" in
      docker|podman|nerdctl|proot)
        Backendcommand="$Backendcommand \\
  $Customdockeroptions"
      ;;
      # host) ;; # BackendKind_host
    esac
  }

  # --rootfs
  case "$g_BackendKind" in
    podman)
      [ "$g_Podmanrootfs" = "yes" ] && Backendcommand="$Backendcommand \\
  --rootfs"
    ;;
  esac

  case "$g_BackendKind" in
    docker|podman|nerdctl)
      Backendcommand="$Backendcommand \\
  --"
    ;;
    proot)
      Backendcommand="$Backendcommand \\
  "
    ;;
    # host) ;; # BackendKind_host
esac

  case "$Containersetup" in
    yes)
      case "$Switchcontaineruserflag" in
        no)
          case "$g_BackendKind" in
            docker|podman|nerdctl)
              Backendcommand="$Backendcommand ${g_Rootfs:-$g_Imagename} $Initcommand /bin/sh - $(convertpath share "$Containerrc")"      # start_container runs containerrootrc with 'docker exec'
            ;;
            proot)
              Backendcommand="$Backendcommand /bin/sh - $(convertpath share "$Containerrc")"
            ;;
          # host) ;; # BackendKind_host
          esac
        ;;
        yes)
          case "$g_BackendKind" in
            docker|podman|nerdctl)
              Backendcommand="$Backendcommand ${g_Rootfs:-$g_Imagename} $Initcommand /bin/sh - $(convertpath share "$Containerrootrc")"  # containerrootrc runs containerrc
            ;;
            proot)
              Backendcommand="$Backendcommand /bin/sh - $(convertpath share "$Containerrootrc")"
            ;;
          # host) ;; # BackendKind_host
          esac
        ;;
      esac
    ;;
    no)
      case "$g_BackendKind" in
        docker|podman|nerdctl)
          case "$g_Initsystem" in
            tini) Backendcommand="$Backendcommand ${g_Rootfs:-$g_Imagename} $Initcommand $g_Containercommand" ;;
            *) Backendcommand="$Backendcommand ${g_Rootfs:-$g_Imagename} $g_Containercommand" ;;
          esac
        ;;
        proot)
          Backendcommand="$Backendcommand $g_Containercommand"
        ;;
        # host) ;; # BackendKind_host
      esac
    ;;
  esac

  return 0
}
setup_capabilities() {          # check linux capabilities needed by container
  # compare: man capabilities

  [ "$Sudouser" ]               && Adminusercaps="yes"
  [ "$Capdropall" = "no" ]      && [ "$Allownewprivileges" = "auto" ] && {
    note "Option --cap-default: Enabling option --newprivileges=yes.
  You can avoid this with --newprivileges=no"
    Allownewprivileges="yes"
  }

  # --sudouser
  [ "$Sudouser" ] && warning "Option --sudouser severely reduces container security.
  Container gains additional capabilities to allow sudo and su.
  If an application breaks out of container, it can harm your system
  in many ways without you noticing. Default password: x11docker"

  # enable dbus
  [ "$Dbussystem" = "yes" ]    && {
    Dbusrunsession="yes"
    store_runoption_cap "CHOWN FOWNER" ### FIXME: CHOWN needed indeed here?
    Switchcontaineruserflag="yes"
  }
  #case "$g_Initsystem" in
  #  systemd) Dbusrunsession="no" ;;
  #esac

  case "$g_Initsystem" in
    none|tini|dockerinit) ;;
    systemd)
      Switchcontaineruserflag="yes"
      store_runoption_cap "FSETID FOWNER SETPCAP SYS_BOOT"
    ;;
    runit|openrc|sysvinit)
      Switchcontaineruserflag="yes"
      store_runoption_cap "SYS_BOOT KILL"
    ;;
    s6-overlay)
      Switchcontaineruserflag="yes"
      store_runoption_cap "CHOWN KILL"
    ;;
  esac

  [ "$Sharecgroup" = "yes" ]         && Switchcontaineruserflag="yes" # needed for elogind
  [ "$Switchcontaineruserflag" = "yes" ] && Switchcontainerusercaps="yes"

  [ "$Adminusercaps" = "yes" ] && {
    Switchcontainerusercaps="yes"
    store_runoption_cap "CHOWN KILL FSETID FOWNER SETPCAP"
    [ "$Allownewprivileges" = "auto" ] && {
      note "Option --sudouser: Enabling option --newprivileges=yes.
  You can avoid this with --newprivileges=no"
      Allownewprivileges="yes"
    }
  }
  [ "$Switchcontainerusercaps" = "yes" ] && {
    warning "setup_capabilities(): Adding capabilities for user switching
  from root to unprivileged user"
    store_runoption_cap "SETUID SETGID DAC_OVERRIDE AUDIT_WRITE"
  }

  # Automated NVIDIA driver installation
#  [ "$Sharegpu" = "direct" ] && [ "$Nvidiainstallerfile" ] && [ "$Switchcontaineruserflag" = "yes" ] && {
  [ "$Sharegpu" = "direct" ] && [ "$Nvidiainstallerfile" ] && {
    store_runoption_cap "CHOWN FOWNER DAC_OVERRIDE"
  }

  [ "$Allownewprivileges" = "auto" ] && Allownewprivileges="no"

  [ "$Allownewprivileges" = "yes" ] && warning "Option --newprivileges=yes: x11docker does not set
  docker run option --security-opt=no-new-privileges.
  That degrades container security.
  However, this is still within a default docker setup."

  # Issues with hidepid=2 seen on NixOS (issue #83)
  { [ "$Switchcontaineruserflag" = "yes" ] || [ "$g_Containerusername" != "$Hostuser" ] ; } && {
    [ "$Hostcanwatchroot" = "no" ] && {
      [ "$Hosthidepid" = "yes" ]            && Message="/proc is mounted with hidepid=2." || Message="Cannot watch processes of other users for unknown reasons."
      Message="$Message
  x11docker cannot watch processes of root
  or other users different from $Hostuser."
      [ "$Hostuser" != "$g_Containerusername" ]   && Message="$Message
  Container user $g_Containerusername is different from host user $Hostuser."
      [ "$Switchcontaineruserflag" = "yes" ]    && Message="$Message
  Container PID 1 will run as root."
      Message="$Message
  Therefore x11docker cannot watch container processes
  for a clean termination of X and x11docker itself.
  Four possible solutions:
    1. Run x11docker as root.
    2. Don't use options like --user or --init=systemd that change container user.
    3. Add user $Hostuser to group 'proc'.
    4. Change /proc mount option hidepid=2 to hidepid=1."
      error "$Message"
    }
  }

  return 0
}
setup_initsystem() {            # option init: set up capabilities, check or create files
  # some init system setup also in containerrootrc
  local Message=

  # --init in Dockervm. /usr/bin/docker-init is not available in MSYS2/Cygwin/WSL1
  if case_match "$Dockervm" 'moby|desktop' && [ "$g_Initsystem" = "tini" ] ; then
      g_Initsystem="dockerinit"
  fi

  case "$g_BackendKind" in
    proot|host) # BackendKind_host
      case "$g_Initsystem" in
        tini|none) ;;
        *)
          note "Option --init: Only --init[=tini] or --init=none are
  supported with option --backend=$g_BackendKind. Fallback: Setting option --init=tini"
          check_fallback
          g_Initsystem="tini"
        ;;
      esac
    ;;
  esac

  case "$g_BackendKind" in
    docker|podman|nerdctl)
      store_runoption_env "container=$g_BackendKind"   # At least OpenRC and systemd regard this hint
    ;;
  esac

  case "$g_Initsystem" in
    none|dockerinit) ;;
    tini)
      check_smallinit && {
        case "$Runtime" in
          kata-runtime)
            # avoid sharing same file that might be shared with runc already.
            cp -u "$g_Initbinaryfile" "$Localsharedir/init-kata"
            g_Initbinaryfile="$Localsharedir/init-kata"
          ;;
        esac
      } || {
        g_Initsystem="none"
      }
      [ "$g_Initsystem" = "none" ] && {  ### FIXME --backend=host,proot
        note "--init=$g_Initsystem: Did not find container init system
  'tini' or 'catatonit'. It should be provided by docker or podman package.
  Please install catatonit to provide a container init system.
  $Wikipackagesimage"
      }
      verbose "--init: Found init binary: ${g_Initbinaryfile:-(none)}"
      [ "$g_Initbinaryfile" ] && storeinfo_add_kv_sh "tini=$g_Initbinaryfile"
    ;;
    systemd)
      Stopsignal="SIGRTMIN+3"
      Containerusergroups="$Containerusergroups systemd-journal"
    ;;
    runit)
      Stopsignal="HUP"
      store_runoption_env "VIRTUALIZATION=docker"
    ;;
    openrc)
    ;;
    sysvinit)
      Stopsignal="INT"
    ;;
    s6-overlay)
    ;;
  esac

  case "$g_Initsystem" in
    systemd)
      warning "Option --init=systemd slightly degrades container isolation.
  It adds some capabilities x11docker would drop otherwise.
  However, they are still within default docker capabilities.
  Not within default docker capabilities it adds capability SYS_BOOT.
  Some processes in container will run as root."
    ;;
    runit|openrc|sysvinit)
      warning "Option --init=$g_Initsystem slightly degrades container isolation.
  It adds some user switching capabilities x11docker would drop otherwise.
  However, they are still within default docker capabilities.
  Not within default docker capabilities it adds capability SYS_BOOT.
  Some processes in container will run as root."
    ;;
    s6-overlay)
      warning "Option --init=$g_Initsystem slightly degrades container isolation.
  It adds some user switching capabilities x11docker would drop otherwise.
  However, they are still within default docker capabilities.
  Some processes in container will run as root."
    ;;
    tini|none|dockerinit)
      [ "$Dbussystem" = "yes" ] && {
        [ "$Capdropall" = "yes" ] && warning "Option --dbus=system slightly degrades container isolation.
  It adds some user switching capabilities x11docker would drop otherwise.
  However, they are still within default docker capabilities.
  Some processes in container will run as root.
  --dbus=system might need further capabilities or --cap-default to work
  as expected. If in doubt, one of --init=systemd|openrc|runit|sysvinit
  might be a better choice."
        note "Option --dbus=system with init system '$g_Initsystem'
  can have a quite long timeout delay until startup.
  Use one of --init=systemd|openrc|runit|sysvinit in that case."
      }
    ;;
  esac

  case "$g_BackendKind" in
    host) # BackendKind_host
      [ "$g_Initsystem" = "tini" ] && {
        g_Containerentrypoint="$g_Initbinaryfile --"
        store_runoption_env "TINI_SUBREAPER=1"
      }
    ;;
  esac
  
  case "$g_Initsystem" in
    systemd|sysvinit|openrc|runit)
      check_cgroup ||:
    ;;
  esac
  
  return 0
}

