# NEWLINE contains a newline character. Declared readonly.
#         Used for injecting a newline in double-quoted strings.
#
declare -r NEWLINE=$'\n'


# Function: alertbox
# Brief: Show an  X alert box with title $1 and message $2
# Argument:
#   $1: title
#   $2: message
#
alertbox() {
  local Title Message
  Title="${1:-}"
  Message="${2:-}"

  # Remove UTF-8 special chars; line folding at 120 chars
  Message="$(echo "$Message" | LANG=C sed "s/[\x80-\xFF]//g" | fold -w120 )"

  # try some tools to show alert message. If all tools fail, return 1
  if [ -n "${DISPLAY:-}" ] ; then
      if have_command  gxmessage  ; then
          printf "%s\n\n%s" "${Title}" "${Message}"  \
              | gxmessage -file - -default okay      \
              || true
      elif have_command zenity  ; then
          zenity --error --no-markup --ellipsize \
                 --title="$Title"                \
                 --text="$Message"               \
                 2>/dev/null                     \
              || true
      elif have_command yad  ; then
          # shellcheck disable=SC2001
          yad  --image "dialog-error" \
               --title "$Title"       \
               --button=gtk-ok:0      \
               --text "$(echo "$Message" | sed 's/\\/\\\\/g')" \
               --fixed                \
               2>/dev/null            \
              || true
      elif have_command kdialog  ; then
          # shellcheck disable=SC2001
          kdialog                                               \
              --title "$Title"                                  \
              --error "$(echo "$Message" | sed 's/\\/\\\\/g' )" \
              2>/dev/null                                       \
              || true
      elif have_command  xmessage  ; then
          printf "%s\n\n%s" "${Title}" "${Message}"  \
              | xmessage  -file - -default okay      \
              || true
      elif have_command xterm  ; then
          # shellcheck disable=SC2001
          xterm                             \
              -title "$Title"               \
              -e "echo '$(echo "$Message" | sed "s/'/\"/g")' ; read -n1" \
              || true
      else
          # none of the abve branches matched
          false
      fi
  fi || {
      # Try  notify-send with or without DISPLAY
      notify-send "$(printf "%s\n\n%s" "${Title}" "${Message}" )"  2>/dev/null
  } || {
      warning "$(printf "Could not display message on X:\n%s" "$Message" )"
      return 1
  }
  return 0
}


# Function: debugnote
# Brief: Show debug output $*
#
# Argument:
#    "$*" is the message.
#
# return: 0
#
# Globals:
#   Debugmode
#   Verbose
#   Colblue, Colnorm
#   FDstderr
#
# Calls:
#    function timestamp
#
debugnote() {
    if [ "$Debugmode" = "yes" ] && [ "$Verbose" != "yes" ] ; then
        echo "${Colblue}DEBUGNOTE[$(timestamp)]:${Colnorm} $*" >&"${FDstderr}"
    fi
    #
    logentry "DEBUGNOTE[$(timestamp)]: $*"
    return 0
}


# Function: error
# Usage: error msg
# Brief: Show error message and exit
#
# Argument:
#    "$*" is the message
#
# Added: call to @code{stacktrace}
#
error() {
  local Message

  # shellcheck disable=SC2104
  break >/dev/null 2>&1 # just in case error occurred in a loop

  stacktrace
  
  Message="$(printf \
                "%s\n\n%s" \
                "$*" \
                "$(trim_to_bar \
                     "|  Type 'x11docker --help' for usage information
                      |  Debug options: '--verbose' (full log) or '--debug' (log excerpt).
                      |  Logfile will be: $Logfilebackup
                      |  Please report issues at https://github.com/mviereck/x11docker"
                )"
          )"

  # shellcheck disable=SC2119
  Message="$(rmcr <<< "$Message")"

  # output to terminal
  echo -e "\n${Colredbg}x11docker ERROR:${Colnorm} $Message\n" >&2

  # output to logfile
  logentry "$(printf "%s\n" "x11docker ERROR: $Message")"
  saygoodbye error
  storeinfo_test_sh error && waitfortheend
  storeinfo_add_kv_sh error=64

  # output to X dialogbox if not running in terminal
  # shellcheck disable=SC2086
  if     [ "$Runsinterminal" = "no" ]  \
      && [ "$Silent"         = "no" ]  ; then
      export ${Hostxenv:-DISPLAY}
      alertbox "x11docker ERROR" "$Message" &
  fi
  finish
}

# Function: logentry
# Brief: write into logfile
#
# Argument:
#   "$*" is the message
#
# Globals:
#   Messagelogfile : Which file to append to.
#                    Probably @code{ "$Cachefolder/message.log" }
#
#   Logmessages : Used to collect messages until @code{ [ -e "$Logfile" ] }
#
#   Logfile : The file whose existence is tested before we write to
#             Messagelogfile.
#             Q: Why do we test a different file?
#
#             Probably @code{ Logfile="$Sharefolder/x11docker.log" }
#             and will be saved to @code{ Logfilebackup="$Cachebasefolder/x11docker.log" }
#
logentry() {
    if [ -e "$Logfile" ] ; then
        #
        # Try to emit earlier messages. Clear Logmessages on success
        if [ -n "$Logmessages" ] ; then
            if echo "$Logmessages" >> "$Messagelogfile" 2>/dev/null ; then
                Logmessages=""
            fi
        fi
        #
        # Try to emit current message. Append to Logmessages on failure.
        if ! echo "$*" >> "$Messagelogfile" 2>/dev/null ; then
            Logmessages+="${NEWLINE}$*"
        fi
    else
        # No Logfile, collect in Logmessages
        Logmessages+="${NEWLINE}$*"
    fi
}

# Function: note
# Brief: Show notice messages if @code{Verbose} is not yes. @code{logentry} always.
#
# Argument:
#  "$*" is the message
#
# Globals:
#    Verbose : If not yes, print to FDstderr
#    Colgreen, Colnorm
#    NEWLINE
#    FDstderr
#
note() {
    # Only show notice messages if not Verbose ?
    #
    # See: setup_verbosity(). If Verbose is not empty, the @code{tail -f} of the
    #       Logfile will be shown, and direct output is not needed.
    #
    if [ "$Verbose" != "yes" ] ; then
        echo "${Colgreen}x11docker note:${Colnorm} $*${NEWLINE}" >&"${FDstderr}"
    fi
    #
    logentry  "x11docker note: $*${NEWLINE}"
}

# Function: traperror
#
# Argument:
#   $1:exitvalue
#   $2:lineno
#   $3:bash_lineno
#   $4:bash_command
#   $5:funcname
#
#
# Example:
#
#    set -Eu
#    trap 'traperror $? $LINENO $BASH_LINENO "$BASH_COMMAND" $(printf "::%s" ${FUNCNAME[@]})'  ERR
#
# Note: -E  If set, the ERR trap is inherited by shell functions.
#       -u  Treat unset variables as an error when substituting.
#
# Description:   trap ERR: --debug: Output for 'set -o errtrace'
#
traperror() {
    debugnote_ttm \
      "|traperror: Command at Line ${2:-} returned with error code ${1:-}:
       |  ${4:-}
       |  ${3:-} - ${5:-}"
    #
    storeinfo_add_kv_sh error=64
    saygoodbye traperror
}

