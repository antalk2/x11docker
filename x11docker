# Function: storeinfo_add_kv_sh
#
# Usage: storeinfo_add_kv_sh key_and_value
# Brief: Store a "key=value" in "$Storeinfofile"
#
# Argument:
#   key_and_value : String in the format "key=value"
#
# Note: Old entry for `key` is removed if exists.
#
# Calls: storeinfo_test_sh, storeinfo_drop_sh
#
storeinfo_add_kv_sh() {
    [ -e "$Storeinfofile" ] || return 1
    # local key_and_value="${1:-}"
    #
    # store entry  key=value
    debugnote "storeinfo(): ${1:-}"
    #
    # local key
    storeinfo_add_kv_key="$(echo "${1:-}" | cut -d= -f1)"
    #
    # drop possible old entry :
    #
    # Q: Why test? Why not just drop it?
    # A: Maybe grep is faster, and most of the time there is no entry
    #    to delete.
    #
    if storeinfo_test_sh "${storeinfo_add_kv_key}" ; then
        storeinfo_drop_sh "${storeinfo_add_kv_key}"
    fi
    # Store value
    echo "${1:-}"           >> "$Storeinfofile"
}


