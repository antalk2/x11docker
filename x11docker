      [ -z "$XDG_RUNTIME_DIR" ] && {
        export XDG_RUNTIME_DIR="$Cachefolder/XDG_RUNTIME_DIR"
        mkfolder "$XDG_RUNTIME_DIR" 0700
      }
    ;;
  esac
  return 0
}

