$(sed 's/^/--/g ; s/://g' <<< "$Line")"
  done
  g_AllAvailableLongOptions="$(grep . <<< "$g_AllAvailableLongOptions")"

  return 0
}

#
# parse_preset( fn )
#
#  - Note: called from parse_options(), and it also calls parse_options()
#
parse_preset() {
    # nested parsing for --preset
    local Presetfile Presetoptions
    local fn="${1:-}"

    # file already parsed? Avoid a loop
    if grep -q -x "${fn}" <<< "$g_Preset_list_of_seen_files_nls" ; then return 0; fi

    #
    g_Preset_list_of_seen_files_nls+="${NEWLINE}${fn}"

    # check global and local preset dir. Prefer local one.
    if   [ -f  "$Presetdirlocal/${fn}" ] ; then Presetfile="$Presetdirlocal/${fn}"  ;
    elif [ -f "$Presetdirsystem/${fn}" ] ; then Presetfile="$Presetdirsystem/${fn}" ;
    else
        return 1 # Not found
    fi

    # parse:
    #    - drop lines starting with #
    #    - tr newline to space
    Presetoptions="$(sed '/^#/d' < "$Presetfile" | tr '\n' ' ')"
    #
    if [ -n "$(tr -d ' ' <<< "$Presetoptions")" ] ; then
        #
        # Presetoptions contains at least one non-space character.
        #
        note "Option --preset: Parsing $Presetfile:${NEWLINE}  $Presetoptions"
        #
        # Use `eval`,  to preserve whitespace in arguments:
        # Q: The spaces in "$Presetoptions" ?
        eval parse_options "$Presetoptions"
  fi
}

check_options_arguments() {     # check for [likely] valid arguments
