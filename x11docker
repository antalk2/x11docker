killall Xorg weston
sleep 1

exit 0
" >> "$Xcontainerrc"

  return 0
}

#
# Create xinitrc: set up X environment, create cookies
#
create_xinitrc() {
    echo "#! /bin/sh"
    #
    # declare -f FUNNAME emits the definition of FUNNAME. This is how
    #       unmodified functions are shared with the emitted scripts.
    #
    #       Note: we start from bash, yet as for /bin/sh
    #             May need to check portability of these functions.
    #
    declare -f cookiebaker
    declare -f strlenhex
    declare -f pspid
    declare -f disable_X_access_via_xhost
    #
    declare -f makecookie_v1
    declare -f makecookie_v2
    declare -f makecookie_v3
    declare -f makecookie
    #
    declare -f rocknroll
    # declare -f storeinfo_test_sh
    # declare -f storeinfo_drop_sh
    # declare -f storeinfo_add_kv_sh
    # declare -f storeinfo_dump_sh
    declare -f saygoodbye
    #
    declare -f calculate_floor_a_per_b
    #
    # Stuff that differs from the main x11docker script:
    #
    echo "$Messagefifofuncs"
    #
    case "$Xcontainer_option" in
        yes)
            echo           "storepid() { : ; }"
            echo           "unpriv() {"
            echo           '  eval "${1:-}"'
            echo           "}"
            ;;
        no)
            declare -f storepid
            declare -f unpriv
            echo           "Unpriv='$Unpriv'"
            ;;
    esac
    #
    echo               "xtool() {"
    echo               '  [ "${1:-}" = "--check" ] && command -v "${2:-}" && return'
    echo               '  eval ${1:-}'
    echo               "}"
    echo               "getscreensize() {"
    echo               "  CurrentXaxis=\"\$(xrandr | grep primary | cut -d' ' -f4 | cut -dx -f1 )\""
    echo               "  CurrentYaxis=\"\$(xrandr | grep primary | cut -d' ' -f4 | cut -dx -f2 | cut -d+ -f1)\""
    echo               "}"
    echo               "checkscreensize() {"
    echo               "  getscreensize"
    echo               "  [ \"\$Xaxis\" = \"\$CurrentXaxis\" ] || return 1"
    echo               "  [ \"\$Yaxis\" = \"\$CurrentYaxis\" ] || return 1"
    echo               "  return 0"
    echo               "}"
    echo               "getprimary() {"
    echo               "  xrandr | grep -q primary || xrandr --output \$(xrandr | grep ' connected' | head -n1 | cut -d' ' -f1) --primary"
    echo               "  echo \$(xrandr | grep primary | cut -d' ' -f1)"
    echo               "}"
    echo               ""

    echo               "Messagefile='$Messagefifo'"
    echo               "Output=\"\$(getprimary)\""
    echo               "Storeinfofile='$Storeinfofile'"
    echo               "Storepidfile='$Storepidfile'"
    echo               "Timetosaygoodbyefile='$Timetosaygoodbyefile'"
    echo               ""
    echo               "export PATH='${PATH:-}'"
    echo               ""
    echo               "Cookie=''"
    echo               "Line=''"
    echo               "Var=''"
    echo               ""

    echo               "echo 'Running xinitrc'"
    echo               "debugnote 'Running xinitrc'"
    echo               ""

  case "$Xserver" in
    --weston|--kwin|--hostwayland)
      echo           "export $Newxenv"
      echo           "unset  DISPLAY XAUTHORITY"
      echo           "export DISPLAY XAUTHORITY"
    ;;
    --tty)
      echo           "unset  DISPLAY XAUTHORITY WAYLAND_DISPLAY"
      echo           "export DISPLAY XAUTHORITY WAYLAND_DISPLAY"
    ;;
    --runx)
      [ "$Xauthentication" != "no" ] && {
        echo         "# cookie generated by runx"
        echo         'debugnote "xinitrc: Option --runx: Using cookie: $XAUTHORITY"'
        echo         "cp -T -v \"\$XAUTHORITY\" '$Xclientcookie'"
        echo         "cp -T -v \"\$XAUTHORITY\" '$Xservercookie'"
      }
      echo           "export $Newxenv"
    ;;
    *) # here something for real X servers
      echo           "export $Newxenv"
      case "$Xoverip" in
        socat)
          case "$Xcnetworkid" in
            "")
              echo "echo \"socat -d TCP-LISTEN:$((6000+Newdisplaynumber)),fork,bind=${Xcontainerip:-$Hostip} UNIX-CONNECT:$Newxsocket\""
              echo        "socat -d TCP-LISTEN:$((6000+Newdisplaynumber)),fork,bind=${Xcontainerip:-$Hostip} UNIX-CONNECT:$Newxsocket &"
            ;;
            *)
              echo "echo \"socat -d TCP-LISTEN:$((6000+Newdisplaynumber)),fork,bind=$Xcontainername UNIX-CONNECT:$Newxsocket\""
              echo        "socat -d TCP-LISTEN:$((6000+Newdisplaynumber)),fork,bind=$Xcontainername UNIX-CONNECT:$Newxsocket &"
            ;;
          esac
          echo       "storepid \$! socat-tcp"
        ;;
      esac
      echo           ""
      case "$Xserver" in
        --hostdisplay)
          [ -s "$Hostxauthority" ] && {
            echo     "# --hostdisplay: need cookie from host" ### FIXME rather get a trusted one
            echo     "Hostcookie=\"\$(xauth -n -i -f $Hostxauthority list | grep :$Hostdisplaynumber | awk '{print \$3}')\""
            echo     "xauth -n -i -f $Xclientcookie add $Newdisplay MIT-MAGIC-COOKIE-1 \$Hostcookie"
            echo     ""
          }
        ;;
        --nxagent)
          echo       "sleep 1 && xsetroot -solid '#7F7F7F' 2>/dev/null &" ;;
        *) echo      "xsetroot -solid '#7F7F7F' 2>/dev/null" ;;
      esac
      echo ""

      [ "$Xauthentication" != "no" ] && {
        echo         "# create new XAUTHORITY cookies"
        case "$Xauthentication" in
          yes|trusted)
            Xauthentication="trusted"
            echo     "Trusted=trusted"
          ;;
          untrusted)
            echo     "Trusted=untrusted"
          ;;
        esac
        echo         "echo \"Requesting \$Trusted cookie from X server\""
        echo         "xauth -v -n -i -f $Xclientcookie generate $Newdisplay . \$Trusted timeout 3600"
        [ "$Xserver" = '--hostdisplay' ] && {
          echo       "[ -n \"\$Hostcookie\" ] && sed -i /\$Hostcookie/d $Xclientcookie"
        }
        echo         "[ -s '$Xclientcookie' ] || { "
        echo         "  :"
        case "$Xauthentication" in
          untrusted)
            echo     "  error '--xauth=untrusted: Failed to create cookie
  for untrusted clients.
  Maybe your X server misses extension SECURITY.'"
          ;;
        esac
        echo         "}"
        [ "$Xserver" = "--hostdisplay" ] && {
          echo       "[ ! -s '$Xclientcookie' ] && {"
          echo       "  [ -n \"\$Hostcookie\" ] && {"
          echo       "    debugnote 'xinitrc() --hostdisplay: Failed to retrieve cookie from X server.
  Maybe your X server misses extension SECURITY. Will bake one with host cookie.'"
          echo       "    xauth -v -n -i -f $Xclientcookie add :$Newdisplaynumber . \$Hostcookie"
          echo       "  }"
          echo       "}"
        }
        echo         "[ -s '$Xclientcookie' ] || { "
        echo         "  # still no cookie? try to create one without extension security"
        echo         "  debugnote 'xinitrc(): Failed to retrieve trusted cookie from X server. Will bake one directly with xauth'"
        echo         "  xauth -v -n -i -f $Xclientcookie add :$Newdisplaynumber . $(makecookie)"
        echo         "}"
        echo         "[ -s '$Xclientcookie' ] && {"
        echo         "  # Prepare cookie with localhost identification disabled by ffff, needed if X socket is shared. ffff means 'familiy wild'"
        echo         "  Cookie=\"\$(xauth -n -i -f $Xclientcookie nlist | sed -e 's/^..../ffff/')\""
        echo         "  truncate -s0 $Xclientcookie"
        echo         "  echo \"\$Cookie\" | xauth -v -n -i -f $Xclientcookie nmerge -"
        echo         "}"
        echo         "[ -s '$Xclientcookie' ] || {"
        echo         "  debugnote 'xinitrc(): Failed to create cookie with xauth. Will try custom cookie baker script.'"
        echo         "  cookiebaker '$Newdisplay' >> $Xclientcookie"
        echo         "}"
        echo         "ls -l $Xclientcookie"
        echo         "truncate -s0 $Xservercookie"
        echo         "cat $Xclientcookie >> $Xservercookie"
        echo         "chmod 644 $Xclientcookie"
        echo         ""
        echo         "[ -s '$Xclientcookie' ] || error 'xinitrc(): Option --xauth=$Xauthentication: Cookie creation failed.'"
      }
      echo           "export XAUTHORITY=$Xclientcookie"
      echo           "[ '$Xauthentication' = 'no' ] || [ ! -s '$Xclientcookie' ] && unset XAUTHORITY && warning 'Option --xauth=no: X server $Newdisplay runs without cookie authentication.'"
      echo           ""
      case "$Xserver" in
        --hostdisplay) ;;   # do not change host settings
        *)
          case "$Xauthentication" in
            yes|trusted|untrusted)
              case "$Xserver" in
                runx) ;;
                *)
                  echo "# clean xhost"
                  echo "verbose 'Disabling any possible access to new X server possibly granted by xhost'"
                  echo "disable_X_access_via_xhost"
                ;;
              esac
            ;;
          esac
          [ -n "$Xhost" ] && {
            [ "$Xhost" = "auto" ] && Xhost="+SI:localuser:$Containeruser"
            echo     "warning \"Option --xhost: Running 'xhost $Xhost' on $Newdisplay\""
            echo     "xhost $Xhost"
          }
          echo       ""
        ;;
      esac

      case "$Xserver" in
        --hostdisplay|--nxagent) ;;
        --hostwayland|--weston|--kwin|--tty) ;;
        *)
          echo       "# Keyboard layout"
          [ -n "$Hostdisplay" ] && {
            xtool --check setxkbmap && {
              case "$Xkblayout" in
                "") 
                  #setxkbmap -display "$Hostdisplay" -print >> "$Xkbkeymapfile"
                  echo "env DISPLAY=$Hostdisplay XAUTHORITY=$Hostxauthority setxkbmap -display $Hostdisplay -print >> $Xkbkeymapfile"
                ;;
                *)
                  echo "setxkbmap '$Xkblayout' -print >> $Xkbkeymapfile"
                ;;
              esac
            }
            [ -s "$Xkbkeymapfile" ] && {
              echo   "# set keyboard layout on $Newdisplay"
              echo   "verbose \"Keyboard layout:"
              echo   "\$(cat $Xkbkeymapfile)\""
              echo   "xkbcomp $Xkbkeymapfile $Newdisplay"
            }
            echo     ""
          }
        ;;
      esac
    ;;
  esac

  case "$Xserver" in
    --xpra|--xpra2|--xvfb|--weston-xwayland|--xwayland)
      echo           "# create set of different screen resolutions"
      echo           "[ -e \"$Modelinefile\" ] && while read Line; do"
      echo           "  Line=\"\$(echo \"\$Line\" | sed 's/Modeline//g')\""
      echo           "  Line=\"\$(echo \"\$Line\" | sed 's/\"//g')\""
      echo           "  xrandr --newmode \$Line 2>/dev/null"
      echo           "  xrandr --addmode \"\$Output\" \$(echo \$Line | cut -d' ' -f1) 2>/dev/null"
      echo           "done < \"$Modelinefile\""
      [ -n "$Modeline" ] && {
        echo         "xrandr --newmode $Modeline"
        echo         "xrandr --addmode \$Output $(echo $Modeline | cut -d " " -f1)"
        [ "$Xserver" != "--xvfb" ] && [ "$Desktopmode" = "yes" ] && echo "xrandr --output  \$Output --mode $(echo $Modeline | cut -d " " -f1)"
      }
      echo           ""
    ;;
    --xorg) # --xorg: --scale, --size, --rotate
      echo           "# determine screen size"
      echo           '[ -n "$(xrandr | grep connected | grep -v disconnected)" ] && {'
      [ -z "$Screensize" ] && {
        echo         "  getscreensize"
        echo         "  Xaxis=\"\$CurrentXaxis\""
        echo         "  Yaxis=\"\$CurrentYaxis\""
        #
        if false ; then
            [ "$Scaling" ] && echo "  Xaxis=\"\$(awk -v a=\"\$Xaxis\" -v b=\"$Scaling\" 'BEGIN {print (a / b)}')\""
            echo         "  Xaxis=\"\${Xaxis%.*}\""
            [ "$Scaling" ] && echo "  Yaxis=\"\$(awk -v a=\"\$Yaxis\" -v b=\"$Scaling\" 'BEGIN {print (a / b)}')\""
            echo         "  Yaxis=\"\${Yaxis%.*}\""
        else
            [ "$Scaling" ] && echo "  Xaxis=\"\$( calculate_floor_a_per_b \"\$Xaxis\" \"$Scaling\" )\""
            [ "$Scaling" ] && echo "  Yaxis=\"\$( calculate_floor_a_per_b \"\$Yaxis\" \"$Scaling\" )\""
            # # The following should not be necessary if Xaxis and Yaxis are already integers.
            # echo         "  Xaxis=\"\${Xaxis%.*}\""
            # echo         "  Yaxis=\"\${Yaxis%.*}\""
        fi
        #
      } || {
        echo         "  Xaxis='$Xaxis'"
        echo         "  Yaxis='$Yaxis'"
      }
      echo           "  Screensize=\"\${Xaxis}x\${Yaxis}\""
      echo           ""

      [ "$Screensize" ] && [ -z "$Scaling" ] && {
        echo         "  # Switch to desired screen size $Screensize"
        echo         "  [ -n \"\$(xrandr | grep \$Screensize)\" ] && { "
        echo         "    note \"Will try to set native resolution \$Screensize."
        echo         "  If that looks ugly, use --scale=1 to enforce a fake scaled resolution.\""
        echo         "    xrandr --output \$Output --mode \$Screensize"
        echo         "  } || note \"Resolution \$Screensize not found in xrandr.\""
        echo         ""
      }

      [ "$Screensize" ] && [ -z "$Scaling" ] && {
        echo         "  checkscreensize || {"
        echo         "    note \"Panning \$Screensize. If virtual screen is greater than "
        echo         "  maximal screen size, you can move virtual screen with mouse at screen edges."
        echo         "  You can force the virtual screen to match your monitor with option --scale=1\""
        echo         "    xrandr --output \$Output --panning \$Screensize+0+0/\$Screensize+0+0/100/100/100/100 --verbose"
        echo         '  }'
        echo         "  checkscreensize || {"
        echo         "    note 'Panning failed, trying to scale instead.'"
        echo         "    xrandr --output \$Output --scale-from \$Screensize --panning \$Screensize+0+0/\$Screensize+0+0"
        echo         "    checkscreensize && note \"Successfully set screen size \$Screensize\""
        echo         '  }'
        echo         "  checkscreensize || {"
        echo         "    getscreensize"
        echo         "    note \"Setting desired resolution \$Screensize failed."
        echo         "  Fallback: Will use detected \${CurrentXaxis}x\${CurrentYaxis} instead.\""
        echo         '  }'
        echo         ""
      }

      [ "$Scaling" ] && {
        echo         "  # --scale $Scaling"
        [ "$Screensize" ] && [ "$Scaling" != "1" ] && echo "  note 'Cannot set panning and scaling at the same time.
  Desired screen size $Screensize will be scaled to your monitor size
  for arbitrary values you may provide with option --scale.'"
        echo         "  # Scaling $Scaling"
        echo         "  note \"Setting scaled resolution \$Screensize\" with scale factor $Scaling."
        # must use --scale-from and --panning because --scale causes mouse barriers/crtc-boundaries
        echo         "  xrandr --output \$Output --scale-from \$Screensize --panning \$Screensize+0+0/\$Screensize+0+0 --verbose"
        echo         "  checkscreensize || {"
        echo         "    getscreensize"
        echo         "    note \"Setting desired resolution \$Screensize failed."
        echo         "  Detected resolution \${CurrentXaxis}x\${CurrentYaxis} instead.\""
        echo         "  }"
        echo         ""
      }

      [ -n "$Rotation" ] && {
        echo         "  # --rotate $Rotation"
        echo         "  verbose 'Rotation $Rotation'"
        case "$Rotation" in
          0|normal)    Rotation="" ;;
          90)          Rotation="--rotate right";;
          180)         Rotation="--reflect xy" ;;
          270)         Rotation="--rotate left";;
          flipped)     Rotation="--reflect y";;
          flipped-90)  Rotation="--rotate right --reflect x";;
          flipped-180) Rotation="--reflect x";;
          flipped-270) Rotation="--rotate left --reflect x";;
        esac
        echo         "  bash -c 'while read Line ; do xrandr --output \$Line $Rotation ; done < <(xrandr | grep \" connected\" | cut -d \" \" -f1)'"
        echo         ""
      }
      echo           "  :"
      echo           "} || {"
      echo           "  Xaxis=${Xaxis:-1024}"
      echo           "  Yaxis=${Yaxis:-768}"
      echo           "  Screensize=\"\${Xaxis}x\${Yaxis}\""
      echo           "  note \"Could not detect any connected monitor."
      echo           "  Running on a server? Is xrandr installed? Will try to set a framebuffer size"
      echo           "  with \"xrandr --fb \$Screensize\" that may serve as a virtual display.\""
      echo           "  xrandr --fb \$Screensize"
      echo           "}"
      echo           ""
    ;;
  esac

  [ -n "$Newdisplay" ] && echo "verbose \"Output of xrandr on $Newdisplay
\$(xrandr)\""
  echo ""

  # --wm
  [ "$Windowmanagermode" = "host" ] && {  # Windowmanagermode_host
    echo             "# window manager"
    echo             "$Windowmanagercommand & storepid \$! windowmanager"
    echo             "# only one desktop"
    echo             "sleep 1 && wmctrl -n 1 &"
  }

  # --xeyes
  [ -n "$Xeyes" ] && {
    echo             "xeyes +shape $Xeyes &"
    echo             "storepid \$! xeyes"
  }

  # --xlogo
  [ -n "$Xlogo" ] && {
    echo             "xlogo &"
    echo             "storepid \$! xlogo"
  }

  # --xfishtank
  [ "$Xfishtank" = "yes" ] && echo "xfishtank -nomenu & storepid \$! xfishtank"

  echo               "echo 'xinitrc: xinitrc is ready'"
  #echo               "storeinfo_add_kv_sh xinitrc=ready"
  echo               ""

  # --clipboard
  case "$Shareclipboard" in
    no) ;;
    native* ) ;;
    yes|h2c|c2h|cmv)
      case "$Xserver" in
        --xwin|--runx) ;;                           # have their own clipboard management
        --hostdisplay|--hostwayland) ;;             # already same clipboard
        *)
          echo       "# option '-c, --clipboard': Run clipboard script"
          echo       "bash $Clipboardrc &"
          echo       ""
        ;;
      esac
    ;;
  esac

  # --checkwindow
  [ "$Checkforopenwindow" ] && {
    echo             "sleep 5"
    echo             "while rocknroll; do"
    echo             "  sleep 2"
    case "$Checkforopenwindow" in
      yes)
        echo         "  [ \"\$(xwininfo -root -children | grep -v '(has no name)' | awk '{print \$1}' | grep -c ^0x)\" = '0' ] && break"
      ;;
      *)
        echo         "  xwininfo -root -children | grep -q '$Checkforopenwindow' || break"
      ;;
    esac
    echo             "done"
    echo             "saygoodbye"
  }

  echo               "# wait for the end"
  case "$Usemkfifo" in
    yes) echo        "read Var <$Timetosaygoodbyefifo" ;;
    no)  echo        "while rocknroll; do sleep 1; done" ;;
  esac

  return 0
}

#
# function disable_X_access_via_xhost() : Remove any access to X server granted by
#                            `xhost`
#
# Usage: disable_X_access_via_xhost [Environment]
#
# Environment : passed to "env $Environment xhost".
#               Defaults to `"DISPLAY=$DISPLAY XAUTHORITY=$XAUTHORITY"`
#
# global DISPLAY
# global XAUTHORITY
#
# Note: also used under /bin/sh in xinitrc
#
disable_X_access_via_xhost() {
    local Environment
    Environment="${1:-"DISPLAY=$DISPLAY XAUTHORITY=$XAUTHORITY"}"
    local Line=""
    #
    xtool --check xhost || return 1
    #
    # Disable every entry
    #
    {
        # Note: "| tail -n +2  /dev/stdin" skips the first line (header).
        # Q: Why is it part of the xtool argument?
        # Q: Why does it need an explicit "/dev/stdin" argument?
        #
        xtool "env $Environment xhost 2>&1 | tail -n +2  /dev/stdin" \
            | while read -r Line ; do
            #
            debugnote "xhost: Removing entry $Line"
            xtool "env $Environment xhost -'$Line'"
        done
    }
    #
    # Enable access control
    xtool "env $Environment xhost -"

    #
    # Check what did we achieve
    #
    if [ "$(xtool "env $Environment xhost 2>&1 | wc -l")" -gt "1" ] ; then
        warning "$(printf "%s\n%s"                                       \
         "Remaining xhost permissions found on display ${DISPLAY:-}"     \
         "$(xtool "env $Environment xhost 2>&1" )"
         )"
        return 1
    fi

    if xtool "env $Environment xhost 2>&1" | grep -q "access control disabled" ; then
        warning_ttm "|Failed to restrict xhost permissions.
                     |  Access to display ${1:-} is allowed for everyone."
        return 1
    fi
    return 0
}

setup_xcnetwork() {             # --xoverip --xc: start internal network between X container and command container
  local Internal
  [ "$BackendKind" = "$Xcontainerbackend" ] && [ "$Xcrootless" = "$Backendrootless" ] || return 1
  case "${1:-}" in
    "")
      [ "$Xcontainer_option" = "yes" ] && [ "$Hostxoverip" = "no" ] && {
        case "$Xoverip" in
          yes|listentcp|socat)
            case "$g_Network" in
              none) Internal="--internal" ;;
              ""|bridge) Internal="";;
              *) return 1 ;; ### FIXME
            esac
            Xcnetworkid="$(unpriv_backend "$Backendbin network create $Internal $Xcnetworkname")" 2>>$Xinitlogfile || return 1
            debugnote "setup_xcnetwork(): Creating $Xcnetworkname $Xcnetworkid"
          ;;
        esac
      }
    ;;
    remove)
      [ -n "$Xcnetworkid" ] && {
        debugnote "setup_xcnetwork(): Removing $Xcnetworkname $Xcnetworkid"
        unpriv_backend "$Backendbin network remove $Xcnetworkid" >>$Xinitlogfile 2>&1 || return 1
      }
    ;;
  esac
  return 0
}

store_newxenv() {               # store display variables
    #
    Newdisplay="${Newdisplay//"XCONTAINERIP"/"$Xcontainerip"}"
    #
  # create $Newxenv: collection of environment variables to access new X from host (e.g. in xinitrc)
  [ "$Newdisplay" ]                   && storeinfo_add_kv_sh "DISPLAY=$Newdisplay"                 && Newxenv="$Newxenv DISPLAY=$Newdisplay"
  [ "$Xauthentication" != "no" ]      && storeinfo_add_kv_sh "XAUTHORITY=$Xclientcookie"           && Newxenv="$Newxenv XAUTHORITY=$Xclientcookie"
  case "$Newwaylandsocket" in
    "")
      [ "$Sharehostwayland" = "yes" ] && storeinfo_add_kv_sh "WAYLAND_DISPLAY=$Hostwaylandsocket"  && Newxenv="$Newxenv WAYLAND_DISPLAY=$Hostwaylandsocket"
    ;;
    *)
                                         storeinfo_add_kv_sh "WAYLAND_DISPLAY=$Newwaylandsocket"   && Newxenv="$Newxenv WAYLAND_DISPLAY=$Newwaylandsocket"
    ;;
  esac
  [ "$Setupwayland" = "yes" ] && for Line in $Waylandtoolkitenv ; do                        Newxenv="$Newxenv $Line" ; done
  [ -n "$XDG_RUNTIME_DIR" ]           && storeinfo_add_kv_sh "XDG_RUNTIME_DIR=$XDG_RUNTIME_DIR"    && Newxenv="$Newxenv XDG_RUNTIME_DIR=$XDG_RUNTIME_DIR"
  Newxenv="$(awk '{$1=$1;print}' <<< " $Newxenv ")" # Remove superfluous whitespaces
  storeinfo_add_kv_sh "Xenv=$Newxenv"

  # X / Wayland environment variables for container
  case "$Xserver" in
    --xpra*|--xephyr|--weston-xwayland|--hostdisplay|--xorg|--xvfb|--xwayland|--satellite|--kwin-xwayland|--nxagent|--xwin|--runx)
      store_runoption_env "DISPLAY=$Newdisplay"
      [ "$Xauthentication" != "no" ] && store_runoption_env "XAUTHORITY=$(convertpath share "$Xclientcookie")"
    ;;
  esac
  case "$Xserver" in
    --weston|--kwin|--tty)
      store_runoption_env "WAYLAND_DISPLAY=$Newwaylandsocket"
    ;;
    --hostwayland)
      store_runoption_env "WAYLAND_DISPLAY=$Hostwaylandsocket"
    ;;
  esac
  [ "$Setupwayland" = "yes" ] && {
    for Line in $Waylandtoolkitenv; do
      store_runoption_env "$Line"
    done
  }
  
  return 0
}


#
# function xtool() :
#
# Run X tool command in X container if available, otherwise on host
#
# Examples:
#   xtool --check "wmctrl"
#   xtool "vainfo 2>&1 | grep drv_video.so
#   Xrandroutput="$(xtool "xrandr" ||:)"
#   xtool --check cvt && ...
#   Modeline="$(xtool "cvt '$Xaxis' '$Yaxis'" | tail -n1 | cut -d' ' -f2-)"
#   xtool --check --quiet xinit || { ... }
#   xtool --check --quiet xdotool || { ... }
#   xtool --check --quiet xeyes
#   xtool --check --quiet xlogo
#   xtool --check --quiet xfishtank
#   Xdpyinfooutput="$(xtool "xdpyinfo 2>> $Xinitlogfile" ||:)"
#   xtool --check setxkbmap
#   xtool --check xhost
#   xtool "env $Environment xhost 2>&1 | tail -n +2  /dev/stdin" | while read -r Line ; do ...
#   xtool "env $Environment xhost -'$Line'"
#   xtool "env $Environment xhost -"
#   xtool "env $Environment xhost 2>&1 | wc -l"
#   xtool "env $Environment xhost 2>&1" | grep -q "access control disabled"
#   xtool "xdotool windowunmap 0x$(printf '%x\n' $(grep 'window id' "$Compositorlogfile" | rev | cut -d' ' -f1 | rev))"
#   xtool --check "xauth"
#   xtool --nocheck "env LD_PRELOAD= xdpyinfo 2>>$Xinitlogfile | grep -q MIT-SHM"
#   xtool --check --quiet xdpyinfo
#   xtool --check xbindkeys
#   xtool --check xclip
#   xtool --check wl-copy
#   xtool --check xrandr
#   xtool --check xwininfo
#   xtool --check "xhost"
#
#   xtool "env DISPLAY=:$Newdisplaynumber XAUTHORITY=$Xclientcookie xhost +INET:$Containerip"
#
# Usage: xtool [ { --check | --nocheck } ]
#              [ { note|debugnote|verbose|warning|error | --quiet } ]
#              "the_command"
#
# --check   : Only check, do not run
# --nocheck : Set Check to "no". Usexcontainer fallback is "yes".
#   Neither : ??? Usexcontainer fallback is "no". Do run the_command.
#
#  { note|debugnote|verbose|warning|error | --quiet }
#        Set "Message" used for messages.
#        Only --quiet is actually used.
#        The default is ":" for --nocheck, "note" otherwise.
#
#  the_command  The command to run as
#               unpriv_xcbackend "$Xcontainerbackend exec $Xcontainername ${the_command}"
#          or   unpriv "${the_command}"
#
xtool() {
    local Tool Toolinfo Usexcontainer
    local Check=

    # Nocheck is unused
    # local Nocheck=

    local Message
    local the_command

    Message="note"
    case "${1:-}" in
        --check)       Check="yes" ;  Message="note" ; shift ;;
        --nocheck)     Check="no"  ;  Message=":"    ; shift ;;
        *)
            Check="" # Or should it be "no"?
            Message="note"
            ;;
    esac

    case "${1:-}" in
        note|debugnote|verbose|warning|error)
            Message="${1:-}"
            shift
            ;;
        --quiet)
            Message=":"
            shift
            ;;
    esac

    the_command="${1:-}"
    #
    # extract tool from "env a=b tool args"
    #
    # Step1: remove NonSpaces*(=|env )NonSpaces*
    # Step2: remove intial spaces
    # Step3: keep the word before the first space
    Tool="$(sed 's/\S*\(=\|env \)\S*//g ; s/^ *//' <<< "${the_command}" | cut -d' ' -f1)"

    #
    # set Toolinfo (used in Please install... message)
    #
    case "$Tool" in
        cvt)
            # man cvt - calculate VESA CVT mode lines
            Toolinfo="$(trim_to_bar \
                     "|x11docker uses cvt to create a set of screen resolutions
                      |  that can be seen and set by tools like xrandr."
                      )" ;;
        setxkbmap|xkbcomp)
            Toolinfo="$(trim_to_bar \
                     "|x11docker uses setxkbmap and xkbcomp to set the keyboard
                      |  in new X server to same as on host or specified with --keymap."
                      )"
            ;;
        socat)
            Toolinfo="socat allows to set up TCP access to X unix sockets."
            ;;
        vainfo)
            # man vainfo - display information from VA API driver
            Toolinfo="vainfo helps to configure VAAPI video decoding support."
            ;;
        wl-copy|wl-paste)
            Toolinfo="$(trim_to_bar \
                     "|x11docker uses wl-copy and wl-paste for Wayland clipboard support."
                      )"
            ;;
        wmctrl)
            Toolinfo="$(trim_to_bar \
                     "|x11docker uses wmctrl to configure window managers
                      |  to provide one virtual desktop only."
                      )"
            ;;
        xauth)
            Toolinfo="xauth creates and adjusts X authentication cookies."
            ;;
        xbindkeys)
            Toolinfo="xbindkeys intercepts SUPER+v or ALT+v for option --clipboard."
            ;;
        xclip)
            Toolinfo="xclip is needed for option --clipboard."
            ;;
        xdpyinfo)
            Toolinfo="$(trim_to_bar \
                    "|xdpyinfo provides some information about the host X server.
                     |  It tells x11docker about dpi and installed extensions like MIT-SHM."
                     )"
            ;;
        xdotool)
            Toolinfo="$(trim_to_bar \
                    "|x11docker uses xdotool to hide the weston window
                     |  that is used in background for --xpra-xwayland."
                     )"
            ;;
        xeyes)
            Toolinfo="$(trim_to_bar \
                    "|xeyes shows eyes following your mouse cursor. 
                     |  The xeyes X window can provide focus for --clipboard=cmv."
                     )"
            ;;
        xlogo)
            Toolinfo="$(trim_to_bar \
                    "|xlogo shows the X11 logo in an X11 window. 
                     |  This window can provide focus for --clipboard=cmv."
                     )"
            ;;
        xfishtank)
            Toolinfo="xfishtank shows a fish tank with --xfishtank."
            ;;
        xhost)
            Toolinfo="$(trim_to_bar \
                    "|xhost controls network access to X. x11docker uses it to disable
                     |  undesired network access, or to allow some with option --xhost=ARG."
                     )"
            ;;
        xinit)
            Toolinfo="xinit serves to properly start and stop most X servers."
            ;;
        xrandr)
            Toolinfo="$(trim_to_bar \
                    "|xrandr allows to check or set the screen size (option --size).
                     |  with --xorg it also helps at options --rotate and --scale."
                     )"
            ;;
        xwininfo)
            Toolinfo="$(trim_to_bar \
                    "|x11docker needs xwininfo for option --checkwindow
                     |  to get a list of currently open windows."
                     )"
            ;;
    esac

    #
    # set Usexcontainer
    #
    case "$Xcontainer_option" in
        yes)
            Usexcontainer="yes"
            if ! word_is_in "$Tool" "$Xcontainertools" ; then
                $Message "$(trim_to_bar \
                   "|Option --xc: Please update image x11docker/xserver.
                    |  Did not find command '$Tool' in image. Will try to run '$Tool' on host"
                    )"
                Usexcontainer="no"
            fi
            ;;
        no)
            Usexcontainer="no"
            ;;
    esac

    if [ "$Check" = "no" ] ; then
        Usexcontainer="${Usexcontainer:-yes}"
    else
        # Check in yes|""
        # Only checking (?)
        Usexcontainer="${Usexcontainer:-no}" # in case xinitrc already runs in X container.
    fi
    verbose "xtool(): (use xc $Usexcontainer): ${the_command}"

    #
    # Check tool availability on host
    #
    case "$Usexcontainer" in
        no)
            if ! have_command  "$Tool"  ; then
                $Message  "$(trim_to_bar \
                    "|xtool(): Command '$Tool' not found on host. Please install $Tool.
                     |  $Toolinfo
                     |  $Wikipackagesimage"
                     )"
                return 1
            fi
            ;;
    esac

    if [ "$Check" = "yes" ] ; then
        # Only cheking
        return 0
    fi

    #
    # Run the tool
    #
    case "$Usexcontainer" in
        yes)
            unpriv_xcbackend "${Xcontainerbackend} exec ${Xcontainername} ${the_command}"
            ;;
        no)
            unpriv "${the_command}"
            ;;
    esac
    return $?
} # end xtool()


