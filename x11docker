# Function: check_newxenv
# Brief: Find a free display number
#
check_newxenv()  {
    local Line Newwaylandnumber
    # Find free display number
    #
    #
    if [ -z "$Newdisplaynumber" ] ; then
        Newdisplaynumber="0"
        #
        while : ; do
            #
            if [ ! -e "/tmp/.X11-unix/X$Newdisplaynumber" ] \
            && [ ! -e "/tmp/.X$Newdisplaynumber-lock"     ] ;
            then break ; fi
            #
            case "$Xserver" in
                --xwin|--runx)
                    # Try a random value. Why?
                    Newdisplaynumber="$((RANDOM / 10 + 200))"
                    ;;
                *)
                    # Try the next one
                    Newdisplaynumber="$((Newdisplaynumber + 1))"
                    ;;
            esac
        done
        #
        Newwaylandnumber="0"
        while : ; do
            Newwaylandnumber="$((Newwaylandnumber + 1))"
            if [ ! -e "$XDG_RUNTIME_DIR/wayland-$Newwaylandnumber" ] ;
            then break ; fi
        done
    fi
    echo "$Newdisplaynumber" >> "$Numbersinusefile"

    # --xoverip
    if [ -z "$Xoverip" ] ; then
        case "$Dockervm" in
            moby)
                Xoverip="listentcp"
                ;;
            desktop)
                note "Option --xoverip is enabled to allow Docker Desktop VM."
                Xoverip="listentcp"
                ;;
        esac

        case "$Runtime" in
            kata-runtime)
                note_ttm "|Option --runtime=$Runtime works only with X over IP.
                          |  Enabling option --xoverip."
                Xoverip="listentcp"
                ;;
        esac

        case "$Xserver" in
            --xwin|--runx)
                Xoverip="listentcp"
                if [ "$g_Network" = "none" ] ; then
                    note_ttm "|Option $Xserver needs network access.
                              |  Enabling option -I, --network."
                    check_fallback
                    g_Network=""
                fi
                ;;
            --hostdisplay)
                if [ "$Hostxoverip" = "yes" ] ; then
                    note_ttm \
                        "|Option $Xserver needs --xoverip because host X server
                         |  DISPLAY==$Hostdisplay uses X over TCP/IP.
                         : Enabling option --xoverip."
                    #
                    Xoverip="listentcp"
                fi
                ;;
        esac
    fi # [ -z $Xoverip ]

    case "$Xoverip" in
        yes)
            case "$Xserver" in
                --hostdisplay)
                    if grep -q -- '^:' <<< "$Hostdisplay" ;
                    then Xoverip="socat"
                    else Xoverip="listentcp"
                    fi
                    ;;
                *)
                    Xoverip="listentcp"
                    ;;
            esac
            ;;
    esac

    Xoverip="${Xoverip:-no}" # If did not set it yet, fallback to "no"

    case "$Xoverip" in
        socat|listentcp)
            case "$BackendKind" in
                docker|podman|nerdctl)
                    case "$Xcontainer_option" in
                        yes)
                        ;;
                        no)
                            if [ "$g_Network" = "none" ] ; then
                                error_ttm \
                                    "|Option --xoverip needs network access.
                                     |  Please enable option -I, --network.
                                     |  Alternatively provide image x11docker/xserver (option --xc)
                                     |  to allow an isolated internal network."
                            fi
                            ;;
                    esac
                    ;;
            esac
            ;;
    esac

    # --xc --xoverip
    Xcnetworkname="x11docker_X${Newdisplaynumber}_network_${Cachenumber}"

    ###

    # set $Newdisplay (DISPLAY of container) and $Newxsocket
    case "$Xserver" in
        --hostdisplay)
            case "$Xoverip" in
                listentcp) if [ "$(cut -c1 <<< "$Hostdisplay")" = ":" ] ;
                           then  Newdisplay="${Hostip}${Hostdisplay}"
                           else  Newdisplay="$Hostdisplay" ; fi  ;;
                no)              Newdisplay="$Hostdisplay"
                                 Newdisplaynumber="$(echo "$Newdisplay" | cut -d: -f2 | cut -d. -f1)" ;;
                socat) case "$Xcontainer_option" in
                           yes) Newdisplay="XCONTAINERIP:$Newdisplaynumber" ;;
                           no)  Newdisplay="$Hostip:$Newdisplaynumber"      ;;   esac ;;
            esac
            Newxsocket="$Hostxsocket"
            ;;
        --weston|--kwin|--hostwayland|--tty)
            Newdisplay=""
            Newxsocket=""
            Xclientcookie=""
            Xservercookie=""
            ;;
        *) # other Xserver
            case "$Xoverip" in
                socat|listentcp)
                    case "$Xcontainer_option" in
                        yes) Newdisplay="XCONTAINERIP:$Newdisplaynumber"           ;;
                        no)
                            case "$Xserver" in
                                --runx) Newdisplay="$Hostipwindows:$Newdisplaynumber"   ;;
                                *)      Newdisplay="$Hostip:$Newdisplaynumber"          ;;
                            esac ;;
                    esac
                    ;;
                no)
                    Newdisplay=":$Newdisplaynumber"
                    Newxlock="/tmp/.X$Newdisplaynumber-lock"
                    #
                    #
                    if [ -e "$Newxsocket" ] || [ -e "$Newxlock" ] ; then
                        error "Display $Newdisplay is already in use."
                    fi
                    ;;
            esac
            Newxsocket="/tmp/.X11-unix/X$Newdisplaynumber"
            #
            # Fix for WSL2g #557, create unix socket file for virtual
            #        socket, available only because /tmp/.X11-unix is
            #        read-only
            #
            if [ "$X11unixrw" = "no" ]           \
            && [ "$Xoverip"   = "no" ]           \
            && [ "$Xserver" != "--hostdisplay" ] \
            && [ "$Xcontainer_option" = "no"   ] ;
            then
                if have_command  socat  ; then
                    Newxsocket="$Cachefolder/tmp/.X11-unix/X$Newdisplaynumber"
                    socat UNIX-LISTEN:${Newxsocket},fork,unlink-close \
                          ABSTRACT-CONNECT:/tmp/.X11-unix/X${Newdisplaynumber} &
                    storepid $! "socat_X$Newdisplaynumber"
                else
                    note_ttm \
                        "|It seems you are running x11docker on WSL2g.
                         |  Because WSL2g mounts /tmp/.X11-unix read-only,
                         : x11docker needs either socat
                         |  for a workaround, so please install socat, or
                         : use option --xoverip.
                         |  This start of x11docker is likely to fail."
                fi
            fi
            ;; #  # other Xserver
    esac

    # set $Newwaylandsocket
    case "$Xserver" in
        --weston*|--kwin*|--xpra-xwayland|--xpra2-xwayland)
            Newwaylandsocket="wayland-$Newwaylandnumber"
            ;;
    esac

  return 0
} # check_newxenv()

