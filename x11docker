                    # Only create X server / --xonly  # BackendKind_host
                    Codename="xonly"
                    g_BackendKind="${g_BackendKind:-host}" # BackendKind_host
                    g_Containercommand="sleep infinity"
                    Showdisplayenvironment="${Showdisplayenvironment:-yes}"
                    ;;
            esac
        fi

        g_BackendKind="${g_BackendKind:-docker}"
        case "$g_BackendKind" in
            docker|podman|host) ;; # BackendKind_host
            proot|nerdctl) 
                note_ttm "|Option --backend=$g_BackendKind is deprecated.
                          |  Please use --backend=docker or --backend=podman instead."
                ;;
            *) 
                error "Option --backend: Unknown argument '$g_BackendKind'."
                ;;
        esac
    }
    POST_CONDITION g_BackendKind  'word_is_in "$g_BackendKind" "docker podman host proot nerdctl"'

    # Shareclipboard : --clipboard
    {
        case "$Shareclipboard" in
            yes|no|cmv|h2c|c2h) ;;
            superv|altv)
                note_ttm "|Option --clipboard=$Shareclipboard is deprecated.
                          |  Please use --clipboard=cmv instead.
                          |  This uses key combo [CRTL] + [META] + v
                          |  Fallback: Setting --clipboard=cmv"
                #
                check_fallback
                Shareclipboard="cmv"
                ;;
            oneway)
                note_ttm "|Option --clipboard=$Shareclipboard:
                          |  Argument $Shareclipboard is deprecated.
                          |  Please use --clipboard=c2h instead."
                #
                Shareclipboard="c2h"
                ;;
            *)
                note_ttm "|Option --clipboard: Unknown argument '$Shareclipboard'.
                          |  Fallback: Disabling option --clipboard."
                #
                check_fallback
                Shareclipboard="no"
                ;;
        esac
    }
    POST_CONDITION Shareclipboard 'word_is_in "${Shareclipboard}" "yes no cmv h2c c2h"'

    # Dbusrunsession Dbussystem : --dbus [=system]
    {
        case "$Dbusrunsession" in
            yes|user|session) Dbusrunsession="yes" ;;
            no) ;;
            system)
                Dbusrunsession="yes"
                Dbussystem="yes"
                ;;
            *)
                note_ttm "|Option --dbus: Unknown argument '$Dbusrunsession'.
                          |  Fallback: Enabling --dbus user session."
                #
                check_fallback
                Dbusrunsession="yes"
                ;;
        esac
    }
    POST_CONDITION Dbusrunsession 'word_is_in "${Dbusrunsession}"  "yes no"'
    POST_CONDITION Dbussystem     'word_is_in "${Dbussystem}"      "yes no"'
    
    # Dpi : --dpi
    {
        if [ -n "$Dpi" ] ; then
            if ! isnum "$Dpi" ; then
                note_ttm "|Option --dpi only accepts numeric values. Not numeric: '$Dpi'
                          |  Fallback: Disabling option --dpi."
                #
                check_fallback
                Dpi=""
            fi
        fi
    }
    POST_CONDITION Dpi '[ -z "${Dpi}" ] || isnum "${Dpi}" '

    # Sharegpu : --gpu
    {
        case "$Sharegpu" in
            yes|no|direct|iglx) ;;
            virgl)
                note "Option --gpu=virgl: Argument 'virgl'  is deprecated."
                ;;
            *)
                note_ttm "|Option --gpu: Unknown argument '$Sharegpu'.
                          |  Fallback: Disabling option --gpu."
                #
                check_fallback
                Sharegpu="no"
                ;;
        esac
    }
    POST_CONDITION Sharegpu 'word_is_in "${Sharegpu}"  "yes no direct iglx virgl"'

    # Hosthomebasefolder : --homebasedir
    {
        if [ -n "$Hosthomebasefolder" ] ; then
            Hosthomebasefolder="$(convertpath subsystem "$Hosthomebasefolder")"
            if [ ! -e "$Hosthomebasefolder" ] ; then
                error_ttm "|Option --homebasedir: Specified path does not exist:
                           |  $Hosthomebasefolder"
            fi
        fi
    }
    POST_CONDITION Hosthomebasefolder '[ -z "${Hosthomebasefolder}" ] || [ -e  "${Hosthomebasefolder}" ] '

    # g_Initsystem : --init
    {
        case "$g_Initsystem" in
            tini | systemd | sysvinit | openrc | runit | dockerinit | s6-overlay )
                : # NOP
                ;;
            no | none )
                g_Initsystem="none"
                ;;
            *)
                # FIXME: dockerinit is accepted above, but not mentioned here. Why?
                note_ttm "|Option --init: Unknown init system $g_Initsystem
                          |  Possible: tini systemd sysvinit openrc runit s6-overlay none
                          |  Fallback: Using --init=tini instead."
                #
                check_fallback
                g_Initsystem="tini"
                ;;
        esac
    }
    POST_CONDITION g_Initsystem 'word_is_in "${g_Initsystem}" \
            "tini systemd sysvinit openrc runit dockerinit s6-overlay none"'

    # g_Limitresources : --limit N
    {
        if [ -n "$g_Limitresources" ] ; then
            #
            #  g_Limitresources should be in the interval "(0,1]"
            #
            if  num_compare  "$g_Limitresources" ">"  1 \
            ||  num_compare  "$g_Limitresources" "<=" 0 ;
            then
                warning_ttm \
                    "|Option --limit: Specified value '$g_Limitresources' is out of range.
                     |  Allowed is a factor greater than 0 and less than or equal to 1.  0<FACTOR<=1
                     |  Fallback: Setting limit factor to --limit=0.5"
                #
                check_fallback
                g_Limitresources="0.5"
            fi
        fi
    }
    POST_CONDITION g_Limitresources \
           '[ -z "${g_Limitresources}" ] || is_num_in_interval  "${g_Limitresources}" "(0,1]" '

    # g_Containername : --name
    {
        if [ -n "$g_Containername" ] ; then
            if [ "$g_Containername" != "$( unspecialstring "$g_Containername" "." )" ] ; then
                error_ttm \
                    "|Option --name: container name must not contain special chars.
                     |  Compare:
                     |  $g_Containername
                     |  $( unspecialstring "$g_Containername" "." )
                     |"
                #
            fi
        fi
    }
    POST_CONDITION g_Containername \
                   '[ -z "${g_Containername}" ] || [[ "${g_Containername}" =~ ^([a-zA-Z0-9_.]+)$  ]] '

    # Allownewprivileges : --newprivileges
    {
        if ! case_match "$Allownewprivileges" 'yes|no|auto' ; then
            note_ttm "|Option --newprivileges: Unknown argument '$Allownewprivileges'.
                      |  Fallback: Setting --newprivileges=auto"
            #
            check_fallback
            Allownewprivileges="auto"
        fi
    }
    POST_CONDITION Allownewprivileges 'word_is_in "${Allownewprivileges}"  "yes no auto" '

    # Outputcount : --output-count
    {
        if ! [[ "$Outputcount" =~ ^[1-9]$ ]] ; then
            note_ttm "|Option --output-count: Value must be one of 1 2 3 4 5 6 7 8 9
                      |  Disabling invalid value $Outputcount"
            #
            check_fallback
            Outputcount="1"
        fi
    }
    POST_CONDITION Outputcount 'word_is_in "${Outputcount}" "1 2 3 4 5 6 7 8 9" '

    # Sharecupsmode : --printer
    {
        if ! case_match "$Sharecupsmode" ' socket | tcp | auto | "" ' ; then
            note_ttm "|Option --printer: Unknown argument '$Sharecupsmode'.
                  |  Fallback: Setting --printer=auto."
            #
            check_fallback
            Sharecupsmode="auto"
        fi
    }
    POST_CONDITION Sharecupsmode \
                   '[ -z "${Sharecupsmode}" ] || word_is_in "${Sharecupsmode}"  "socket | tcp | auto" '

    # Pulseaudiomode : --pulseaudio
    if ! case_match "$Pulseaudiomode" ' socket|tcp|auto|host| "" ' ; then
        note_ttm "|Option --pulseaudio: Unknown argument '$Pulseaudiomode'.
                  |  Fallback: Setting --pulseaudio=auto."
        #
        check_fallback
        Pulseaudiomode="auto"
    fi
    POST_CONDITION Pulseaudiomode \
                   '[ -z "${Pulseaudiomode}" ] || word_is_in "${Pulseaudiomode}" "socket tcp auto host" '

    # Backendrootless : --rootless
    {
        if ! case_match "$Backendrootless" ' yes|no| "" ' ; then
            error_ttm "|Option --rootless: Unknown argument: $Backendrootless
                       |      Allowed values: yes|no"
            #
        fi
    }
    POST_CONDITION Backendrootless '[ -z "${Backendrootless}" ] || word_is_in "${Backendrootless}" "yes no" '

    # Rotation : --rotate
    {
        if [ -n "$Rotation" ] ; then
            if ! word_is_in "$Rotation" "0 90 180 270 flipped flipped-90 flipped-180 flipped-270" ; then
                note_ttm "|Option --rotate: Unsupported value '$Rotation'.
                          |  Must be one of 0 90 180 270 flipped flipped-90 flipped-180 flipped-270
                          |  Fallback: disabling option --rotate"
                #
                check_fallback
                Rotation=""
            fi
        fi
    }
    POST_CONDITION Rotation \
       '[ -z "$Rotation" ] || word_is_in "$Rotation" "0 90 180 270 flipped flipped-90 flipped-180 flipped-270"'

    # Runtime : --runtime
    {
        case "$Runtime" in
            runc|crun|sysbox|sysbox-runc)
            # NOP
            ;;
            kata|kata-runtime)
                Runtime="kata-runtime"
                note_ttm "|Option --runtime=kata-runtime:
                      |  Support of kata-runtime is deprecated."
                #
                ;;
        esac
    }
    #
    # POST_CONDITION Runtime 'word_is_in "$Runtime" "runc crun sysbox sysbox-runc nvidia kata-runtime"'
    #
    # In create_xcontainercommand(), Runtime_can_be_empty and Runtime_can_be_anything 
    #
    # https://docs.docker.com/engine/daemon/alternative-runtimes/
    #     You can use any runtime that implements the containerd shim API.
    #      https://github.com/containerd/containerd/blob/main/docs/runtime-v2.md
    #

    # Scaling : --scale
    {
        if [ -n "$Scaling" ] ; then
            if ! isnum "$Scaling" ; then
                note_ttm "|Option --scale needs a number. '$Scaling' is not allowed.
                          |  Fallback: disabling option --scale"
                #
                check_fallback
                Scaling=""
            fi
        fi
    }
    POST_CONDITION Scaling '[ -z "${Scaling}" ] || isnum "${Scaling}"'

    # SharevolumesArray : --share
    {
        while read Line; do

            # If Line contains slash, backslash, or colon, then
            # convertpath
            if grep -q -E "/|\\|:" <<< "$Line" ; then
                Line="$(convertpath subsystem "$Line")"
            fi

            if [ "${Line:0:1}" != "/" ] && grep -q "/" <<< "$Line" ; then
                error_ttm "|Option --share needs either an absolute path
                       |  or a volume name without any '/':
                       |  $Line"
                #
            fi

            if [ "${Line:0:1}" = "/" ] && [ ! -e "$Line" ] ; then
                error_ttm "|Option --share: File or folder does not exist:
                       |  $Line"
                #
            fi

            if [ -z "$Line" ] ; then
                error "Option --share needs an argument"
            fi

        done < <(store_runoption_dump_volume)
    }
    # POST_CONDITION SharevolumesArray
    #
    # Each entry in SharevolumesArray (printed by
    # store_runoption_dump_volume) is either
    #
    # - (1) a volume name that does not contain a slash, backslash, or
    #       colon, or
    #
    # - (2) a path that after @code{ convertpath subsystem } becomes
    #       an absolute path of a file or dir that exists.
    #

    # Screensize : --size
    {
        if [ -n "$Screensize" ] ; then
            if ! [[ "$Screensize" =~ ^[0-9]+x[0-9]+$ ]] ; then # Screensize_parse
                note_ttm "|Option --size: Invalid argument: $Screensize
                          |  Must consist of two integers with an x between them.
                          |  Fallback: Disabling option --size"
                #
                check_fallback
                Screensize=""
            fi
        fi
    }
    POST_CONDITION Screensize '[ -z "$Screensize" ] || [[ "$Screensize" =~ ^[0-9]+x[0-9]+$ ]] '

    # Sudouser : --sudouser
    {
        #
        # FIXME: Could not figure out the purpose, or even the effect
        #        of the next line.
        #
        # Sudouser="${Sudouser,,}"
        #
        case "$Sudouser" in
            no|"")
                Sudouser="" # empty means disabled
                ;;
            yes|nopasswd)
                : # NOP
                ;;
            *)
                note_ttm "|Option --sudouser: Unknown argument '$Sudouser'.
                          |  Fallback: Disabling option --sudouser."
                #
                Sudouser=""
                check_fallback
                ;;
        esac
    }
    POST_CONDITION Sudouser '[ -z "${Sudouser}" ] || word_is_in "${Sudouser}" "yes nopasswd" '

    # Installerarg : --update, --update-master
    {
        case "$Installerarg" in
            "")   ;;
            diff) ;;
            *)
                error "Option --update/--update-master: Unknown argument '$Installerarg'."
                ;;
        esac
    }
    POST_CONDITION Installerarg '[ -z "${Installerarg}" ] || word_is_in "${Installerarg}"  "diff" '

    # Newxvt : --vt
    {
        if [ -n "$Newxvt" ] ; then
            if [ "$Newxvt" != "auto" ] && ! isint "$Newxvt" ; then
                note_ttm "|Option --vt: Argument must be a positive integer: $Newxvt
                          |  Fallback: Disabling option --vt"
                #
                check_fallback
                Newxvt=""
            fi
        fi
    }
    POST_CONDITION Newxvt '[ -z "$Newxvt" ] || [ "$Newxvt" = "auto" ] || isint "$Newxvt"'

    # Westonarg : --weston
    # Affects:  Xserver, Setupwayland, Desktopmode
    {
        case "$Westonarg" in
            x)
                Xserver="--weston-xwayland"
                Setupwayland="yes"
                ;;
            X)
                Xserver="--weston-xwayland"
                Setupwayland="yes"
                Desktopmode="yes"
                ;;
            "") ;;
            *)
                note_ttm "|Option $Xserver: Unkown argument '$Westonarg'.
                          |  Fallback: Disabling argument."
                #
                check_fallback
                Westonarg=""
                ;;
        esac
    }
    POST_CONDITION Westonarg '[ -z "$Westonarg" ] || word_is_in "$Westonarg" "x X" '

    # Xauthentication : --xauth
    {
        case "$Xauthentication" in
            yes|no|trusted|untrusted|-ac) ;;
            *)
                note_ttm "|Option --xauth: Unknown argument: $Xauthentication
                          |  Fallback: Setting --xauth=yes"
                #
                check_fallback
                Xauthentication="yes"
                ;;
        esac
    }
    POST_CONDITION Xauthentication 'word_is_in "$Xauthentication" "yes no trusted untrusted -ac"'

    # Xoverip : --xoverip
    {
        case "$Xoverip" in
            yes|no|listentcp|socat|"") ;;
            *)
                note_ttm "|Option --xoverip: Unknown argument: $Xoverip
                          |  Fallback: Disabling option --xoverip"
                #
                check_fallback
                Xoverip="no"
                ;;
        esac
    }
    POST_CONDITION Xoverip '[ -z "$Xoverip" ] || word_is_in "$Xoverip" "yes no listentcp socat"'

    # Xtest : --xtest
    {
        case "$Xtest" in
            yes|no|"") ;;
            *)
                note_ttm "|Option --xtest: Unknown argument: $Xtest
                          |  Fallback: Disabling option --xtest"
                #
                check_fallback
                Xtest=""
                ;;
        esac
    }
    POST_CONDITION Xtest '[ -z "$Xtest" ] || word_is_in "$Xtest" "yes no" '

    # Customwestonini : --westonini
    {
        if [ -n "$Customwestonini" ] && [ ! -f "$Customwestonini" ] ; then
            warning_ttm "|Custom weston.ini (option --westonini) not found.
                         |  $Customwestonini"
            #
            check_fallback
            Customwestonini=""
        fi
    }
    POST_CONDITION Customwestonini '[ -z "$Customwestonini" ] || [ -f "$Customwestonini" ]'

    # Xcontainer_option : --xc
    {
        case "$Xcontainer_option" in
            yes|no|auto|force) ;;
            docker|podman|nerdctl) ;;
            *)
                note_ttm "|Option --xc: Unknown argument '$Xcontainer_option'.
                          |  Fallback: Setting --xc=auto."
                #
                check_fallback
                Xcontainer_option="auto"
                ;;
        esac
    }
    POST_CONDITION Xcontainer_option \
                   'word_is_in "$Xcontainer_option" "yes no auto force   docker podman nerdctl" '

    return 0
} # end check_options_arguments


# Function: check_options_interferences
#
# Brief: check multiple option interferences, change settings if needed
#
check_options_interferences() {
    local Message

    if case_match "$Dockervm" 'desktop' ; then

        # Sharepipewire  : --pipewire,
        # Pulseaudiomode : --pulseaudio,
        # Sharealsa      : --alsa
        # 
        {
            if [ "$Pulseaudiomode" = "auto" ] ; then
                Pulseaudiomode="tcp"
            fi

            if    [ "$Sharepipewire"  = "yes"              ] \
               || [ "$Sharealsa"      = "yes"              ] \
               || case_match "$Pulseaudiomode" "socket|host" ;
            then
                note_ttm "|With Docker Desktop VM,
                          |    Options --pipewire and --alsa do not work.
                          |    Pulseaudio works only in tcp mode.
                          |  Fallback: Setting   --pulseaudio=tcp
                          |            Disabling --alsa and --pipewire
                          |"
                #
                check_fallback
                Pulseaudiomode="tcp"
                Sharealsa="no"
                Sharepipewire="no"
            fi
        }

        # Sharecupsmode : --printer
        {
            if   [ "$Sharecupsmode" = "auto"   ] ; then
                Sharecupsmode="tcp"

            elif [ "$Sharecupsmode" = "socket" ] ; then
                note_ttm "|With Docker Desktop VM,
                          |    Option --printer=socket does not work.
                          |    Only   --printer=tcp works.
                          |  Fallback: Setting --printer=tcp"
                #
                check_fallback
                Sharecupsmode="tcp"
            fi
        }

        # Sharegpu : --gpu
        {
            case "$Sharegpu" in
                no|iglx) ;;
                *)
                    note_ttm "|With Docker Desktop VM,
                              |    Option --gpu=$Sharegpu does not work.
                              |    Only   --gpu=iglx would work with --xorg.
                              |  Fallback: Disabling option --gpu"
                    check_fallback
                    Sharegpu="no"
                    ;;
            esac
        }
    fi # case_match Dockervm desktop

    # Runtime : --runtime
    # Affects: g_Network Sharealsa Sharewebcam
    #
    if case_match "$Runtime" 'kata-runtime' ; then
        if [ "$g_Network" = "host" ] ; then        # g_Network_host
            #
            note_ttm "|With --runtime=kata-runtime,
                      |    Option --network=host (sharing host network stack)
                      |    does not work.
                      |  Fallback: Allowing default kata --network."
            #
            check_fallback
            g_Network=""
        fi
        #
        {
            # --runtime=kata-runtime is not compatible with --alsa
            if ! check_optionset "--runtime=kata-runtime" "--alsa" ; then
                Sharealsa="no"
            fi

            # --runtime=kata-runtime is not compatible with --webcam
            if ! check_optionset "--runtime=kata-runtime" "--webcam" ; then
                Sharewebcam="no"
            fi
        }
    fi

    # Xauthentication : --xauth
    # depends-on: Xserver : --tty|--weston|--kwin|--hostwayland | --hostdisplay
    #
    if [ "$Xauthentication" != "no" ] ; then
        #
        if   case_match "$Xserver" '--tty|--weston|--kwin|--hostwayland' ; then
            # These do not support xauth. Override silently.
            Xauthentication="no"
            #
        elif case_match "$Xserver" '--hostdisplay'                       ; then
            #
            if ! xtool --check "xauth" ; then
                note_ttm "|Option --hostdisplay --xauth=$Xauthentication:
                          |  Command xauth not found. Accessing host display might fail.
                          |  Fallback: Setting --xauth=no.
                          |  $Wikipackagesimage"
                #
                Xauthentication="no"
            fi
            #
        fi
        #
    fi

    # Xtest : --xtest
    # depends-on: "$Xserver" '--xpra*|--xvfb'
    #
    if case_match "$Xserver" '--xpra*|--xvfb' && [ -z "$Xtest" ]; then
        note "Option $Xserver: Enabling option --xtest to allow xpra access."
        Xtest="yes"
    fi

    # Hostmitshm : Whether host X server has MIT-SHM enabled.
    #
    if [ -z "$Winsubsystem" ] ; then
        #
        # Q: If we test the host X server, why are running xdpyinfo
        #    using xtool, which prefers to run it in the X container?
        #
        if xtool --nocheck "env LD_PRELOAD= xdpyinfo 2>>$Xinitlogfile | grep -q MIT-SHM" ;
        then Hostmitshm="yes"
        else Hostmitshm="no"
        fi
        #
        if ! xtool --check --quiet xdpyinfo ; then
            Hostmitshm="yes" # if unknown, assume yes
        fi
    fi

    # Shareclipboard : --clipboard
    if [ "$Shareclipboard" != 'no' ] ; then
        if [ -z "$Hostdisplay$Hostwaylandsocket" ] ; then
            note_ttm "|Option --clipboard: Did not find a host X display
                      |  or Wayland server to share the clipboard with.
                      |  DISPLAY and WAYLAND_DISPLAY are empty.
                      |  Fallback: Disabling option --clipboard."
            #
            check_fallback
            Shareclipboard="no"
        fi
    fi
    if [ "$Shareclipboard" = "cmv" ] ; then
        if ! xtool --check xbindkeys ; then
            note_ttm "|Option --clipboard=$Shareclipboard needs missing tool xbindkeys.
                      |  Fallback: Setting --clipboard=c2h."
            #
            check_fallback
            Shareclipboard="c2h"
        fi
        if [ "$Xtest" = "yes" ] ; then
            warning_ttm \
                "|Options --xtest --clipboard=$Shareclipboard:
                 |  X extension XTEST is enabled that allows container applications
                 |  to fake key presses like [CTRL] + [META] + [v] so they could fool x11docker
                 |  to provide the host clipboard content without user interaction."
            #
        fi
    fi
    if case_match "$Shareclipboard" 'c2h|h2c|cmv' ; then
        case "$Xserver" in
            --hostdisplay|--hostwayland|--xwin|--runx)
                note_ttm "|Option --clipboard: Option $Xserver only supports arguments yes|no.
                          |  Fallback: Disabling option --clipboard"
                #
                check_fallback
                Shareclipboard="no"
                ;;
        esac
    fi
    if [ "$Shareclipboard" = "yes" ] ; then
        case "$Xserver" in
            --xpra*|--nxagent)
                if [ "$Setupwayland" = "no" ] ; then
                    Shareclipboard="native-$Shareclipboard"
                    # Shareclipboard="native-yes"
                fi
                ;;
        esac
    fi

    if case_match "$Shareclipboard" 'yes|c2h|h2c|cmv' ; then
        if case_match "$Xserver" '--tty|--hostwayland' ; then
            note_ttm "|Option --clipboard is not supported for $Xserver.
                      |  Clipboard should be handled already by host Wayland compositor.
                      |  Fallback: Disabling option --clipboard."
            #
            check_fallback
            Shareclipboard="no"
        else
            if ! xtool --check xclip ; then
                note_ttm "|Option --clipboard with $Xserver needs xclip.
                          |  Fallback: Disabling option --clipboard."
                #
                check_fallback
                Shareclipboard="no"
            fi
            #
            if case_match "$Xserver" '--weston|--kwin|--weston-xwayland|--hostwayland' \
            && [ "$Setupwayland" = "yes" ]                                             \
            &&  ! xtool --check wl-copy                                                ;
            then
                note_ttm "|Option --clipboard with $Xserver needs wl-copy and wl-paste.
                          |  Fallback: Disabling option --clipboard.
                          |  $Wikipackagesimage"
                #
                check_fallback
                Shareclipboard="no"
            fi
        fi
    fi

    # X server
    case "$Xserver" in

        --xorg) 
            # check if --xorg can be started by an unprivileged user
            if [ -e "/etc/X11/Xwrapper.config" ]                                               \
                   && sed 's/ //g' /etc/X11/Xwrapper.config | grep -xq "allowed_users=anybody" \
                   && sed 's/ //g' /etc/X11/Xwrapper.config | grep -xq "needs_root_rights=yes" ;
            then Xlegacywrapper="yes"
            else Xlegacywrapper="no"
            fi
            
            # xrandr: --scale --size --rotate
            if ! xtool --check xrandr ; then
                if  [ -n "$Scaling"    ] \
                ||  [ -n "$Rotation"   ] \
                ||  [ -n "$Screensize" ] ;
                then
                    note_ttm "|Option --xorg needs 'xrandr' for several options.
                              |  Fallback: Disabling options --size, --scale and --rotate."
                    #
                    check_fallback
                    Screensize=""
                    Rotation=""
                    Scaling=""
                fi
            fi
            ;;

        --tty)
            if [ "$g_Interactive" = "no" ]    ; then
                if tput lines >/dev/null 2>&1 ; then
                    store_runoption_env "LINES=$(tput lines)"
                    store_runoption_env "COLUMNS=$(tput cols)"
                fi
            fi
            check_optionset "--tty" "$(trim_to_bar \
                                     "|--border --clipboard --composite
                                      | --desktop --display --dpi
                                      | --fullscreen --keymap --output-count
                                      | --rotate --scale --size --vt --wm --westonini
                                      | --xauth --xc --xeyes --xlogo --xfishtank
                                      | --xhost --xonly --xoverip --xtest"
                                      )" || :
            ;;

        --hostdisplay)

            {
                check_optionset "$Xserver" "--xtest --composite"
                Xtest=""
                Xcomposite=""
            }

            if  [ "$Runsoverssh" = "yes" ] &&  ### FIXME
                [ "$g_Network" != "host" ]  ; # g_Network_host
            then
                error_ttm \
                    "|For SSH connection with option --hostdisplay
                     |  x11docker would need insecure option --network=host.
                     |  It is recommended to use another X server option
                     |  like --xpra, --xephyr or --nxagent."
                #
            fi

            # MIT-SHM
            if [ "$Hostmitshm" = "yes"  ] \
            && [ "$Shareipc"  != "host" ] \
            && [ "$Xoverip"    = "no"   ] ; # Shareipc_host
            then
                #
                if [ -z "$Xlibnoshmfile" ] ; then

                    if case_match "$Sharegpu"  'yes|direct' \
                    && [ "$Xauthentication" != "trusted" ]  ;
                    then
                        note_ttm \
                            "|Option --hostdisplay --gpu=direct
                             |  (option --xc) would require insecure option --ipc=host to avoid MIT-SHM
                             |  errors. (If you don't care for MIT-SHM errors, use --xauth=trusted.)
                             |  Possible solutions:
                             |   - Use option --xc to use image x11docker/xserver
                             |   - Provide XlibNoSHM.so in ~/.local/share/x11docker
                             |     or in /usr/local/share/x11docker.
                             |     (Either Download it from x11docker repo,
                             |     or run with --xc once, it will be stored.)
                             |  Fallback: Disabling option --gpu."
                        #
                        check_fallback
                        Sharegpu="no"
                        #
                    elif case_match "$Sharegpu" 'no'  \
                    &&  [ "$Xauthentication" =  yes ] ;
                    then
                        note_ttm \
                            "|Option --hostdisplay: To avoid MIT-SHM errors,
                             |  x11docker sets uncomfortable option --xauth=untrusted to limit X access.
                             |  Some applications might misbehave or crash.
                             |  Possible solutions:
                             |   - Use option --xc to use image x11docker/xserver.
                             |   - Provide XlibNoSHM.so in ~/.local/share/x11docker.
                             |     (Either Download it from x11docker repo,
                             |     or run with --xc once, it will be stored.)
                             |   - If you don't care about MIT-SHM errors, set --xauth=trusted.
                             |   - Use another X server option like --nxagent."
                        #
                        Xauthentication="untrusted"
                        #
                    fi
                    #
                    if case_match "$Xauthentication" 'trusted|yes' ; then
                        note "Option --hostdisplay --xauth=trusted: MIT-SHM errors might occur."
                        store_runoption_env "QT_X11_NO_MITSHM=1"
                        store_runoption_env "_X11_NO_MITSHM=1"
                        store_runoption_env "_MITSHM=0"
                    fi
                    #
                else # [ -n "$Xlibnoshmfile" ]
                    if case_match $g_BackendKind 'docker|host' ; then # BackendKind_host
                        if [ -f "$Libdlsofile" ] ; then
                            # Ignore the directory, assume there is a copy
                            # in Sharefoldercontainer.
                            store_runoption_env "$(trim_to_mark \
                                                 "|LD_PRELOAD
                                                  :=$Sharefoldercontainer/$(basename "$Libdlsofile")
                                                  ::$Sharefoldercontainer/XlibNoSHM.so"
                                                  )"
                        else
                            store_runoption_env "LD_PRELOAD=$Sharefoldercontainer/XlibNoSHM.so"
                        fi
                    elif case_match $g_BackendKind 'podman' ; then
                        note_ttm "|Option --hostdisplay: Cannot set LD_PRELOAD with
                                  |  --backend=podman to avoid MIT-SHM issues.
                                  |  Graphical glitches might occur.
                                  |  Rather use another X server option."
                    fi
                fi # "$Xlibnoshmfile"
            fi # MIT-SHM
            ;; #  --hostdisplay
    esac # case "$Xserver"

    # Newxvt : --vt
    if [ -n "$Newxvt" ] ; then

        if case_match "$Xserver" '--weston|--weston-xwayland' \
        && [ -n "$Hostdisplay" ]                              ;
        then
            error_ttm \
                "|Option $Xserver: Opening a TTY for weston on console
                 |  while still running on X would break TTY switching.
                 |  Please run nested without option --vt or switch to console first."
            #
        fi

        if [ "$Xcontainer_option" =  yes ] ; then

            if case_match "$Xserver" '--weston' ; then
                note_ttm \
                    "|Option $Xserver: TTY switching will not work
                     |  with weston on console running in a container (option --xc).
                     |  Alternative: Run with --xc=no using weston from host."
                #
            fi

            if case_match "$Xserver" '--weston*|--xorg' ; then

                if [ "$Xcforce" =  yes ] ; then
                    warning_ttm \
                        "|Option --xc=force passes by this issue:
                         |  Options $Xserver --xc: Running weston or Xorg
                         |  with option --xc on console can result in not being able to get back
                         |  to console after terminating or to switch to other ttys.
                         |  This is likely caused by proprietary NVIDIA drivers.
                         |  Consider to use free and open source nouveau driver instead.
                         |  Rather use $Xserver with option '--xc=no'."
                    #
                elif [ -n "$Nvidiaversion" ] ; then
                    error_ttm \
                        "|Options $Xserver --xc: Running weston or Xorg
                         |  with option --xc on console can result in not being able to get back
                         |  to console after terminating or to switch to other ttys.
                         |  This is likely caused by proprietary NVIDIA drivers.
                         |  Consider to use free and open source nouveau driver instead.
                         |  Rather use $Xserver with option '--xc=no'.
                         |  You can force to run with option --xc with option '--xc=force'."
                    #
                fi
            fi
        fi # Xcontainer_option

    fi # Newxvt

    # window manager: Windowmanagermode Windowmanagercommand
    {
        if [ "$Desktopmode" = "no"   ] \
        && [ -z "$Windowmanagermode" ] ;
        then

            if [ "$Xserver" = '--weston-xwayland' ] ;
            then Xwaylandrootless="yes"
            fi

            if [ "$Xwaylandrootless" = "no" ] \
             && case_match "$Xserver" '--xephyr|--weston-xwayland|--kwin-xwayland|--xorg|--xwayland' ;
            then
                note_ttm "|Option $Xserver: x11docker assumes that you need
                          |  a window manager. If you don't want this, run with option --desktop.
                          |  Enabling option --wm to provide a window manager."
                #
                Windowmanagermode="auto"
                #
                if [ "$Autochooseserver" = "yes" ] \
                && [ "$Runsonconsole"    = "no"  ] ;
                then
                    case "$Sharegpu" in
                        no)  note_ttm "|Did not find a nice solution to run a seamless application
                                       |  on your desktop.
                                       |  (Only insecure option --hostdisplay would work).
                                       |  It is recommended to install xpra or nxagent
                                       |  to allow a seamless mode without the need of a window manager.
                                       |  $Wikipackagesimage"
                             #
                             ;;
                        yes) note_ttm "|Did not find a nice solution to run a seamless application with
                                       |  option --gpu on your desktop.
                                       |  (Only insecure option --hostdisplay would work).
                                       |  It is recommended to install xpra, weston, Xwayland and xdotool
                                       |  to allow a seamless mode without the need of a window manager.
                                       |  $Wikipackagesimage"
                             #
                             ;;
                    esac
                fi
            fi

        fi

        if [ -n "$Windowmanagercommand"   ] \
        && [ "$Xcontainer_option" = "yes" ] ;
        then
            note_ttm "|Option --wm=$Windowmanagercommand: With option --xc
                      |  only OpenBox is provided as window manager.
                      |  Fallback: Setting --wm=auto"
            #
            check_fallback
            Windowmanagermode="auto"
            Windowmanagercommand=""
        fi
    } # window manager

    # Checkforopenwindow : --checkwindow
    if [ -n "$Checkforopenwindow" ] \
    && ! xtool --check xwininfo     ;
    then
        note_ttm "|Option --checkwindow needs 'xwininfo'.
                  |  Fallback: Disabling option --checkwindow."
        #
        check_fallback
        Checkforopenwindow=""
    fi

    # Sharegpu : --gpu
    {
        # Xoverip : --xoverip
        if [ "$Xoverip" = 'socat' ] ; then
            store_runoption_env "LIBGL_ALWAYS_SOFTWARE=1"
            if case_match "$Sharegpu" 'yes|direct|iglx' ; then
                note_ttm "|Option --gpu=$Sharegpu is not possible with --xoverip=socat.
                          |  Fallback: Setting option --gpu=no"
                #
                check_fallback
                Sharegpu="no"
            fi
        fi

        # --gpu
        if case_match "$Xoverip" 'yes|listentcp' ; then
            case "$Sharegpu" in
                virgl|iglx) ;;
                yes)
                    note_ttm "|Option --gpu=$Sharegpu with X over IP.
                              | Enabling indirect rendering with --gpu=iglx"
                    Sharegpu="iglx"
                    ;;
                direct)
                    note_ttm "|Option --gpu=$Sharegpu with --xoverip is not supported.
                              |  Try --gpu=iglx instead.
                              |  Fallback: Disabling option --gpu."
                    #
                    check_fallback
                    Sharegpu="no"
                    ;;
            esac
        fi

        if case_match "$Sharegpu" 'yes' ; then
            case "$Xserver" in
                --weston|--kwin|--hostwayland)
                    Sharegpu="direct"
                    ;;
                --xorg|*xwayland|--satellite|--hostdisplay)
                    Sharegpu="direct"
                    ;;
                --xwin|--runx)
                    Sharegpu="iglx"
                    ;;
                --tty)
                    Sharegpu="direct"
                    ;;
                *)
                    note_ttm "|Option --gpu=direct is not supported by $Xserver.
                              |  Options supporting direct rendering:
                              |  --xpra-xwayland, --weston-xwayland, --xwayland, --xorg, --hostdisplay
                              |  Fallback: Disabling option --gpu"
                    #
                    check_fallback
                    Sharegpu="no"
                    ;;
            esac
        fi

        case "$Sharegpu" in
            iglx)
                store_runoption_env "LIBGL_ALWAYS_INDIRECT=1"
                ;;
            virgl)
                case "$Xcontainer_option" in
                    yes)
                        case "$g_BackendKind" in
                            docker|podman|nerdctl)
                                store_runoption_env "LIBGL_ALWAYS_SOFTWARE=1"   ### FIXME rather belongs to setup_gpu()
                                store_runoption_env "GALLIUM_DRIVER=virpipe"
                                ;;
                            *)  # proot|host # BackendKind_host
                                note_ttm "|Option --gpu=virgl is supported with
                                          |  backends docker|podman|nerdctl only.
                                          |  Fallback: Disabling option --gpu=virgl."
                                #
                                check_fallback
                                Sharegpu="no"
                                ;;
                        esac
                        ;;
                    no)
                        note_ttm "|Option --gpu=virgl needs image x11docker/xserver (option --xc).
                                  |  Fallback: Disabling option --gpu=virgl."
                        #
                        check_fallback
                        Sharegpu="no"
                        ;;
                esac
                ;;
        esac
    }

    # Containersetup : --no-setup
    if [ "$Containersetup" = 'no' ] ; then
        check_optionset "--no-setup" "--dbus --no-entrypoint --runasroot --runasuser" || :

        if [ "$Langwunsch" ] ; then store_runoption_env "LANG=$Langwunsch" ; fi

        if ! case_match "$g_Initsystem"  'none|tini|dockerinit' ; then
            note_ttm "|Option --no-setup: Option --init=$g_Initsystem is not supported.
                      |  Fallback: Setting --init=tini"
            #
            check_fallback
            g_Initsystem="tini"
        fi

        if [ -z "$g_Workdir" ] && [ "$Sharehome" != "no" ] ; then
            note_ttm "|Option --no-setup: You might need to specify
                      |  e.g. '--workdir=/tmp' or '--env HOME=/tmp' to allow proper functionality."
            #
        fi

        if [ -n "$Sudouser" ] && [ "$g_Containerusername" != "root" ] ; then
            note_ttm "|Option --no-setup does not support option --sudouser.
                      |  Fallback: Enabling needed container capabilities to allow sudo
                      |  just in case the container user is set up for su and/or sudo.
                      |  Consider to use --user=root."
            #
        fi

        ### FIXME check support of further options
        # --stdin?
        # --hostdbus

        Dbusrunsession="no"
        g_Noentrypoint="no"
        Runasroot=""
        Runasuser=""
    fi # Containersetup = no

    # Capdropall : --cap-default
    # Allownewprivileges :  --newprivileges
    if [ "$Capdropall" = "no" ]            \
    && [ "$Allownewprivileges" =  "auto" ] ;
    then
        note_ttm "|Option --cap-default: Enabling option --newprivileges.
                  |  You can avoid this with --newprivileges=no"
        #
        Allownewprivileges="yes"
    fi

    # Xkblayout : --keymap: XKB keyboard layout
    {
        if [ -n "$Xkblayout" ] ; then

            if case_match "$Xserver" '--kwin|--kwin-xwayland'        \
            && ( [ "$Runsonconsole" = "yes" ] || [ -n "$Newxvt" ] )  \
            && ! check_optionset "$Xserver" "--keymap"               ;
            then
                note_ttm "|Option --keymap does not work with option $Xserver
                      |  if running from console.
                      |  Fallback: disabling option --keymap."
                #
                check_fallback
                Xkblayout=""
            fi

            if [ "$Xkblayout" = "clone" ]          \
            && ! case_match "$Xserver" '--nxagent' ;
            then
                note_ttm "|Option --keymap=clone is supported with --nxagent only.
                      |  Fallback: Disabling option --keymap."
                #
                check_fallback
                Xkblayout=""
            fi
        fi
    }

    # Rotation : --rotate
    {
        if [ "$Rotation" = "0" ] ; then  Rotation="normal" ; fi
        case "$Xserver" in
            --weston*)
                # recoding_Rotation for --weston* (to WestonRotation)
                # This changes the set of allowed values.
                case "$Rotation" in
                    90)          Rotation="rotate-270" ;;
                    180)         Rotation="rotate-180" ;;
                    270)         Rotation="rotate-90" ;;
                    flipped-90)  Rotation="flipped-rotate-270" ;;
                    flipped-180) Rotation="flipped-rotate-180" ;;
                    flipped-270) Rotation="flipped-rotate-90" ;;
                esac
                ;;
        esac
    }

    # Containerusershell : --shell
    # using: Containersetup : --no-setup
    if ! case_match "$Containerusershell" 'auto' ; then
        store_runoption_env "SHELL=$Containerusershell"
        if [ "$Containersetup" = "no" ] ; then
            note_ttm "|Option --shell: With option --no-setup
                      |  x11docker only sets variable SHELL, but does no setup in /etc/passwd.
                      |  Some terminal emulators might not work as expected."
            #
        fi
    fi

    # Outputcount : --output-count
    if [ "$Outputcount" != "1" ] && [ "$Runsonconsole" = "yes" ] ; then
        note_ttm "|Option --output-count works in nested/windowed mode only,
                  |  but not on console. Fallback: disabling option --output-count."
        #
        check_fallback
        Outputcount="1"
    fi

    # Xeyes : --xeyes
    if [ -n "$Xeyes" ] ; then
        if ! xtool --check xeyes ; then
            note_ttm "|Option --xeyes : could not find xeyes.
                      |  Disabling option --xeyes."
            #
            Xeyes=""
        fi
        case "$Xserver" in
            --weston|--kwin|--hostwayland|--tty)
                note_ttm "|Option --xeyes does not run on $Xserver.
                          |  Fallback: Disabling option --xeyes."
                #
                check_fallback
                Xeyes=""
                ;;
        esac
    fi

    # Xlogo : --xlogo
    if [ -n "$Xlogo" ] ; then
        if ! xtool --check xlogo ; then
            note_ttm "|Option --xlogo : coudl not find xlogo.
                      |  Disabling option --xlogo."
            #
            Xlogo=""
        fi
        case "$Xserver" in
            --weston|--kwin|--hostwayland|--tty)
                note_ttm "|Option --xlogo does not run on $Xserver.
                          |  Fallback: Disabling option --xlogo."
                #
                check_fallback
                Xlogo=""
                ;;
        esac
    fi

    # Xfishtank : --xfishtank
    if [ "$Xfishtank" = "yes" ] ; then
        if xtool --check xfishtank ; then
            case "$Xserver" in
            --xpra*|--nxagent)
                if [ "$Desktopmode" = "no" ] ; then
                    Windowmanagermode="${Windowmanagermode:-auto}"
                else
                    Desktopmode="yes"
                fi
                ;;
            esac
        else
            : # NOP. We did not find xfishtank for --xfishtank, but
              # keep silent.
        fi
    fi

    # MSYS2, Cygwin, WSL
    if [ "$Winsubsystem" = WSL2 ] ; then
        note_ttm "|WSL2 support is experimental and barely tested yet.
                  |  Feedback and bug reports are appreciated!"
    fi

    if [ "$Dockervm" =  moby ] ; then

        case "$Winsubsystem" in
            WSL1|WSL2)
                if grep -q "/c/" <<< "$Cachebasefolder" && [ -z "$Hosthomebasefolder" ] ; then
                    note_ttm "|With MobyVM and WSL x11docker stores its cache files on drive C:
                              |  to allow cache file sharing.
                              |  Your Docker setup might not allow to share files from drive C:.
                              |  If startup fails with an 'access denied' error,
                              |  please either allow access to drive C: or specify a custom folder for
                              |  cache storage with option '--cachebasedir D:/some/cache/folder'.
                              |  Same issue can occur with option '--home'.
                              |  Use option '--homebasedir D:/some/home/folder' in that case.
                              |  Option --preset can help to reduce typing for each command."
                    #
                fi
                ;;
        esac

        if [ "$g_Initsystem" = "systemd" ] ; then
            note_ttm "|Option --init=systemd is not supported with MobyVM.
                      |  You can try another init option instead, e.g. --init=openrc.
                      |  Fallback: Disabling option --init=systemd"
            #
            check_fallback
            g_Initsystem="tini"
        fi

        if [ "$Sharecgroup" = "yes" ] ; then
            note_ttm "|Option --sharecgroup is not supported with MobyVM.
                      |  Fallback: Disabling option --sharecgroup."
            #
            check_fallback
            Sharecgroup="no"
        fi

    fi

    # Pulseaudiomode : --pulseaudio
    # Sharecupsmode : --printer
    # Sharewebcam : --webcam
    if case_match "$Winsubsystem"  'MSYS2 | CYGWIN | WSL1 | WSL2' ; then
        check_optionset "Windows" "--pulseaudio --printer --webcam" || :
        Sharecupsmode=""
        Pulseaudiomode=""
        Sharewebcam="no"
    fi

    # Setupwayland : --wayland
    if [ "$Setupwayland" = "yes" ] ; then Dbusrunsession="yes" ; fi

    # g_Initsystem : --init
    if case_match "$g_Initsystem" 'systemd|sysvinit|openrc|runit' ; then Dbussystem="yes" ; fi


    # g_Interactive : --interactive
    if [ "$g_Interactive" = yes ] ; then

        if [ "$Forwardstdin" = "yes" ] ; then
            note_ttm "|Option --stdin is not compatible with option --interactive.
                      |  Fallback: Disabling option --stdin."
            #
            check_fallback
            Forwardstdin="no"
        fi

        if [ "$Runsinteractive" = "yes" ] ; then
            note_ttm "|Option -i, --interactive: Does not work in interactive
                      |  bash mode (option --enforce-i).
                      |  Fallback: Disabling option --interactive."
            #
            check_fallback
            g_Interactive="no"
        fi

        if case_match "$Winsubsystem"  'MSYS2 | CYGWIN | WSL1' ; then
            Winpty="$(command -v winpty)"
            Winpty="$(escapestring "$Winpty")"
            [ -z "$Winpty" ] && \
                error_ttm "|Option --interactive on MS Windows needs 'winpty'
                           |  to run x11docker in interactive mode. MSYS2 provides winpty as a package.
                           |  On Cygwin it can be compiled from source. WSL1 isn't supported yet.
                           |  WSL2 might work, but is not tested yet."
            #
        fi
    fi

    if [ "$g_Interactive" = "yes" ] ; then Showcontaineroutput="no" ; fi

    return 0
} # end check_options_interferences

# Function: check_options_messages
#
# Brief: Some messages depending on options, but not changing settings
#
#
# Exception: under
#            [ "$Xserver" = '--nxagent' ]
#         && [ "$Hostsystem" = "mageia" ]
#         && [ "$Desktopmode" = "no" ]
#         && [ "$Autochooseserver" = "yes" ]
#
#   the value of Desktopmode and Windowmanagermode ae modified.
#
check_options_messages() {

    # X server specific messages
    case "$Xserver" in # Xserver_case_1
        --hostdisplay)

            if [ "$Autochooseserver" = "yes" ] \
            && [ -z "$Winsubsystem"          ] ;
            then
                note_ttm  "|Option --hostdisplay: To allow protection against
                           |  X security leaks, please install 'xinit' and one or more of:
                           |    xpra, Xephyr, nxagent, weston+Xwayland,
                           |  or run a second Xorg server with option --xorg.
                           |  $Wikipackagesimage"
                #
            fi

            # --xauth
            if ! case_match "$Xauthentication" 'untrusted' ; then
                warning_ttm \
                    "|Option --hostdisplay provides QUITE BAD container isolation!
                     |  Abuse of X11 protocol for keylogging and remote host control is possible.
                     |  It is recommended to use another X server option like --nxagent or --xpra.
                     |  You can mitigate the issue with option --xauth=untrusted."
                #
            fi

            # --checkwindow
            if [ "$Checkforopenwindow" = "yes" ] ; then
                note_ttm "|Option --checkwindow along with --hostdisplay
                          |  should only be used with a keyword as a check argument.
                          |  Otherwise the container is likely to run forever."
                #
            fi
            ;; # Xserver --hostdisplay

        --xorg)
            if [ "$Xcontainer_option" = "yes" ] ; then
                note_ttm "|Options --xorg --xc: Running Xorg in container is experimental
                          |  and might misbehave, fail or crash.
                          |  Please report issues at https://github.com/mviereck/x11docker"
                #
            fi

            if [ "$Hostsystem" = "opensuse" ] \
            && [ "$Runsonconsole" = "no"    ] \
            && [ "$Startuser" != "root"     ] ;
            then
                warning_ttm "|Option --xorg: openSUSE does not support starting
                             |  a second Xorg server from within X. Possible solutions:
                             |  1.) Install nested X server 'Xephyr', 'nxagent' or 'Xnest',
                             |      or for --gpu support: install 'Weston' and 'Xwayland'.
                             |  2.) Switch to console tty1...tty6 with <CTRL><ALT><F1>...<F6>
                             |      and start x11docker there.
                             |  3.) Run x11docker as root."
                #
            fi

            case "$Xlegacywrapper" in
                yes)
                    warning_ttm "|Option --xorg: Although x11docker starts Xorg as
                                 |  unprivileged user, most system setups wrap Xorg to give it root
                                 |  permissions (setuid). Evil containers may try to abuse this.
                                 |  Other x11docker X server options like --xephyr are more secure at this point."
                    #
                    ;; # Xlegacywrapper yes
                no)
                    if [ "$Startuser" = "root" ] ; then
                        warning "Option --xorg: x11docker will run Xorg as root."
                    else
                        if [ "$Xcontainer_option" = "no" ] && [ "$Runsonconsole" = "no" ] && [ -z "$Newxvt" ] ; then
                            warning_ttm \
                                "|Option --xorg: Your configuration seems not to allow
                                 |  to start a second core Xorg server from within X. Option --xorg may fail.
                                 |  (Per default, only root or console users are allowed to run an Xorg server).
                                 |
                                 |  Possible solutions:
                                 |  1.) Install one of nested X servers 'Xephyr', 'Xnest' or 'nxagent'.
                                 |      For --gpu support: install 'weston' and 'Xwayland'.
                                 |  2.) Switch to console tty1...tty6 with <CTRL><ALT><F1>...<F6>
                                 |      and start x11docker there.
                                 |  3.) Run x11docker as root.
                                 |  4.) Edit file '/etc/X11/Xwrapper.config' and replace line:
                                 |          allowed_users=console
                                 |      with lines
                                 |          allowed_users=anybody
                                 |          needs_root_rights=yes
                                 |      If the file does not exist already, you can create it.
                                 |      On Debian and Ubuntu you need package xserver-xorg-legacy.
                                 |
                                 |   Be aware that switching directly between Xorg servers can crash them.
                                 |   Always switch to a black console first before switching to Xorg."
                            #
                        fi
                    fi
                    ;; # Xlegacywrapper no
            esac

            if [ "$Runsoverssh" = "yes" ] ; then
                note "|Option --xorg: x11docker can run Xorg,
                  |  but you won't see it in an 'ssh -X' session.
                  |  Rather install e.g. Xephyr on ssh server and use option --xephyr."
                #
            fi

            # --gpu=iglx
            if [ "$Sharegpu" = "iglx"        ] \
            && [ "$Xcontainer_option" = "no" ] \
            && [ -e "/var/log/Xorg.0.log"    ] ;
            then
                # Xorgversion :
                #   grep yields something like:
                #   [    40.001] xorg-server 2:21.1.12-1ubuntu1.5 (For technical support[...]
                #                              ^^^^^^^^^^^^^^^^^^
                #
                #   cuts get the underlined part (between teh first colon and the following space)
                #
                Xorgversion="$(grep -m1 xorg-server </var/log/Xorg.0.log | cut -d: -f2 | cut -d' ' -f1)"
                #
                if [ -z "$Nvidiaversion" ]                   \
                && [ -n "$Xorgversion"   ]                   \
                && version_less_than "$Xorgversion" "1.20.8" ;
                then
                    note_ttm "|Options --xorg --gpu=iglx: 
                              |  It seems you have Xorg v$Xorgversion. iGLX is known to have a bug
                              |  in Xorg<v1.20.8. --gpu=iglx may fail and give black content."
                    #
                fi
            fi
            ;; # Xserver --xorg

        --xpra*)
            if [ "$Sharegpu" = "yes" ] ; then
                note_ttm "|Option $Xserver: If performance of GPU acceleration
                          |  is not satisfying, you can try insecure '--hostdisplay --gpu'
                          |  or, better but windowed, '--weston-xwayland --gpu'."
                #
            fi
            note_ttm "|Option $Xserver: If you encounter issues with xpra,
                      |  you can try --nxagent instead.
                      |  Rather use xpra from www.xpra.org than from distribution repositories."
            #
            ;; # Xserver --xpra*

        --kwin)
            if [ "$Newxvt" ] ; then
                note "Option --kwin: Switching console with STRG+ALT+Fn fails."
            fi
            ;; # Xserver --kwin

        --nxagent)
            if [ "$Hostsystem" = "mageia" ] ; then
                #
                # https://www.mageia.org/en/about/
                #
                if [ "$Desktopmode" = "no"       ] \
                && [ "$Autochooseserver" = "yes" ] ;
                then
                    Desktopmode="yes"
                    Windowmanagermode="${Windowmanagermode:-auto}"
                fi

                if [ "$Desktopmode" = "no" ] ; then
                    #
                    # Note: on Ubuntu 24.04,
                    #
                    # the path would be /usr/bin/nxagent or
                    # /usr/lib/x86_64-linux-gnu/nx/bin/nxagent
                    #
                    # and the result: "NXAGENT - Version 3.5.99.27" twice.
                    #
                    warning_ttm "|Option --nxagent: nxagent version 3.5.0 on Mageia 6
                                 |  is known to crash in seamless mode. 
                                 |  (Detected version:
                                 : '$(strings --bytes 20 /usr/libexec/nx/nxagent | grep "NXAGENT - Version")').
                                 |  If you encounter issues, please try seamless --xpra (secure),
                                 |  --hostdisplay (insecure), or run --nxagent in desktop mode with a
                                 |  host window manager (--wm=WINDOWMANAGER or --wm=auto or short -wm)."
                    #
                fi
            fi # mageia

            if [ "$Xauthentication" != '-ac' ] ; then
                warning_ttm "|Option --nxagent: X server nxagent is set up
                             |  with X option -ac that disables X access control entirely because it has
                             |  issues with X authentication cookie setup. Access to nxagent from
                             |  different networks and arbitrary users might be possible."
                #
            fi

            note_ttm "|Option --nxagent: A few applications do not work well
                      |  with --nxagent. In that case, you can try to fix the issue with
                      |  option --composite or try another X server option
                      |  like --xpra (seamless) or --xephyr (windowed)."
            #

            if [ "$Xcomposite" = "yes" ] ; then
                note_ttm "|Option --nxagent: nxagent can have issues with option
                          |  --composite. Maybe rather try --xephyr (windowed) or --xpra (seamless)."
                #
            fi
            ;; # Xserver --nxagent

        --xwayland|--weston-xwayland)

            if [ ! -e "/usr/lib/x86_64-linux-gnu/libdecor/plugins-1/libdecor-cairo.so" ] \
            && [ ! -e "/lib/x86_64-linux-gnu/libdecor/plugins-1/libdecor-cairo.so"     ] \
            && [ "$Xcontainer_option" = "no" ]                                           ;
            then
                note_ttm "|Option $Xserver: You might need to install
                          |  libdecor cairo plugin for Xwayland window decoration.
                          |  $Wikipackages"
                #
            fi
            ;; # Xserver --xwayland|--weston-xwayland

        --xwin|--runx) 
            note_ttm "|Windows firewall settings can forbid application access
                      |  to the X server. If no application window appears, but no obvious error
                      |  is shown, please check your firewall settings. Compare issue #108 on github."
            #
            ;; # Xserver --xwin|--runx

    esac # Xserver_case_1

    if case_match "$Xserver" '--weston|--kwin|--hostwayland' ; then
        note_ttm "|Option $Xserver: You are running a pure Wayland
                  |  environment. X applications without Wayland support will fail."
        #
    fi

    if [ "$Xserver" = "--kwin" ] ; then
        note_ttm "|Option --kwin: kwin_wayland does not support the xdg_shell
                  |  interface in all versions. Some GTK3 Wayland applications depend on it.
                  |  If application startup fails, try --weston instead."
        #
    fi
    
    if case_match "$Xserver" '--weston|--weston-xwayland' ; then
        if [ "$Runsonconsole" = "yes" ] || [ -n "$Newxvt" ] ; then
            note_ttm "|Option --$Xserver: Running Weston on console
                      |  is experimental and might fail.
                      |  Please report issues at https://github.com/mviereck/x11docker"
            #
        fi
        if [ "$Sharegpu" = "no" ] ; then
            note "Option $Xserver: You might need option --gpu."
        fi
    fi

    # NVIDIA without --gpu
    if [ -n "$Nvidiaversion" ]                       \
    && [ "$Sharegpu" = "no"  ]                       \
    &&  case_match "$Xserver" '--hostdisplay|--xorg' ;
    then
        note_ttm "|Option $Xserver may fail with proprietary NVIDIA driver
                  |  on host without enabling option --gpu.
                  |  In that case try other X server options like --nxagent, --xpra or --xephyr."
        #
    fi

    # --cap-default
    [ "$Capdropall" = "no" ] && \
        warning_ttm "|Option --cap-default disables security hardening
                     |  for containers done by x11docker. Default docker capabilities are allowed.
                     |  This is considered to be less secure."
    #

    # --clipboard

    # --clipboard=cmv
    if case_match "$Shareclipboard" 'cmv' \
    && [ "$Setupwayland" = "yes" ]        \
    && [ "$Xcontainer_option" = "no" ]    ;
    then
        note_ttm "|Option --clipboard=$Shareclipboard:
                  |  Keyboard binding works only if an X window of container that has focus.
                  |  Options --xeyes or --xlogo can provide an X window for this purpose.
                  |  Alternatively provide image x11docker/xserver (option --xc)
                  |  that contains a bindkey helper for Wayland."
        #
    fi

    if ! case_match "$Shareclipboard"  'native* | no' ; then
        #
        if [ "$Setupwayland" = "yes" ] \
        || [ -n "$Hostwaylandsocket" ] ;
        then
            note_ttm "|Option --clipboard:
                      |  Wayland windows might show undesired flickering due to
                      |  focus switches for clipboard checks with wl-clipboard."
            #
        fi
        #
        note_ttm "|Option --clipboard: For X11 options --xpra* and --nagent
                  |  provide the best clipboard support. (Supported args: yes|c2h|h2c)."
        #
    fi

    if [ "$Shareclipboard" != "yes" ] ; then
        #
        if [ "$Xserver" = "--hostdisplay" ] ; then
            warning_ttm "|Option --hostdisplay:
                         |  The clipboard is not isolated."
            #
        fi
        #
        if [ "$Sharehostwayland" = "yes" ]  ; then
            warning_ttm "|Option --hostwayland:
                         |  The clipboard is not isolated."
            #
        fi
    fi

    # --fullscreen
    if [ "$Fullscreen" = "yes" ]                                                             \
    && ! case_match "$Xserver"                                                               \
           ' --xephyr|--weston|--weston-xwayland|--nxagent|--xpra*|--xwin  |  --xvfb|--xorg' ;
    then
        note "Option --fullscreen is not supported by option $Xserver."
    fi

    # --gpu
    {
        if [ "$Sharegpu" = iglx  ] \
               && [ -z "$Nvidiaversion" ] ;
        then
            note_ttm "|Option --gpu=iglx: iGLX is known to work only with new
                      |  MESA drivers and new X servers. Otherwise you might get black content only."
        fi

        if [ "$Sharegpu" = iglx ]           \
               && ! case_match "$Xserver" '--xorg' ;
        then
            note "Option --gpu=iglx is useful with option --xorg only."
        fi

        if case_match  "$Sharegpu" 'direct|virgl' ; then
            warning_ttm "|Option --gpu=$Sharegpu degrades container isolation.
                         |  Container gains access to GPU hardware.
                         |  This allows reading host window content (palinopsia leak)
                         |  and GPU rootkits (compare proof of concept: jellyfish).
                         |  An alternative is --gpu=iglx that works with --xorg only."
        fi
    }

    # g_Interactive : --interactive
    if [ "$g_Interactive" = "yes" ] ; then
        if case_match "$g_Initsystem" 'openrc|runit|sysvinit' ; then
            note_ttm "|Option --interactive: Interactive mode with option
                      |  --init=$g_Initsystem is not well integrated yet.
                      |  Shells do not have job control and CTRL-C can behave different than expected."
            #
        elif case_match "$g_Initsystem" 'systemd' ; then
            note "Option --interactive might fail with old systemd versions."
        fi
    fi

    # --ipc=host  # Shareipc_host
    if [ "$Shareipc" = "host" ]                            \
    && case_match "$g_BackendKind" 'docker|podman|nerdctl' ;
    then
        warning_ttm "|Option --ipc=host severely degrades
                     |  container isolation. IPC namespace remapping is disabled."
    fi

    # --limit N
    if [ "$g_Limitresources" ] ; then
        note_ttm "|Option --limit does not avoid possibly flooding the hard disk
                  |  in docker's container partition or in shared folders.
                  |  It only restricts memory and CPU usage."
    fi

    # --network
    {
        # --network and --backend
        if case_match "$g_BackendKind" 'docker|podman|nerdctl' ; then
            #
            case "$g_Network" in
                #
                none)
                    note_ttm "|Option --network=none is set to disable network access.
                              |  If you need network and internet access, set option -I, --network [=NET]."
                    ;;
                #
                ""|bridge)
                    warning_ttm "|Option --network: Container has access to
                                 |  local network and internet."
                    ;;
                #
                host)
                    warning_ttm "|Option --network=host severely degrades
                                 |  container isolation. Network namespacing is disabled.
                                 |  Container shares host network stack.
                                 |  Spying on network traffic may be possible.
                                 |  Access to host X server $Hostdisplay may be possible
                                 |  through abstract unix socket."
                    ;;
                #
                *)
                    warning_ttm "|Option --network=$g_Network: Some sort of network access
                                 |     is enabled."
                    ;;
                #
            esac
        elif case_match "$g_BackendKind" 'host | proot' ; then
            : # NOP
        fi

        # --network, --backend and Xserver
        if [ "$g_Network" !=  none ]                           \
        && case_match "$g_BackendKind" 'docker|podman|nerdctl' ;
        then
            if case_match "$Xserver" '--hostdisplay' ; then
                warning_ttm "|Option --hostdisplay with enabled internet access
                             |  allows the container to provide your host X server to the entire world."
                #
             elif ! case_match  "$Xserver" '--tty|--weston|--kwin|--hostwayland' ; then
                note_ttm "|Option -I, --network: The container is able to provide
                          |  access to X server $Newdisplay ($Xserver) to the entire world."
                #
            fi
        fi
    }

    # --output-count
    if [ "$Outputcount" != "1" ]            \
    && [ "$Xserver" = '--weston-xwayland' ] ;
    then
        note_ttm "|Option --output-count: Xwayland sometimes does not position itself well
                  |  at origin 0+0 of first virtual screen, and some screens appear to be unused.
                  |  You may need to move Xwayland manually with [META]+[LeftMouseButton].
                  |  (Bug report at https://bugzilla.redhat.com/show_bug.cgi?id=1498665 )"
        # Reported: 2017-10-04. Status: closed EOL, not fixed.
    fi

    # --runtime
    if [ "$Runtime" = 'sysbox-runc'   ] \
    && [ "$g_BackendKind" != 'docker' ] ;
    then
        note_ttm "|Option --runtime=$Runtime --backend=$g_BackendKind: $Runtime is known
                  |  to work with Docker only yet."
    fi

    # --scale
    if [ -n "$Scaling" ]                  \
    && [ "$Xserver" = '--xorg' ]          \
    && [ -n "$Rotation" ]                 \
    && [ num_compare "$Scaling"  '<' 1 ]  ;
    then
        note_ttm "|Option --xorg does not work well with combination
                  |  of --scale smaller than 1 and rotation different from 0."
    fi

    # --user=RETAIN / keep container user defined in image
    if [ "$Createcontaineruser" = no ] \
    && [ -n "$Sudouser" ]              ;
    then
        note_ttm "|Option --sudouser has limited support with --user=RETAIN.
                  |  x11docker will only set needed capabilities.
                  |  User setup and /etc/sudoers won't be touched.
                  |  Option --group-add=sudo might be useful."
    fi

    # --xoverip
    if [ "$Xoverip" !=  no ]                                               \
    && ( [ "$Xcontainer_option" != "yes" ] || [ "$g_Network" != "none" ] ) ;
    then
        warning_ttm "|Option --xoverip might allow undesired access to the X server.
                     |  At least along with image x11docker/xserver (option --xc) and 
                     |  --network=none (x11docker default) the setup is considered to be secure
                     |  because a private network is used."
        #
    fi

    #
    # Customdockeroptions : CUSTOM_RUN_OPTIONS
    #
    if [ -n "$Customdockeroptions" ] ; then
        warning_ttm "|Found custom CUSTOM_RUN_OPTIONS.
                     |  x11docker will add them to 'docker run' command without
                     |  a serious check for validity or security. Found options:
                     |  $Customdockeroptions"
        #
        if grep -q -- '--privileged'           <<< "$Customdockeroptions" ; then
            warning_ttm "|Found option --privileged
                         |  in CUSTOM_RUN_OPTIONS. That is A VERY BAD IDEA.
                         |  A privileged setup allows unrestricted access from container to host.
                         |  Malicious applications can cause arbitrary harm."
        fi
        #
        # FIXME: using '.' for '=' in pattern. Why not grep -F ?
        #        Maybe . stands for [ =], i.e. space or '='?
        #        Above, the line
        #           Customdockeroptions="${Customdockeroptions//"--cap-add "/"--cap-add="}"
        #        normalizes space to '=' in check_options_arguments()
        #
        if grep -q -i -- '--cap-add.ALL'       <<< "$Customdockeroptions" ; then
            warning_ttm "|Found option --cap-add=ALL
                         |  in CUSTOM_RUN_OPTIONS. That is A VERY BAD IDEA.
                         |  That is a very privileged setup.
                         |  Malicious applications may harm to the host."
        fi
        #
        # FIXME: using '.' for '=' in pattern. Why not grep -F ?
        if grep -q -i -- '--cap-add.SYS_ADMIN' <<< "$Customdockeroptions" ; then
            warning_ttm "|Found option --cap-add=SYS_ADMIN
                         |  in CUSTOM_RUN_OPTIONS. That is A VERY BAD IDEA.
                         |  That is a very privileged setup.
                         |  Malicious applications may harm to the host."
        fi
        #
        if grep -q -- '--entrypoint'           <<< "$Customdockeroptions" ; then
            warning_ttm "|Found option --entrypoint
                         |  in CUSTOM_RUN_OPTIONS. x11docker uses this option, too.
                         |  This setup will probably fail. Use x11docker option --no-entrypoint instead
                         |  and add desired command as container command after the image name."
        fi
        #
        for Line in "--group-add" "--ipc" "--name" "--network" "--user=" "--runtime" "--workdir"; do
            if grep -q -- "$Line" <<< "$Customdockeroptions" ; then
                note_ttm "|Found option $Line in CUSTOM_RUN_OPTIONS.
                          |  Please use x11docker option $Line instead.
                          |  Otherwise x11docker might behave wrong."
            fi
        done
    fi # Customdockeroptions

    return 0
} # end check_options_messages()

#
# Function: check_optionset
# Usage:  check_optionset the_option incompatible_options
#
# Brief: Emit a @code{note} for each of incompatible_options in g_Optionset1
#
# Argument:
#
#   the_option : The option that is incompatible with each element of
#                incompatible_options. Inly used in messages.
#
#   incompatible_options : List of options that are not compatible
#                          with the_option. They are separated by
#                          whitespace.
#
# Global:
#
#    g_Optionset1 : The currently selected options. Newline-separated
#
# Description:
#
#    Check if any of the incompatible_options appear in g_Optionset1, the
#    list of current options.
#    Emit a @code{note} on each that appears.
#
# return: 1 if any of the incompatible_options was found in g_Optionset1.
#         0 if not.
#
#
#
check_optionset() {
    local the_option="${1:-}"
    local incompatible_options="${2:-}"
    #
    local x
    local Return=""
    #
    for x in ${incompatible_options}; do
        if stdin_contains_the_word "$x" <<< "$g_Optionset1" ; then
            Return=1
            note "Option ${the_option} does not support option ${x}"
        fi
    done
    if [ "${Return}" = "1" ] ; then
        check_fallback
    fi
    return "${Return:-0}"
}


#### main
#
#
#
declare_variables() {           # declare global variables
  export IFS=$' \n\t'           # set IFS to default

  # Global environment variables used in x11docker
  ALSA_CARD="$(check_envvar "${ALSA_CARD:-}")"
  CUPS_SERVER="$(check_envvar "${CUPS_SERVER:-}")"
  DBUS_SESSION_BUS_ADDRESS="$(check_envvar "${DBUS_SESSION_BUS_ADDRESS:-}")"
  DISPLAY="$(check_envvar "${DISPLAY:-}")"
  DRI_PRIME="$(check_envvar "${DRI_PRIME:-}")"
  DOCKER_HOST="$(check_envvar "${DOCKER_HOST:-}")"
  GDK_BACKEND="$(check_envvar "${GDK_BACKEND:-}")"
  HOME="$(check_envvar "${HOME:-}")"
  LANG="$(check_envvar "${LANG:-}")"
  LC_ALL="$(check_envvar "${LC_ALL:-}")"
  PATH="$(check_envvar -w "${PATH:-}")"
  WAYLAND_DISPLAY="$(check_envvar "${WAYLAND_DISPLAY:-}")"
  XAUTHORITY="$(check_envvar "${XAUTHORITY:-}")"
  XDG_CURRENT_DESKTOP="$(check_envvar "${XDG_CURRENT_DESKTOP:-}")"
  XDG_RUNTIME_DIR="$(check_envvar "${XDG_RUNTIME_DIR:-}")"
  XDG_SEAT="$(check_envvar "${XDG_SEAT:-}")"
  XDG_SESSION_ID="$(check_envvar "${XDG_SESSION_ID:-}")"
  XDG_VTNR="$(check_envvar "${XDG_VTNR:-}")"
  __GLX_VENDOR_LIBRARY_NAME="$(check_envvar "${__GLX_VENDOR_LIBRARY_NAME:-}")"
  __NV_PRIME_RENDER_OFFLOAD="$(check_envvar "${__NV_PRIME_RENDER_OFFLOAD:-}")"
  __VK_LAYER_NV_optimus="$(check_envvar "${__VK_LAYER_NV_optimus:-}")"
  #
  # Add possibly missing PATH entries
  PATH="${PATH:-"/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:/usr/local/games:/usr/games"}"
  grep -q ':/sbin:'            <<< ":$PATH:" || PATH="$PATH:/sbin"
  grep -q ':/usr/sbin:'        <<< ":$PATH:" || PATH="$PATH:/usr/sbin"
  grep -q ':/usr/local/bin:'   <<< ":$PATH:" || PATH="$PATH:/usr/local/bin"
  grep -q ':/usr/bin:'         <<< ":$PATH:" || PATH="$PATH:/bin"
  grep -q ':/usr/bin:'         <<< ":$PATH:" || PATH="$PATH:/usr/bin"
  grep -q ':/usr/local/games:' <<< ":$PATH:" || PATH="$PATH:/usr/local/games"
  grep -q ':/usr/games:'       <<< ":$PATH:" || PATH="$PATH:/usr/games"
  export PATH
  #
  # seconds and nanoseconds since epoch
  Cachenumber="$(date +%s%N | cut -c6-17)"        # Number to use for cache folder
  [ -z "$Cachenumber" ] && Cachenumber="$(makecookie | cut -c6-17)"

  # =========================
  # --- File descriptors ---
  # =========================

  # FDcmdstdin : --stdin channel to forward stdin to container.
  #              Previously &7
  FDcmdstdin=""

  # FDmessage : message channel for notes, warnings and verbosity
  #             across threads and container.
  #             Previously &6
  #
  FDmessage=""

  # FDstderr : internal stderr >&2, redirected to null with
  #            --silent. Already declared in main(). Previously &3
  
  # FDstderr=""


  # FDtimetosaygoodbye : message channel to send termination signal
  #                      from or to containers. Previously &8
  FDtimetosaygoodbye=""
  
  # FDwatchpid : message channel for watchpidlist(). Previously &9
  FDwatchpid=""

  # ================================================
  # --- Terminal colors used for messages and -V ---
  # ================================================

  Esc="$(printf '\033')"
  Colblue="${Esc}[35m"
  Colyellow="${Esc}[33m"
  Colgreen="${Esc}[32m"
  Colgreenbg="${Esc}[42m"
  Colred="${Esc}[31m"
  Colredbg="${Esc}[41m"
  Coluline="${Esc}[4m"
  Colnorm="${Esc}[0m"

  # =====================================
  # --- x11docker startup environment ---
  # =====================================
  
  # Runsinsnap : docker runs in Ubuntu snap, Value: yes|""
  Runsinsnap=""
  
  # Runsinteractive : --enforce-i: Script runs in bash interactive
  #                   mode (bash -i) yes/no.
  Runsinteractive=""
  
  # Runsinterminal : x11docker runs in a terminal yes/no
  Runsinterminal=""
  
  # Runsonconsole : x11docker runs on tty yes/no
  Runsonconsole=""
  
  # Runsoverssh : x11docker runs over SSH yes/no. Makes a difference
  #               for --hostdisplay
  Runsoverssh=""
  
  # Runssourced : x11docker has been sourced yes/no
  Runssourced=""

  # =========================
  # --- Generated scripts ---
  # =========================
  
  # Clipboardrc : --clipboard: Generated script for text clipboard sharing
  Clipboardrc="clipboardrc"
  
  # Cmdrc : Generated script starting container command
  Cmdrc="cmdrc"

  # Containerrc : Generated script starting cmdrc
  Containerrc="containerrc"
  
  # Containerrootrc : Generated script to set up container, e.g. user
  #                   creation. Runs as root in container.
  Containerrootrc="containerrootrc"

  # Sshenvscript : Generated script to manually set environment
  #                variables for ssh -X
  Sshenvscript="sshenv"
  
  # Xinitrc : Generated script to set up X, e.g. cookie and xrandr
  Xinitrc="xinitrc"
  
  # Xtermrc : Generated script for password prompt
  Xtermrc="xtermrc"

  # =========================
  # --- Internal messages ---
  # =========================
  
  # Logmessages : Stores messages until logfile is available, needed
  #               by logentry()
  Logmessages=""
  
  # Messagefifo : Message channel for
  #               warning/verbose/debugnote/note/error within
  #               container,, containerrootrc and others
  #
  Messagefifo="message.fifo"
  
  # Storeinfofile : File to store some info like id, pid, name, exit
  #                 code
  #
  Storeinfofile="store.info"

  # Storepidfile : File to store pids and names of background
  #                processes that should be terminated on exit
  Storepidfile="store.pids"
  
  # Timetosaygoodbyefile : File giving term signal to all parties
  Timetosaygoodbyefile="timetosaygoodbye"

  # Timetosaygoodbyefifo : Message channel for
  #                       --init=openrc|runit|sysvinit
  #                       to shut down on x11docker signal
  #
  Timetosaygoodbyefifo="timetosaygoodbye.fifo"
  
  # Usemkfifo : Not on Windows nor with kata-runtime
  Usemkfifo=""

  # Watchpidfifo : Message channel to transfer pids to watchpidlist()
  Watchpidfifo="watchpid.fifo"

  # =========================
  # --- Logfiles          ---
  # =========================

  # Backendcommandfile : File to store generated docker command,
  #                      needed for --interactive
  Backendcommandfile="docker.command"

  # Compositorlogfile : Logfile for weston or kwin_wayland
  Compositorlogfile="compositor.log"
  
  # Containerlogfile : Logfile for container output other than
  #                    container command output
  #
  Containerlogfile="container.log"

  # Logfile : $Cachefolder/x11docker.log (current log)
  Logfile=""

  # Logfilebackup : $Cachebasefolder/x11docker.log (latest terminated
  #                 log)
  #
  Logfilebackup=""

  # Messagelogfile : Logfile for warning/verbose/debugnote/note/error
