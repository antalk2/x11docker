#
# Function: timestamp
#
timestamp() {                   # print HH:MM:SS,NNN
    # %N prints nanoseconds. cut truncates it to millisecods
    # Output seems to contain decimal comma in the seconds part.
    date +%T,%N | cut -c1-12
    return 0
}

# Function: unspecialstring
#
# Usage: unspecialstring s [extra_allowed_chars]
#
# Brief: Replace special chars of `s` with `-`
#
unspecialstring() {
    #
    # - Replace all characters except those described in "a-zA-Z0-9_"
    #   with a '-'.
    #
    # - Replace newlines, too.
    #
    # - Allow additional chars to pass through in ($2 :
    #   extra_allowed_chars)
    #
    # - Remove leading and trailing '-'
    # - Avoid double '--'
    #
    # - Return empty string if only special chars are given.
    #
    local s="${1:-}"
    local extra_allowed_chars="${2:-}"
    #
    # tr -c : complement next arg (translate those not mentioned)
    #    -s : --squeeze-repeats Here: no "--" in the output.
    #
    printf "%s" "${s}"                                           \
        | LC_ALL=C tr -cs "a-zA-Z${extra_allowed_chars}0-9_" "-" \
        | sed -e 's/^-// ; s/-$//'
}


# Function: version_less_than
# Usage: version_less_than a b
# Brief:  a < b for dot-separated version numbers
#
# was: verlt
#
# return 0 or 1
#
version_less_than() {
    #
    # [ "${1:-}" = "${2:-}" ] && return 1 ||
    #    { version_less_equal "${1:-}" "${2:-}" && return 0 || return 1 ; }
    #
    #  ( a <= b ) && ( a != b )
    local a="${1:-}"
    local b="${2:-}"
    { version_less_equal "${a}" "${b}" ; } && [ "${a}" != "${b}" ]
}

#
# Function: version_less_equal
# Usage: version_less_equal a b
# Brief: a <= b for dot-separated version numbers
#
# was: verlte
#
# return 0 or 1
#
version_less_equal() {
    local a="${1:-}"
    local b="${2:-}"
    #
    # sort -V : natural sort of (version) numbers within text
    local the_smaller_one
    the_smaller_one="$(echo -e "${a}\n${b}" | sort -V | head -n1)"
    #
    [ "${a}" = "${the_smaller_one}" ] # the result
}


# Function wincmd
