#! /usr/bin/env bash
# -*- eval: (modify-syntax-entry ?_ "w") -*-

# x11docker
# Run GUI applications and desktop environments in Docker containers.
#
# - Runs additional X servers to circumvent common X security leaks.
# - Restricts container capabilities to enhance container security.
# - Container user is same as host user to avoid root in container.
# - Features e.g. sound, hardware acceleration and data storage.
#
# Run 'x11docker --help' or scroll down to read usage information.
# More documentation at:  https://github.com/mviereck/x11docker

Version="7.8.1-beta"
Packagedversion="no" # Set to "yes" if you want to package x11docker.
                     # This disables installation and update options.

# --enforce-i: Enforce running in interactive mode
#              to allow commands tty and weston-launch
#              in special setups. (deprecated)
#
grep -q -- "--enforce-i" <<< "$*" && case $- in
    *i*) set +H ;;
    *)   exec bash --noprofile --norc --noediting -i -- "$0" "$@" ;;
esac

# Concept nlsv : newline_separated_values
#
#  - A string where entries are separated by a newline character.
#  - Empty entries would be too easy to lose: we disallow them here.
#

# Concept: word : A string not containing newline, space, tab.
#
#          - Maybe it should be more strict.
#
#          - We need to allow "-", for arguments like "--xc"
#            and for "flipped-180"
#
#          - An empty string is not a word.

# Concept: nlsw : newline_separated_words. An nlsv containing only words.
#

#
# Filter: nlsv_drop_empty
#
# Usage: echo "${a_string}" | nlsv_drop_empty | ...
#
# Description: Remove empty lines (aka empty entries) from stdin.
# stdin:   string.
# stdout:  string, nlsv. As stdin, with empty lines removed.
#
nlsv_drop_empty() {
    grep -F -v -x ''
}

# Filter: as_nlsv
#
# Description: Same as nlsv_drop_empty()
#
# Usage: nlsv="$( cat "$file" | as_nlsv )"
# Usage: nlsv="$(  as_nlsv <<< "${a_string}" )"
#
# stdin:  string
# stdout: string, nlsv. As stdin, with empty lines removed
#
as_nlsv() {
    nlsv_drop_empty
}

# Function: is_nlsv_entry
# Usage:  is_nlsv_entry str
# Brief:  Is str a valid nlsv entry?
#
# Description: Test if a string is non-empty and contains no newlines.
#    This means it is a valid nlsv entry.
#
# Arguments:
#   str : string
#
# return: 0 if "$entry" is     a valid nlsv entry
#         1 if "$entry" is not a valid nlsv entry
#
is_nlsv_entry() {
    local the_bad_part
    if [ -z "$1" ] ; then
        return 1
    fi
    # remove all allowed characters from $1
    the_bad_part="$( echo "$1" | tr -c -d '\n' )"
    [ -z "${the_bad_part}" ]
}

#
# Function: nlsv_contains_any_unsafe
#
# Brief: Given two nlsv values, do they have any common entries?
#
#  Usage: echo "$nlsv1" | nlsv_contains_any_unsafe "$nlsv2"
#
#  return: 0 If "$nlsv1" contains any entry in "$nlsv2"
#          1 If it does not.
#
#  unsafe : Assumes stdin and "$1" are already passed through @code{as_nlsv}
#           (or nlsv_drop_empty) (i.e. they have no empty lines).
#           Otherwise empty lines may match each other.
#
nlsv_contains_any_unsafe() {
    grep -F -x -q  -- "${1}"
}

# Function: nlsv_intersection_unsafe
#
#  Description: The intersection (i.e. common entries) of two
#    nlsv values.
#
#  Usage: nlsv3="$( echo "$nlsv1" | nlsv_intersection_unsafe "$nlsv2" )"
#
# Arguments:
#   nlsv2 : nlsv
#
# stdin: nlsv
# stdout: The common lines, in the order they appear in nlsv1.
#
#         Note: Duplicates in nlsv1 may produce duplicates in the
#               output.
#
# return: 0 If "$nlsv1" and "$nlsv2" have common entries.
#         1 If found no common entries.
#
# unsafe: nlsv1 and stdin are not validated.
#
nlsv_intersection_unsafe() {
    grep -F -x  -- "${1}"
}

# Function: as_nlsw_intersection
#
# Description: Given to strings, convert them to nlsw values, print
#   their intersection.
#
# Usage:   common="$(as_nlsw_intersection "${a}" <<< "${b}")"
#
# Description:
#  - Converts a and b using as_newline_separated_words
#  - Prints their intersection (b filtered by a, order according to b)
#  - Duplicates in b can create duplicates in stdout.
#
#  Note: Probably `a` should be the small set, it is used as the
#        filtering expression.
#
# Arguments:
#   a : string containing words (sep by Space,Tab,Newline)
#
# stdin: string containing words (sep by Space,Tab,Newline)
# stdout: nlsw containing the common words.
#
as_nlsw_intersection() {
    local a="$( as_newline_separated_words <<< "${1}" )"
    as_newline_separated_words | nlsv_intersection_unsafe "$a"
}

# Function: nlsv_contains
#
# Usage: echo "$nlsv" | nlsv_contains "$entry"
#
# Arguments:
#   entry : An nlsv entry.
#
# Description:
#   - Check `is_nlsv_entry "$entry"`, error if not.
#
# return: 0 If entry was found in nlsv.
#
# unsafe: Assumes "$nlsv" has no empty lines
#
#
nlsv_contains() {
  if ! is_nlsv_entry "${1}" ; then
    error_ttm "|nlsv_contains():
               : The entry \"$(printf %q  "$1")\" is not a valid nlsv entry"
    #
    return 13 # Only if error returns.
  fi
  nlsv_contains_any_unsafe
}



#
# Filter: as_newline_separated_words
# Brief: Convert string to nlsw
#
# Description: Convert a (space,tab,newline)-separated list of words
#   to newline_separated_words.
#
# stdin: string
# stdout: nlsw
#
as_newline_separated_words() {
  # Space and Tab to newline, omit empty lines
  tr -s ' \t' '\n\n' | nlsv_drop_empty
}

# Function: is_a_word
# Usage: is_a_word str
# Brief: Test if str is a valid nlsw entry.
#
# return: 0 if yes
#         1 if no
#
is_a_word() {
  local the_bad_part
  # "" is not a word
  if [ -z "$1" ] ; then  return 1 ; fi
  # remove all allowed characters from $1
  the_bad_part="$( echo "$1" | tr -c -d ' \t\n' )"
  [ -z "${the_bad_part}" ]
}

# Function: stdin_contains_the_word
#
# Usage: stdin_contains_the_word a_word  <<< "$list_of_words"
#
# Arguments:
#   a_word : word. error() if is_a_word a_word fails.
#
# stdin : string, passed through as_newline_separated_words
#
# return 0 If word is found in stdin.
#        1 If not found.
#        2 An error in grep
#       13 If (! is_a_word a_word) and  error() returned
#
stdin_contains_the_word() {
    #
    if ! is_a_word "$1" ; then
        # stacktrace
        error_ttm "|stdin_contains_the_word():
                   : The pattern \"$(printf %q  "$1")\" is not a word."
        #
        return 13 # Only if error returns.
    fi
    as_newline_separated_words | nlsv_contains_any_unsafe "${1}"
}

# Function: stdin_contains_any_word
#
#  Description: Given two strings, test if they contain any words in
#    common.
#
#    Both strings are converted to nlsw before testing.
#
# Usage: echo "$wordlist1" | stdin_contains_any_word "$wordlist2"
#
# Arguments:
#   wordlist2 : string
#
# stdin: wordlist1
#
# return: 0 If "$wordlist1" contains any of the words in "$wordlist2".
#         1 If not.
#
stdin_contains_any_word() {
  #
  local pattern
  pattern="$(echo "$1" | as_newline_separated_words)"
  #
  # We want space and tab to separate words in the input.
  # Change these to newlines
  # Accept only whole-line matches.
  as_newline_separated_words | nlsv_contains_any_unsafe "${pattern}"
}


# Function: word_is_in
# Usage: word_is_in  a_word a_text
# Brief: A convenience wrapper around stdin_contains_the_word
#
# Arguments:
#   a_word : word
#   a_text : string. Used as stdin for stdin_contains_the_word
#
word_is_in() {
  echo "${2}" | stdin_contains_the_word "$1"
}

# Function: word_is_not_in
# Usage: word_is_not_in  a_word a_text
# Brief: Same as @code{! word_is_in a_word a_text}
#
# Arguments:
#   a_word : word
#   a_text : string. Used as stdin for stdin_contains_the_word
#
# return: 0 If a_word is not in a_text
#         1 If it is in.
#
word_is_not_in() {
  ! word_is_in "${1}" "${2}"
}


# Function: nlsw_set_difference
#
# Usage: nlsw_set_difference "$A"  "$B"
# Brief: Set difference A \ B
#
# Arguments:
#   A : string
#   B : string
#
# stdout: sorted  nlsw  of words in A but not in B
#
# Note: LC_ALL=C is used to make sorting determinisitic.
#
# Description:
#
# - A and B are converted to nlsw, sorted,
#   duplicates are removed from each.
#
nlsw_set_difference() {
  local A
  local B
  A="$( echo "$1" | as_newline_separated_words | LC_ALL=C sort -u )"
  B="$( echo "$2" | as_newline_separated_words | LC_ALL=C sort -u )"
  # grep considers newline-separated list of patterns as alternatives to match.
  # -v selects lines of A that are not in B
  echo "$A" | grep -Fvx -- "$B"
}

# Function: case_match
# Usage: case_match value pattern
# Brief: Does value match a case PATTERN?
# Arguments:
#   value   : string. The value to be matched
#   pattern : string. Used as a case pattern.
#             Example: "--weston*|--xpra*-xwayland"
#
# return: 0 is matches
#
# Purpose: Allow to rewrite
#
#        case "$value" in a|b*|c?|[e-f]) cmd ;; esac
#
#     to
#
#        if case_match "$value" "a|b*|c?|[e-f]" ; then cmd ; fi
#
# Note: bash has [[ string =~ REGEXP ]]
#
case_match() {
    local value="$1"
    local pattern="$2"
    local cmd

    cmd="$(
         printf "case \"%s\" in %s) true ;; *) false ;; esac" \
                "${value}"                                    \
                "${pattern}"
    )"
    # echo "$cmd"
    eval "$cmd"
}


# Filter: trim_to_bar_filter
# Used-by: trim_to_bar()
#
# Example: trim_to_bar_filter <<< "multiline_string"
#
trim_to_bar_filter() {
  # shellcheck disable=SC2001
  sed -e 's/^[ \t]*|//'
}

# Function: trim_to_bar
#
# Usage: trim_to_bar str
#
# Brief: Allow multiline strings to be indented without affecting
#        their value.
#
# Description:
#  - Remove indentation in `s` up to and including the marker `|`.
#  - Lines not starting (after spaces and tabs) with '|' are not affected.
#
# Example: |
#  trim_to_bar \
#    "|abc
#     |def"
#  # yields: $'abc\ndef'
#
# Arguments:
#     str: A multiline string with indentation markers.
#
# stdout: The string value with indentations and markers removed.
#         Final newlines are usually lost by "$()", not trim_to_bar.
#         If they must be preserved, the following pattern could be used.
#         ----
#         x="$(trim_to_bar str)@magic_end_marker@"
#         x="${x%@magic_end_marker@}"
#         ----
#         Unfortunately, if this would be done inside trim_to_bar,
#         we would still lose the final newlines by the surrounding "$()".
#
#         We could probably pass in the target variable and set it
#         using a variable reference. Then we could:
#           @code{ trim_to_bar_to varname str }
#
trim_to_bar() {
  printf "%s" "${1}" | trim_to_bar_filter
}

# Filter: ws_colon_is_continuation_filter
#
# Brief: Join lines starting with /[ \t]*:/ to the previous line.
#
# Description:
#  - This is a helper for trim_to_mark.
#  - The pattern is not looked for in the first line.
#
#
ws_colon_is_continuation_filter() {
  # Based on https://www.gnu.org/software/sed/manual/html_node/Joining-lines.html
  # Join lines that start with whitespace (e.g SMTP headers):
  #  GNU sed: sed -E ':a ; $!N ; s/\n\s+/ / ; ta ; P ; D'
  #  A portable (non-gnu) variation: sed -e :a -e '$!N;s/\n  */ /;ta' -e 'P;D'
  #
  # Modified to look for /[ \t]*:/ instead of /\s+/ and leave no space after.
  #
  sed -e :a -e '$!N;s/\n[ \t]*://;ta' -e 'P;D'
}

#
# Function: trim_to_mark
# Usage: x="$(trim_to_mark str)"
#
# Purpose: Allow multiline strings to be indented and
#          long lines broken into smaller parts without
#          affecting the result.
#
# Description:
#  - Lines starting with spaces followed by a colon /^[ \t]*:/ are joined to the
#    previous line (dropping the matching part).
#    The result is passed through trim_to_bar_filter.
#
trim_to_mark() {
  printf "%s" "${1}" \
      | ws_colon_is_continuation_filter \
      | trim_to_bar_filter
}

# Group: message_ttm
# Function: error_ttm
# Function: warning_ttm
# Function: note_ttm
# Function: debugnote_ttm
# Function: verbose_ttm
#
#  The @code{ note "$( trim_to_mark text )" } pattern proved wery
#  useful. These functions shorten its use to @code{ note_ttm text }.
#
#  Unlike the original @code{note} et al., these functions accept a
#  single argument.
#
#
error_ttm() {
  error "$( trim_to_mark "${1}" )"
}

warning_ttm() {
  warning "$( trim_to_mark "${1}" )"
}

note_ttm() {
  note  "$( trim_to_mark "${1}" )"
}

debugnote_ttm() {
  debugnote  "$( trim_to_mark "${1}" )"
}

verbose_ttm() {
  verbose  "$( trim_to_mark "${1}" )"
}

# EndGroup: message_ttm

# Group: exitcode_to_string
# Function: exitcode_yes_or_no
# Brief: echo yes or echo no depending on [ "$?" = "0" ]
#
# Example: [ -z "$a_variable" ] ; x="$(exitcode_yes_or_no )"
# Example: x="$( [ -z "$a_variable" ] ; exitcode_yes_or_no )"
#
# Purpose: shortens
#  @code{ if [ -z "$a_variable" ] ; then a_long_name=yes ; else a_long_name=no; fi  }
#  or @code{  [ -z "$a_variable" ] && a_long_name=yes || a_long_name=no   }
#
# Function: exitcode_yes_or_empty
# Brief: Similar to exitcode_yes_or_no, but instead of "no" it produces no output.
#
exitcode_yes_or_no()    { if [ "$?" = "0" ] ; then printf yes ; else  printf no ; fi }
exitcode_yes_or_empty() { if [ "$?" = "0" ] ; then printf yes ;                   fi }

# EndGroup: exitcode_to_string


# Function rev_cut
# Brief: Reversed cut.
#
# Description: As `cut`, but counts fields from the back.
#
# Example: echo abcdef | rev_cut -c1-3 # def
# Example: printf "abddef\nABCDEF" | rev_cut -c1-3 # def\nDEF
#
# Arguments:
#   Same as for cut. @code{"${@}"} is passed on.
#
# stdin:  The text to process.
# stdout: The processed text.
#
rev_cut() {
  rev | cut "${@}" | rev
}

# Function: have_command
# Brief: Test if command "$1" is available.
#
# Warning: Currently it also returns 0 if "$1" is an alias or a shell
#          function. Success does not imply we found the executable.
#
# Arguments:
#    $1: name of an executable (This is what we use it for)
#
# return: 0 If the executable is found (in PATH)
#         1 If no alias, no shell and no executable function found
#            with this name.
#
have_command() {
  # Note: returns 0 for an alias or shell function.
  if [ "$#" != "1" ] ; then
    error "have_command expected exactly one argument"
  fi
  command -v "$1" > /dev/null
}


# Function: join_with
# Brief: SEP="$1",  join the rest of "${@}" by SEP
#
# Usage: join_with SEP [ s1 ... sn ]
#
# Description: Joins the strings s1 ... sn with separator SEP
#
# Example: join_with ":" "${groupname}" "${gid}" "$g_Containerusername"
# Example: variable="$(join_with " \\${NEWLINE}" "${variable}"  "--option1" "--option2" )"
# Example: variable+="$(join_with " \\${NEWLINE}" ""  "--option1" "--option2" )"
#
# Argument:
#
#   SEP : may be empty, may contain newline, may contain
#         multicharacter string.
#
#   s1 ... sn : strings to join.
#               n=0 is allowed, yields ""
#               s1="" yields "${SEP}${s2} ... ${SEP}${sn}",
#                            which is empty for n=1.
#
join_with_sh_v1() {
    local SEP="${1}"
    local s1="${2:-}"
    local si
    shift 2
    #
    # Directly to stdout
    printf "%s" "${s1}"
    for si in "${@}" ; do
        printf "%s" "${SEP}${si}"
    done
}
join_with_sh_v2() {
    local SEP="${1}"
    local s1="${2:-}"
    local si
    shift 2
    #
    # Build in res, emit in one
    local res="${s1}"
    for si in "${@}" ; do
        res="${res}${SEP}${si}"
    done
    printf "%s" "${res}"
}

#
# https://stackoverflow.com/questions/1527049/how-can-i-join-elements-of-a-bash-array-into-a-delimited-string
#
join_with_bash() {
    local SEP="${1}"
    local s1="${2:-}"
    shift 2
    printf %s "${s1}" "${@/#/${SEP}}"
}

join_with() {
    join_with_sh_v2 "${@}" ;
}

# Function: join_with_character
# Usage: join_with_character SEP [ s1 ... sn ]
# Brief: Similar to join_with, but SEP must be a single character (or empty)
#
join_with_character() {
    #
    if [ "$( printf %s "$1" | wc -c )" -gt 1 ] ; then
        error "join_with_character: SEP '${1}' is more than one character"
        return 13
    fi
    #
    local IFS="$1"
    shift
    #
    printf "%s" "${*}"
}

# Function: join_with_comma
# Usage: join_with_comma [ s1 ... sn ]
# Brief: s1,s2,...,sn
#
#
join_with_comma() {
    join_with_character "," "${@}"
}

# Function: join_with_prefix
# Usage: join_with_prefix PREFX s1 ... sn
# Brief: "${PREFX}${s1} ... ${PREFX}${sn}"
#
# Description: Same as join_with PREFX "" s1 ... sn
#
join_with_prefix() {
    local PREFIX="${1}"
    shift
    #
    local res=""
    local si
    for si in "${@}" ; do
        res="${res}${PREFIX}${si}"
    done
    printf "%s" "${res}"
}


# Group: Debug_stuff
#
# Function: stacktrace
# Function: stacktrace2
# Function: echodbg (helper used by stacktrace2)
#
# https://gitlab.com/kyb/autorsync/-/blob/master/utils.bash#L84
# set -eETuo errexit -o nounset -o pipefail #-o errtrace -o functrace
# shopt -s expand_aliases lastpipe #gnu_errfmt globstar huponexit inherit_errexit localvar_inherit

# echodbg()  { >/dev/stderr echo $'\e[0;36m'"DBG  $@"$'\e[0m'; }
echodbg()  { >/dev/stderr printf  '\e[0;36m%s\e[0m\n' "DBG  $*" ; }

stacktrace() {
    local i=1 line file func
    echo >&2 "--- stacktrace begin ---"
    while read -r line func file < <(caller $i); do
        echo >&2 "${file}:${line}: level[$i]  $func(): $(sed -n "${line}p" "$file")"
        ((i++))
    done
    echo >&2 "--- stacktrace end ---"
}

stacktrace2() {
   local i=${1:-1} size=${#BASH_SOURCE[@]}
   ((i<size)) && echodbg "STACKTRACE"
   for ((; i < size-1; i++)) ;do  ## -1 to exclude main()
      ((frame=${#BASH_SOURCE[@]}-i-2 ))
      echodbg "[$frame] ${BASH_SOURCE[$i]:-}:${BASH_LINENO[$i]} ${FUNCNAME[$i+1]}()"
   done
}

# Function: SPY_STDOUT
# Purpose: Find out what is the output of a function.
#
#    To spy on stdout of a function @code{F}, rename @code{F} to @code{F_orig},
#    and add @code{ F(){ SPY_STDOUT F_orig "${@}" } }
#
# This will report args and stdout of calls to F, prefixed with "SPY_STDOUT"
#
SPY_STDOUT() {
    local tmpfile1
    tmpfile1="$(mktemp -t file_1_XXXXXX)"
    "${@}" 1>"$tmpfile1"
    #
    local exitCode
    exitCode=${PIPESTATUS[0]}
    #
    local stdout
    stdout="$(< "$tmpfile1")"
    #
    unlink "$tmpfile1"
    echo "SPY_STDOUT args:   $*"         >&2
    echo "SPY_STDOUT stdout: ${stdout}"  >&2
    echo "${stdout}"
    return "$exitCode"
}

# Function: POST_CONDITION
# Usage: POST_CONDITION label condition
