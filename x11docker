# Function: check_windowmanager
# CommandlineOption:  --wm: search a host window manager
#
#  Attempts to fill Windowmanagercommand and Windowmanagermode
#
# Globals:
#     Xcontainer_option  (--xc) Read.
#
#     Windowmanagermode    : On exit,  can be { none | host }
#     Windowmanagercommand : Can be set
#
check_windowmanager() {
    #
    # check --wm arguments, adjust mode
    #
    if [ "$Xcontainer_option" = yes ] ; then
        case "$Windowmanagermode" in
            auto|host)                    # Windowmanagermode_host
                Windowmanagermode="host"  # Windowmanagermode_host
                Windowmanagercommand="openbox --sm-disable"
                ;;
            *)
                Windowmanagermode="none"
                ;;
        esac
        return 0
    fi

    {
        case "$Windowmanagermode" in
            ""|none)
                Windowmanagermode="none"
                return 0
                ;;
            auto)
                Windowmanagermode="host"           # Windowmanagermode_host
                if [ -n "$Windowmanagercommand" ] ; then
                    if ! have_command  "$(cut -d' ' -f1 <<< "$Windowmanagercommand")" ; then
                        note_ttm \
                            "|Option --wm: Did not find command on host: $Windowmanagercommand
                             |  Fallback: Searching for another window manager."
                        #
                        check_fallback
                        Windowmanagercommand=""
                    else
                        # Windowmanagercommand is available on host
                        Windowmanagermode="host"   # Windowmanagermode_host
                    fi
                fi
                ;;
            host) ;;
        esac

        if [ "$Windowmanagermode" = "none" ] ; then return 0 ; fi
    }

    # Find an available window manager command on the host
    {
        if [ -z "$Windowmanagercommand" ] ; then
            for Windowmanagercommand in $Wm_all WM_NOT_FOUND; do
                if have_command "$Windowmanagercommand" ; then
                    break # found
                fi
            done
        fi

        if [ "$Windowmanagercommand" = "WM_NOT_FOUND" ] ; then
            Windowmanagercommand=""
            note_ttm "|Option --wm: No host window manager found.
                  |    Please install a supported one. Recommended:
                  |  $Wm_recommended_nodesktop_light
                  |  Fallback: Setting --wm=none"
            #
            check_fallback
            Windowmanagermode="none"
        fi
        #
        if  [ "$Windowmanagermode" = "none" ] ; then return 0 ; fi
    }
    
    if grep -q "$Windowmanagercommand" <<< "$Wm_not_recommended" ; then 
        note_ttm "|Option --wm: Window manager $Windowmanagercommand
                  |  is not recommended. Please install a recommended one:
                  |    $Wm_recommended_nodesktop_light
                  |    $Wm_recommended_desktop_light"
    fi

    if [ "$Xtest" = "yes" ] ; then
        warning_ttm \
            "|Options --xtest --wm: Did not disable X extension XTEST
             |  for X server $Xserver.
             |  If your host window manager '$Windowmanagercommand' can start applications
             |  on its own (for example with a context menu), container applications
             |  can abuse this to run and remotely control host applications.
             |  If you provide content of X server $Xserver over network to others,
             |  they may take control over your host system!"
    fi

    #
    # Command adjustment for some host window managers
    #
    case "$(basename "$(cut -d' ' -f1 <<< "$Windowmanagercommand")")" in
        cinnamon|cinnamon-session)
            # Override 'cinnamon-session' and also any args provided elsewhere
            Windowmanagercommand="cinnamon --sm-disable"
            ;;

        compiz)
            # If none, create minimal config to have usable window
            # decoration and can move windows
            (
                local ccdir="$Hostuserhome/.config/compiz-1/compizconfig"
                if [ ! -e    "${ccdir}/Default.ini" ] ; then
                    mkfolder "${ccdir}"
                    mkfile   "${ccdir}/Default.ini"
                    trim_to_bar \
                        '|[core]
                         |s0_active_plugins = core;composite;opengl;decor;resize;move;
                         |' >> "${ccdir}/Default.ini"
                fi
            )
        ;;

        enlightenment|e17|e16|e19|e20|e)
            Windowmanagercommand="enlightenment_start"
            ;;
        matchbox)
            Windowmanagercommand="matchbox-window-manager"
            ;;
        mate|mate-session)
            Windowmanagercommand="mate-session -f"
            ;;
        mate-wm)
            Windowmanagercommand="marco --sm-disable"
            ;;
        openbox)
            Windowmanagercommand="openbox --sm-disable"
            if [ -e "/etc/xdg/openbox/rc.xml" ] ; then
                cp /etc/xdg/openbox/rc.xml "$Sharefolder/openbox-nomenu.rc"
                sed -i /ShowMenu/d         "$Sharefolder/openbox-nomenu.rc" # disable ShowMenu
                sed -i s/NLIMC/NLMC/       "$Sharefolder/openbox-nomenu.rc" # hide the Iconify button
                Windowmanagercommand="$(trim_to_mark
                          "|$Windowmanagercommand
                           : --config-file '$Sharefolder/openbox-nomenu.rc'"
                           )"
            fi
            ;;
    esac

    case "$Windowmanagermode" in
        host) # Windowmanagermode_host
            # https://linux.die.net/man/1/wmctrl
            xtool --check "wmctrl" || true
            ;;
    esac

  note "Using host window manager: ${Windowmanagercommand:-"(none)"}"
  return 0
} # check_windowmanager



# Function clean_xhost
# CommandlineOption:  --clean-xhost
#
# Brief: Disable access to X (granted via `xhost` permissions) on the host.
#
#    Q: Why are we messing with permissions on the host?
#    A: This is only done if the user explicitly asked for it
#       via `--clean-xhost`
#
clean_xhost() {
    #
    #
    if [ -z "$Hostdisplay" ] ; then
        note "Option --clean-xhost: No host X display found."
        return 1
    fi
    #
    if [ -z "$Hostxauthority" ] ; then
        warning_ttm \
            "|Option --clean-xhost: Your host X server does not provide
             |  an authentication cookie in \$XAUTHORITY.
             |  Host applications started after xhost cleanup might fail to start."
    fi
    #
    {
        echo "Option --clean-xhost:"
        disable_X_access_via_xhost "DISPLAY=$Hostdisplay XAUTHORITY=$Hostxauthority"
    } >> "$Xinitlogfile" 2>&1
}

#
# Function: create_clipboardrc
# CommandlineOption: --clipboard
# Brief: Create shareclipboard script
#
# stdout: Writes generated content of the file to stdout.
#
create_clipboardrc() {
    #
    # FIXME: clipboardrc expects bash. Why?
    #
    echo "#! /usr/bin/env bash"

    declare -f rocknroll
    declare -f mysleep
    declare -f exitcode_yes_or_no
    declare -f exitcode_yes_or_empty
    
    echo "Timetosaygoodbyefile='$Timetosaygoodbyefile'"

    if [ -n "$Hostdisplay" ] ; then
        # When X1auth is eval-ed, will set DISPLAY and XAUTHORITY to the
        # values we have here.
        # echo "X1auth='DISPLAY=$Hostdisplay XAUTHORITY=$Hostxauthority'"
        trim_to_mark \
            "|X1auth=
             :'
             : DISPLAY=$Hostdisplay
             : XAUTHORITY=$Hostxauthority
             :'"
        echo
    elif [ -n "$Hostwaylandsocket" ] ; then
        #
        # Will extend the value of X1auth, so that eval $X1auth will
        # also set WAYLAND_DISPLAY and XDG_RUNTIME_DIR
        #
        # Not sure what are we extending, since the DISPLAY branch was
        # not run.
        #
        trim_to_mark \
            "|X1auth=
             :\"
             :\$X1auth
             : WAYLAND_DISPLAY=$Hostwaylandsocket
             : XDG_RUNTIME_DIR=$XDG_RUNTIME_DIR
             :\""
        echo
    fi

    if [ -n "$Newdisplay" ] ; then
        # echo "X2auth='DISPLAY=$Newdisplay  XAUTHORITY=$Xclientcookie'"
        trim_to_mark \
            "|X2auth=
             :'
             : DISPLAY=$Newdisplay
             : XAUTHORITY=$Xclientcookie
             :'"
        echo
    fi

    case "$Xserver" in

        --weston)
            trim_to_mark \
                "|X2auth=
                 :\"
                 :\$X2auth
                 : WAYLAND_DISPLAY=$Newwaylandsocket
                 : XDG_RUNTIME_DIR=$XDG_RUNTIME_DIR
                 :\""
            echo
            ;;

        --weston-xwayland)
            if [ "$Desktopmode" = "yes" ] && [ "$Setupwayland" = "yes" ] ; then
                trim_to_mark \
                    "|X2auth=
                     :\"
                     :\$X2auth
                     : WAYLAND_DISPLAY=$Newwaylandsocket
                     : XDG_RUNTIME_DIR=$XDG_RUNTIME_DIR
                     :\""
                echo
            fi
            ;;
    esac

    # shellcheck disable=SC2016 # (info): Expressions don't expand in
    #                             single quotes
    if [ "$Mytest" ] ; then
        trim_to_bar '|
                     |# Mytest
                     |echo "$X1auth"
                     |echo "$X2auth"
                     |#
                     |'
        echo
    fi

    # shellcheck disable=SC2016 # (info): Expressions don't expand in
    #                             single quotes
    trim_to_bar \
        '|
         |clipexchange() {
         |  # Send clipboard content of one X server or Wayland compositor
         |  # to another X server and/or Wayland compositor and update on changes.
         |  # Run function twice with switched credentials to sync the clipboards.
         |  # Runs in a loop except $4 is set
         |  # $1  credentials to access 1. X server and/or Wayland compositor
         |  # $2  credentials to access 2. X server and/or Wayland compositor
         |  # $3  selection to use (primary or clipboard)
         |  # $4  set to "noloop" if you want to run only once without a loop
         |  #
         |  # Credentials look like
         |  #   "DISPLAY=:0 XAUTHORITY=~/.Xauthority WAYLAND_DISPLAY=wayland-1 XDG_RUNTIME_DIR=/run/user/1000"
         |
         |  local Selection SelectionW   SelectionX
         |  local             TargetsW     TargetsX
         |  local         ImagetargetW ImagetargetX
         |  local Clip           ClipW        ClipX
         |  local Clipold    ClipoldW2    ClipoldX2
         |  local                CopyW        CopyX
         |  local Wprimary1
         |  local Wprimary2
         |  local Noloop
         |
         |  Selection="${3:-}"
         |  Noloop="${4:-}"
         |
         |  export DISPLAY="" WAYLAND_DISPLAY=""
         |  export ${1:-} # evaluate "$X1auth" or "$X2auth"
         |
         |  case "$Selection" in
         |    primary)
         |      SelectionX="-selection primary"
         |      SelectionW="--primary"
         |      #
         |      # wl-paste : sudo apt install wl-clipboard
         |      #
         |      env \$X1auth wl-paste --primary >/dev/null 2>&1 ; Wprimary1="$(exitcode_yes_or_no)"
         |      env \$X2auth wl-paste --primary >/dev/null 2>&1 ; Wprimary2="$(exitcode_yes_or_no)"
         |      #
         |
         |      [ -n "$WAYLAND_DISPLAY" ] && [ "$Wprimary1,$Wprimary2" = "yes,yes" ]
         |      CopyW="$(exitcode_yes_or_empty)"
         |
         |      [ -n "$DISPLAY" ]
         |      CopyX="$(exitcode_yes_or_empty)"
         |    ;;
         |
         |    clipboard)
         |      SelectionX="-selection clipboard"
         |      SelectionW=""
         |
         |      [ -n "$WAYLAND_DISPLAY" ] ; CopyW="$(exitcode_yes_or_empty)"
         |      [ -n "$DISPLAY"         ] ; CopyX="$(exitcode_yes_or_empty)"
         |    ;;
         |  esac
         |'
    echo
  ############
  
  # shellcheck disable=SC2016 # (info): Expressions don't expand in
  #                             single quotes
  trim_to_bar \
      '|
       |  while rocknroll; do
       |
       |    # Why export after already exported above?
       |    # Why export in each loop?
       |    export DISPLAY="" WAYLAND_DISPLAY=""
       |    export ${1:-}
       |
       |    # Check for image clip
       |    if [ "$CopyW" ] ; then TargetsW="$(wl-paste --list-types $SelectionW)"  ; fi
       |    if [ "$CopyX" ] ; then TargetsX="$(xclip -out            $SelectionX -t TARGETS)" ; fi
       |
       |    if grep -q "image/png" <<< "$TargetsW" ;
       |    then  ImagetargetW="-t image/png"      ;
       |    else  ImagetargetW=""                  ; fi
       |
       |    if grep -q "image/png" <<< "$TargetsX" ;
       |    then  ImagetargetX="-t image/png"      ;
       |    else  ImagetargetX=""                  ; fi
       |
       |    # Read content of $Selection of X server $1
       |    if [ "$CopyW" ] ; then ClipW="$(wl-paste   $SelectionW $ImagetargetW | base64 -i)" ; fi
       |    if [ "$CopyX" ] ; then ClipX="$(xclip -out $SelectionX $ImagetargetX | base64 -i)" ; fi
       |
       |    # Check for new clip
       |    if [ -n "$ClipW" ] && [ "$ClipW" != "$Clipold" ] ; then Clip="$ClipW" ; fi
       |    if [ -n "$ClipX" ] && [ "$ClipX" != "$Clipold" ] ; then Clip="$ClipX" ; fi
       |
       |    # Fill empty clipboards to prevent odd issues
       |    case "$Selection" in
       |      clipboard)
       |        if [ -z "$ClipW" ] || [ -z "$ClipX" ] ; then
       |
       |          if [ -z "$Clip" ]  ; then
       |                Clip="$(base64 -i <<< "x11docker")"
       |          fi
       |
       |          if [ -z "$ClipW" ] && [ -n "$CopyW" ] ; then
       |               if  base64 -d -i <<< "$Clip" | wl-copy   $SelectionW ; then
       |                   Clipold="$Clip"
       |               fi
       |          fi
       |
       |          if [ -z "$ClipX" ] && [ -n "$CopyX" ] ; then
       |              if base64 -d -i <<< "$Clip" | xclip -in $SelectionX ; then
       |                  Clipold="$Clip"
       |              fi
       |          fi
       |
       |        fi
       |      ;;
       |    esac
       |'
  echo
  #############

  if [ "$Mytest" ] ; then
      # shellcheck disable=SC2016 # (info): Expressions don't expand
      #                             in single quotes
      trim_to_bar \
          '|
           |# Mytest
           |echo "
           |Selection $Selection
           |ClipX:    $ClipX $(base64 -d -i <<< "$ClipX")  D:$DISPLAY
           |ClipW:    $ClipW $(base64 -d -i <<< "$ClipW")  D:$WAYLAND_DISPLAY
           |Clipold:  $Clipold $(base64 -d -i <<< "$Clipold")
           |Clip:     $Clip $(base64 -d -i <<< "$Clip")
           |"
           |'
      echo
  else
      trim_to_bar \
          '|
           |# Mytest (elided)
           |'
      echo
  fi
  
  # shellcheck disable=SC2016 # (info): Expressions don't expand in single quotes
  trim_to_bar \
      '|
       |
       |    if [ -n "$Clip" ] && [ "$(base64 -d -i  <<< "$Clip")" != "$(base64 -d -i <<< "$Clipold")" ] ; then
       |      Clipold="$Clip"
       |      export DISPLAY= WAYLAND_DISPLAY=
       |      export ${2:-}
       |
       |      # check existing content of target clipboard of $2
       |      [ -n "$WAYLAND_DISPLAY" ] && ClipoldW2="$(wl-paste   $SelectionW $Imagetarget | base64 -i)"
       |      [ -n "$DISPLAY" ]         && ClipoldX2="$(xclip -out $SelectionX $Imagetarget | base64 -i)"
       |
       |      # send only to clipboard of other X server if it has different content.
       |      # Important to keep highlighting of text for primary/middle mouse click.
       |
       |      if [ "$ClipoldW2" != "$Clip" ] && [ -n "$WAYLAND_DISPLAY" ] ; then
       |             base64 -d -i <<< "$Clip" | wl-copy   $SelectionW $Imagetarget
       |      fi
       |
       |      if [ "$ClipoldX2" != "$Clip" ] && [ -n "$DISPLAY"         ] ; then
       |             base64 -d -i <<< "$Clip" | xclip -in $SelectionX $Imagetarget
       |      fi
       |
       |'
  echo
  ##

  # shellcheck disable=SC2016 # (info): Expressions don't expand in single quotes
  if [ "$Mytest" ] ; then
      echo '      [ "'$Mytest'" ] && echo "SEND $Selection to ${2:-} : V.$(base64 -d -i <<< "$Clip").V"'
  else
      echo '      # Mytest [ "'$Mytest'" ] && echo "SEND $Selection to ${2:-} : V.$(base64 -d -i <<< "$Clip").V"'
  fi

  trim_to_bar \
      '|    fi # if [ -n Clip ]
       '

  # shellcheck disable=SC2016 # (info): Expressions don't expand in single quotes
  trim_to_bar \
      '|
       |    [ "$Noloop" ] && break
       |
       |    # wait a bit to avoid high CPU usage and to reduce Wayland window flickering
       |    mysleep 1
       '
  echo

  if [ "$Mytest" ] ; then
      echo '    [ "'$Mytest'" ] && sleep 5'
  else
      echo '    # Mytest [ "'$Mytest'" ] && sleep 5'
  fi

  trim_to_bar \
      '|  done # while rocknroll
       |} # clipexchange
       |
       |'
  echo
  ###########
  
  # shellcheck disable=SC2016 # (info): Expressions don't expand in
  #                             single quotes
  case "$Shareclipboard" in
      yes) # bidirectional
          trim_to_bar \
              '|
               |clipexchange  "$X1auth" "$X2auth" clipboard &
               |#clipexchange "$X1auth" "$X2auth" primary   &
               |mysleep 1.4
               |clipexchange  "$X2auth" "$X1auth" clipboard &
               |#clipexchange "$X2auth" "$X1auth" primary   &
               |#
               |'
          echo
          ;;

      c2h) # only container to host
          trim_to_bar \
              '|
               |clipexchange  "$X2auth" "$X1auth" clipboard &
               |#clipexchange "$X2auth" "$X1auth" primary   &
               |'
          echo
          ;;

      h2c) # only container to host
          trim_to_bar \
              '|
               |clipexchange  "$X1auth" "$X2auth" clipboard &
               |#clipexchange "$X1auth" "$X2auth" primary   &
               |'
          echo
          ;;

      cmv)
          # cmv as in "CTRL+META+V"
          #
          # Always container to host, only with super + alt + v host
          # to container ### FIXME no wayland support here
          #
          trim_to_bar \
              '|
               |case "${1:-}" in
               |  cmv) # recursive call with xbindkeys or bindkey
               |       [ "'$Mytest'" ] && echo "CTRL+META+V" # Mytest
               |       clipexchange "$X1auth" "$X2auth" clipboard noloop
               |       #clipexchange "$X1auth" "$X2auth" primary   noloop
               |  ;;
               |
               |  "") # first call in xinitrc, run bindkey tools
               |    clipexchange  "$X2auth" "$X1auth" clipboard &
               |    #clipexchange "$X2auth" "$X1auth" primary   &
               |
               |# Xbindkeycodes will be passed to xbindkeys.
               |# Has 3 rows: (1) command, (2) state and keycode as reported by the tool xev.
               |# (3) the keysyms associated with the given keycodes.
               |# See https://wiki.archlinux.org/title/Xbindkeys
               |#
               |    Xbindkeycodes="
               |\"bash '"$Clipboardrc"' cmv\"
               |  m:0x54 + c:55
               |  Control+Mod2+Mod4 + v
               |"
               |
               |    # Xcontainer_option="'"$Xcontainer_option"'"
               |    # Xserver="'$Xserver'"
               |    # is_wayland=$( case  "$Xserver" in --weston|--weston-xwayland) echo yes ;; *) echo no ;; esac )
               |    # Setupwayland="'$Setupwayland'"
               |    # use_bindkey=$( if [ "$Xcontainer_option" = yes ]
               |    #                && [ "$is_wayland"        = yes ]
               |    #                && [ "$Setupwayland"      = yes ] ; then echo yes ; else echo no; fi )
               |    #
               |    # if [ $use_bindkey = yes ]
               |    # then env $X2auth bindkey '"$Clipboardrc"'                 & Xbindkeyspid=$!
               |    # else env $X2auth xbindkeys -n -f <(echo "$Xbindkeycodes") & Xbindkeyspid=$!
               |    # fi
               |
               |    # Xcontainer_option
               |    case "'"$Xcontainer_option"'" in
               |      yes)
               |        # Xserver
               |        case "'$Xserver'" in
               |           --weston|--weston-xwayland)
               |              #
               |              # Setupwayland
               |              case "'$Setupwayland'" in
               |                  yes) env $X2auth bindkey   '"$Clipboardrc"'               & Xbindkeyspid=$! ;;
               |                  no)  env $X2auth xbindkeys -n -f <(echo "$Xbindkeycodes") & Xbindkeyspid=$! ;;
               |              esac
