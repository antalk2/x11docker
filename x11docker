# Group: watching_processes
#
# Function: checkpid
# Usage: checkpid PID
# Brief:  Check if PID is active (process with this PID exists)
#
# return: 0 if PID is active
#         1 if not.
#
checkpid() {
    [ -e "/proc/${1:-NONSENSE}" ]
}

#
# Function: containerisrunning
# Brief: Check if container is running
#
containerisrunning() {
    # Has an entry in Storeinfofile?
    if ! storeinfo_test_sh containerid ; then
        return 1
    fi
    #
    if [ "$Dockervm" = no ]; then
        checkpid      "$(storeinfo_dump_sh pid1pid)"
    elif case_match "$Dockervm" 'moby|desktop' ; then
            unpriv_backend "$g_Backendbin inspect '$(storeinfo_dump_sh containerid)'" \
                           >/dev/null 2>&1
    fi
}

#
# global Myps can be:
#            Initially:           ""
#            On Cygwin and MSYS2: "procps"
#            Elsewhere:           "ps"
#

#
# Function: pspid_sh
# Usage: pspid_sh [{--empty-pid-is-OK|--empty-pid-is-FAIL}] pid
# Brief:  Get USER and COMMAND for PID=pid (using ps)
#
# Argument:
#    --empty-pid-is-OK   return 0 on empty pid
#    --empty-pid-is-FAIL return 1 on empty pid
#    pid : PID of a process. May have already exited.
#
# stdout: Line containing
#             USER PID COMMAND
#         for pid==PID, or empty.
#
# return: 0 (true)  if found line matching pid
#         1 (false) if found no process with pid
#
#         Inherited from grep: 0 if a line is selected,
#                              1 if no lines were selected, and
#                              2 if an error occurred.
#
# Compatibility_requirement: /bin/sh in xinitrc and containerrc
#
#
pspid_sh() {
    if [ "${1}" = "--empty-pid-is-OK" ] ; then
        shift
        if [ -z "${1}" ] ; then
            return 0
        fi
    elif [ "${1}" = "--empty-pid-is-FAIL" ] ; then
        shift
        if [ -z "${1}" ] ; then
            return 1
        fi
    fi
    #
    # Three columns: USER PID COMMAND
    #
    # man 1 ps
    # ps ax : To see every process on the system using BSD syntax
    #
    # Q: Why ` grep " ${1:-} "` ?
    # A: Only the middle column (PID) has space on both sides.
    # Q: But COMMAND may contain spaces.
    # A: Anchor to start of line.
    #
    # Q: Do we really want every process if $1 is empty?
    # A: No.
    #
    if [ -z "${1:-}" ] ; then
        error "pspid_sh(): the PID argument is empty"
    fi
    LC_ALL=C $Myps ax -o user,pid,comm | grep -E -e "^[^ ]+[ ]+${1:-} "
}


#
# Function: rocknroll
#
# Brief: Check whether x11docker session is still running
#
# Note: only checks "$Timetosaygoodbyefile", not
#       "$Timetosaygoodbyefifo".
#
# return: 0 If it thinks thes session is still running.
#         1 If Timetosaygoodbyefile is non-empty or missing.
#
rocknroll() {
    # -s : FILE exists and has a size greater than zero
    if [ -s "$Timetosaygoodbyefile" ]  ; then
        # Someone wrote "timetosaygoodbye" int it.
        return 1
    fi
    if [ ! -e "$Timetosaygoodbyefile" ]  ; then
        # We are so late, that the file has already been removed.
        return 1
    fi
    return 0
}

#
# Function: setonwatchpidlist
# Usage: setonwatchpidlist pid codename
#
# Brief: Add pid=$1 to watchpidlist() and @code{ storepid pid codename }
#
setonwatchpidlist() {
  debugnote "watchpidlist(): Setting pid ${1:-} on watchlist: ${2:-}"
  echo "${1:-}" >> "$Watchpidfifo"
  #
  # Add to list of background processes
  if ! grep -q CONTAINER <<<  "${1:-}" ; then
      storepid "${1:-}" "${2:-}"
  fi
}

#
# Function: storepid
# Usage: storepid PID CODENAME # Store (into Storepidfile)
# Usage: storepid test {PID|CODENAME} # return 0 if found
# Usage: storepid dump CODENAME       # print PID (or nothing)
#
# Globals:
#   Storepidfile : Path to file storing the data.
#
storepid() {      # store pid $1 and name $2 of process in file $Storepidfile.
    # Store pid and process name of background processes in a file
    # Used in finish() to clean up background processes
    #
    # Store:
    #  $1 pid
    #  $2 codename
    #
    # Test for stored pid or codename:
    #  $1 test
    #  $2 pid or codename
    #  return 0 if found, 1 if not
    #
    # Dump stored pid:
    #  $1 dump
    #  $2 codename
    #  print the whole line
    #
    case "${1:-}" in
        dump) grep    -w "${2:-}" "$Storepidfile" | cut -d' ' -f1 ;;
        test) grep -q -w "${2:-}" "$Storepidfile"                 ;;
        *)
            echo "${1:-NOPID}" "${2:-NONAME}" >> "$Storepidfile"
            local user_pid_command=""
            if [ ! -z "${1:-}" ] ; then
                user_pid_command="$(pspid_sh "${1:-}" || true)"
            fi
            debugnote "storepid(): Stored pid '${1:-}' of '${2:-}': ${user_pid_command}"
            ;;
    esac
}

#
# Function: termpid
# Usage: termpid PID CODENAME
#
# Brief:  kill PID,  CODENAME is only used in messages.
#
# Description: If needed, after some waiting also sends KILL signal.
#
# return 0: if was not active or was able to kill
#        1: if even the KILL signal did not succeed
#
termpid() {
    # TERM
    debugnote "termpid(): Terminating ${1:-} (${2:-}): $(pspid_sh "${1:-}" ||:)"
    if checkpid "${1:-}" ; then
        kill "${1:-}" 2>/dev/null
        true
    else
        return 0
    fi
    mysleep 0.1
    if checkpid "${1:-}" ; then
        mysleep 0.4
    else
        return 0
    fi
    #
    # KILL
    debugnote "termpid(): Killing ${1:-} (${2:-}): $(pspid_sh "${1:-}" ||:)"
    if checkpid "${1:-}" ; then
        kill -s KILL "${1:-}" 2>/dev/null
    fi
    mysleep 0.2
    if checkpid "${1:-}" ; then 
        note "Failed to terminate ${1:-} (${2:-}): $(pspid_sh "${1:-}" ||:)"
        return 1
    fi
    #
    return 0
}

#
# Function: waitfortheend
# Brief:  Wait for end of x11docker session
#
# Description: watch FDtimetosaygoodbye, in a loop while @code{rocknroll}
#
# return: 0 if rocknroll returned false
#
# Used-by: @code{error}
# Used-by: May appear in the file @code{cmdrc}, under /bin/sh
#
waitfortheend() {
    # signal is byte in $Timetosaygoodbyefifo
    # decent read to wait for signal to terminate
    case "$Usemkfifo" in
        yes)
            while rocknroll; do
                # Read a single character, and also call saygoodbye to
                # write into the same fifo.
                if bash -c "read -n1 <${FDtimetosaygoodbye}" ; then
                    saygoodbye timetosaygoodbyefifo
                else
                    sleep 1
                fi
            done
            ;;
        no|"") # Reading from fifo fails on Windows, workaround
            while rocknroll; do
                sleep 2
            done
            ;;
    esac
    return 0
}

#
# Function: watchpidlist
# Brief: Watch list of important pids
#
# Description:
# - Runs in the background, started by @code{setup_fifo}
# - in a while rocknroll loop
#   - reads FDwatchpid,
#   - manages the list of pids to watch
#   - checks if any watched pid has gone
#   - If gone, calls saygoodbye
#   - If rocknroll returns false, calls saygoodbye and returns.
#
watchpidlist() {
    #
    # Terminate x11docker if a PID in $Watchpidlist terminates.
    # Serves mainly watching X server, Wayland compositor, container and hostexe.
    #
    # echo PIDs to watch into >{FDwatchpid} (setonwatchpidlist())
    #
    local Pid="" local_Containername="" Line""= Watchpidlist=""
    local ListOfLines
    trap '' SIGINT

    while rocknroll; do
        # check for new Pid once a second
        read -r -t1 Pid <&${FDwatchpid} || true
        #
        if [ "$Usemkfifo" = "no" ] ; then  sleep 2 ; fi  # read does not wait if not a fifo
        #
        # Got new pid
        if [ "$Pid" ] ; then
            if [ "${Pid:0:9}" = "CONTAINER" ] ; then
                # Workaround for MS Windows where the pid cannot be watched
                local_Containername="${Pid#CONTAINER}" # remove prefix "CONTAINER"
                debugnote "watchpidlist(): Watching Container: $local_Containername"
            else
                Watchpidlist="$Watchpidlist $Pid"
                #
                ListOfLines=""
                for Line in $Watchpidlist; do
                    ListOfLines+="$(pspid_sh --empty-pid-is-FAIL "$Line" || echo "(pid $Line not found)")${NEWLINE}" ;
                done
                debugnote "watchpidlist(): Watching pids:${NEWLINE}${ListOfLines}"
            fi
        fi
        #
        # check all stored pids
        for Pid in $Watchpidlist; do
            [ -e "/proc/$Pid" ] || {
                debugnote  "watchpidlist(): PID $Pid has terminated"
                saygoodbye "watchpidlist $Pid"
            }
        done
        #
        # Container PID not watchable in MSYS2/Cygwin/WSL1.
        if [ "$local_Containername" ] ; then
            unpriv_backend "$g_Backendbin inspect '$local_Containername'" >/dev/null || {
                debugnote  "watchpidlist(): Container $local_Containername has terminated"
                saygoodbye "watchpidlist $local_Containername"
            }
        fi
    done
    saygoodbye "watchpidlist"
}

