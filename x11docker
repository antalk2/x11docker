#
# Function: parse_inspect
# Usage: parse_inspect json_string  key1 ...  keyn
# Brief: get some values from the JSON output of @code{docker inspect}
#
# Description: JSON processing uses either @code{jq} or @code{python}
#
parse_inspect() {
    # parse for keys in output of docker|podman|nerdctl inspect.
    # Uses python json parser.
    # $1 String containing inspect output
    # $2...$n Key. For second level keys provide e.g. "jsonstring" "Config" "Cmd"

    local Parserscript
    local Jsonstring Keystring Output
    local EXPR
    # shellcheck disable=SC2089 # (warning): Quotes/backslashes will be treated literally. Use an array.
    local SINGLE_QUOTE="'"

    [[ "$Jqbin" ]] && {
        # we have jq (e.g. /usr/bin/jq)
        Jsonstring="${1:-}" ; shift
        #
        # If we have an array, get the first item
        if [[ $("$Jqbin" -r 'type' <<< "$Jsonstring" 2>/dev/null) == array ]] ; then
            Keystring=".[0]"
        else
            Keystring=""
        fi
        # Recursively find key using the sequence of keys
        while [ $# -gt 0 ]; do
            Keystring="$Keystring.${1:-}"
            shift
        done
        ##
        Output="$("$Jqbin" "$Keystring" <<< "$Jsonstring")"
        #
        # If we have an array in Output, single-quote each item and join with spaces
        if [[ $("$Jqbin" -r 'type' <<< "$Output" 2>/dev/null) == array ]]; then
            EXPR="map(tostring | \"'\" + . + \"'\") | join(\" \")"
            Output="$("$Jqbin" -r "$EXPR" <<< "$Output" )"
        fi
        #
        # If we have a string, output the raw contents without quotes
        if [[ $("$Jqbin" -r 'type' <<< "$Output" 2>/dev/null) == string ]]; then
            Output="$("$Jqbin" -r '.' <<< "$Output")"
        fi
        [ "$Output" = "null" ] && Output=""
        echo "$Output"
        return
    }

    ##
    # shellcheck disable=SC2090 # (warning): Quotes/backslashes in this variable will not be respected.
    Parserscript="#! $Pythonbin$(trim_to_mark \
      '|
       |import json,sys
       |
       |def parse_inspect(*args):
       |    """
       |    parse output of docker|podman|nerdctl inspect
       |    args:
       |     0: ignored
       |     1: string containing inspect output
       |     2..n: json keys. For second level keys provide e.g. "Config","Cmd"
       |    Prints key value as a string.
       |    Prints empty string if key not found.
       |    A list is printed as a string with
       : '${SINGLE_QUOTE}${SINGLE_QUOTE}' around each element.
       |    """
       |
       |    output=""
       |    inspect=args[1]
       |    inspect=inspect.strip()
       |
       |    obj=json.loads(inspect)
       |
       |    if "'${SINGLE_QUOTE}'list'${SINGLE_QUOTE}'" in str(type(obj)):
       |        obj = obj[0]
       |
       |    # recursively find the desired object.
       |    # Command.Cmd is found with args "Command" , "Cmd"
       |    for arg in args[2:]:
       |        try:
       |            obj=obj[arg]
       |        except:
       |            obj=""
       |
       |    objtype=str(type(obj))
       |    if "'${SINGLE_QUOTE}'list'${SINGLE_QUOTE}'" in objtype:
       |        for i in obj:
       |            output += "'${SINGLE_QUOTE}'" + str(i) + "'${SINGLE_QUOTE}' "
       |        output = output.strip()
       |    else:
       |        output = str(obj)
       |
       |    if output == "None":
       |        output=""
       |
       |    print(output)
       |
       |parse_inspect(*sys.argv)
       |')"
  ## end of $'string' here
  ##
  echo "$Parserscript" \
      | $Pythonbin - "$@" \
      || warning_ttm \
             "|parse_inspect(): Error while parsing json for
              |  ${2:-} ${3:-} ${4:-} ${5:-} ${6:-} (Line ${BASH_LINENO[0]})"
  #
} # parse_inspect


# Group: storeinfo
#
# The functions storeinfo_dump_sh, storeinfo_drop_sh,
#    storeinfo_test_sh, storeinfo_add_kv_sh manage the content of
#    Storeinfofile ("~/.cache/x11docker/SUBDIR/share/store.info")
#
#    - This consists of lines in key=value  form.
#    - A key can only appear once.
#    - The Storeinfofile is shared between host and container.
#
#    - They are used under /bin/sh in cmdrc
#

# Function: storeinfo_dump_sh
#
# Usage: storeinfo_dump_sh key
# Brief: Get value for a key
#
# Argument:
#  key : string, on the left of "=" in Storeinfofile.
#        Note: used as part of a BRE for grep and sed,
#              avoid BRE special characters.
#
# stdout: Value corresponding to key. May be empty.
