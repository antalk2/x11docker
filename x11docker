#
# Function: setup_gpu
# CommandlineOption:  --gpu
#
# Brief: share /dev/dri and check nvidia driver
#
setup_gpu() {
    #
    # Easiest case: share /dev/dri.
    # Works for open source MESA drivers on host and in image.
    # Debian packages for MESA drivers in image: libgl1-mesa-dri, libglx-mesa0
    #
    # Closed source NVIDIA drivers does not integrate well within linux.
    # Instead, free nouveau driver is a better choice, or no NVIDIA hardware at all.
    # Possibilities:
    # - Install NVIDIA driver in image. It must be the very same version as on your host.
    #   The image is not portable anymore.
    # - x11docker can install NVIDIA driver on the fly in running container. See notes below.
    #
    # g  $Nvidiainstallerfile   nvidia driver file to install in container in containerrootrc
    # g  $Nvidiaversion  nvidia driver version on host

    local Gpudevice
    # unused: local Drivername

    Containerusergroups="$Containerusergroups video render"

    # share device files
    while read -r Gpudevice ; do
        store_runoption_volume "$Gpudevice"
    done < <(devicelist_gpu)

    # NVIDIA
    #
    # Check for closed source nvidia driver on host, provide automated
    # installation, warn about disadvantages
    #
    if [ -z "$Nvidiaversion" ] ; then  return 0 ; fi

    if  [ "$Runtime" = "nvidia" ] || [ -n "$Nvidiainstallerfile" ] ; then
        case "$Xserver" in
            --xorg|--hostdisplay) ;;
            *)
                note_ttm \
                    "|Option --gpu: Acceleration with NVIDIA might work
                     |  with option --xorg and option --hostdisplay only.
                     |  Though, some configuration mit allow Wayland based accelerated X servers.
                     |  Compare https://wiki.debian.org/NvidiaGraphicsDrivers#Wayland"
                #
                ;;
        esac
    fi

    if [ "$Runtime" = "nvidia" ] ; then
        debugnote "NVIDIA: Option --runtime=nvidia: Skipping driver installation."
        Nvidiainstallerfile=""
        return 0
    fi

    if [ -e "$Nvidiainstallerfile" ] ; then
        debugnote_ttm \
            "|NVIDIA: Found proprietary closed source NVIDIA driver installer
             |  $Nvidiainstallerfile"
        #
        if [ "$Containersetup" = "no" ] ; then
            note_ttm \
                "|Options --no-setup --gpu: Cannot install NVIDIA driver
                 |  with option --no-setup. Fallback: Disabling option --gpu"
            #
            check_fallback
            Sharegpu="no"
            return 1
        fi
        
        if [ "$Capdropall" = "yes" ] ; then
            warning_ttm \
                "|Option --gpu: Installing NVIDIA driver in container
                 |  requires container privileges that x11docker would drop otherwise.
                 |  Though, they are still within default docker capabilities."
        fi

        Allownewprivileges="yes"
        store_runoption_cap CHOWN
        store_runoption_cap FOWNER

        note_ttm \
            "|Option --gpu: x11docker will install NVIDIA driver in container.
             |  You can provide images with pre-installed drivers to speed up
             : container start.
             |  Compare: https://github.com/mviereck/x11docker/wiki/NVIDIA-dr
             :iver-support-for-docker-container"
        #

        if [ "$Xcontainer_option" = "yes" ] ; then

            waitforlogentry_sh "start_xcontainer()"          \
                               "$Xinitlogfile"               \
                               "X server container is ready" \
                || return 1
            
            note "Option --gpu: Installing NVIDIA driver in X container."

            unpriv_xcbackend                 \
                "$(trim_to_mark              \
                  "|$Xcontainerbackend exec
                   : --tty --privileged
                   : --user=root
                   : $Xcontainername
                   : bash $Sharefolder/nvidia_installer"
                   )"                       \
                   >> "$Xinitlogfile" 2>&1  \
                   || note 'ERROR: NVIDIA driver installation in X container failed.'
        fi
        return 0
    fi

    Nvidiainstallerfile=""

    note_ttm  \
        "|Option --gpu: You are using the closed source NVIDIA driver.
         |  GPU acceleration will only work if you have installed the very same driver
         |  version in image. That makes images less portable.
         |  It is recommended to use free open source nouveau driver on host instead.
         |  Ask NVIDIA corporation to at least publish their closed source API,
         |  or even better to actively support open source driver nouveau.
         |
         |  To use the GPU without NVIDIA driver in container, you can use 
         |  less performant option --gpu=iglx (--xorg only)."
    #
           
    note_ttm \
        "|Option --gpu: x11docker can try to automatically install NVIDIA driver
         |  version $Nvidiaversion in container on every container startup.
         |  Drawbacks: Container startup is a bit slower and its security will be reduced.
         |
         |  You can look here for a driver installer file:
         |    https://www.nvidia.com/Download/index.aspx
         |    https://http.download.nvidia.com/
         |  A direct download URL is probably:
         |    https://http.download.nvidia.com/XFree86/Linux-x86_64/
         :$Nvidiaversion/NVIDIA-Linux-x86_64-$Nvidiaversion.run
         |  If you got a driver, store it at one of the following locations:
         |    $Localsharedir/
         |    /usr/local/share/x11docker/
         |
         |  Be aware that the version number must match exactly the version on host.
         |  The file name must begin with 'NVIDIA',
         : contain the version number $Nvidiaversion
         |  and end with suffix '.run'."
    #
    return 0
}

#
# Function setup_hostdbus
# CommandlineOption: --hostdbus
#
# Brief: Connect to host DBus session daemon.
#
setup_hostdbus() {

    warning_ttm \
        "|Option --hostdbus: Connecting container to host DBus degrades
         |  container isolation. Container applications might send malicious requests."
    #

    Dbusrunsession="no"

    if [ -z "$DBUS_SESSION_BUS_ADDRESS" ] ; then
        # no running DBus session?
        if have_command  dbus-launch  ; then
            note_ttm \
                 "|Option --hostdbus: DBUS_SESSION_BUS_ADDRESS is empty.
                  |  Creating abstract DBus socket with dbus-launch."
            #
            # shellcheck disable=SC2046 # (warning): Quote this to prevent word splitting.
            #
            # dbus-launch prints something like this:
            # ----
            # BUS_SESSION_BUS_ADDRESS=unix:path=/tmp/dbus-VkoZJLt5tw,guid=b7d98da083a765f5550aced26a3fec3c
            # DBUS_SESSION_BUS_PID=1911329
            # DBUS_SESSION_BUS_WINDOWID=65011713
            # ----
            # We do need word splitting for the assignments to occur individually.
            #
            export $(dbus-launch)
        else
            note_ttm \
                "|Option --hostdbus: Is DBus running on host?
                 |  Did not find an active session and did not find dbus-launch.
                 |  DBUS_SESSION_BUS_ADDRESS is empty.
                 |  $Wikipackages"
            check_fallback
            return 1
        fi
    fi

    if grep -q "unix:path" <<< "$DBUS_SESSION_BUS_ADDRESS" ; then
        # DBus socket file
        case "$Runtime" in
            kata-runtime)
                note "$(trim_to_bar \
                      "|Option --hostdbus with a unix socket is not possible
                       |  with --runtime=$Runtime."
                       )"
                check_fallback
                return 1
                ;;
            *)
                store_runoption_env "DBUS_SESSION_BUS_ADDRESS=$DBUS_SESSION_BUS_ADDRESS"
                #
                # For some reason we do not cut "unix:path=/run/user/1000/bus" at '=',
                # but at the first "/", which we lose in cut, and reinsert after.
                #
                store_runoption_volume "/$( cut -d/ -f2- <<<"$DBUS_SESSION_BUS_ADDRESS" )"
                ;;
        esac
    fi

    if grep -q "unix:abstract" <<< "$DBUS_SESSION_BUS_ADDRESS" ; then
        #
        # DBus abstract socket (dbus-launch)
        store_runoption_env "DBUS_SESSION_BUS_ADDRESS=$DBUS_SESSION_BUS_ADDRESS"
        #
        if [ -n "${DBUS_SESSION_BUS_PID:-}"      ] ; then
            store_runoption_env  "${DBUS_SESSION_BUS_PID:-}"
        fi
        #
        if [ -n "${DBUS_SESSION_BUS_WINDOWID:-}" ] ; then
            store_runoption_env  "${DBUS_SESSION_BUS_WINDOWID:-}"
        fi
        
        if [ "$g_Network" != "host" ] ; then  # g_Network_host
            note_ttm \
                "|Option --hostdbus: Did not find a DBus session socket file
                 |  but an abstract unix socket. To allow access for container,
                 |  x11docker needs insecure option '--network=host'.
                 |  Sharing host dbus will fail."
            check_fallback
            return 1
        fi
    fi
    return 0
} # setup_hostdbus

#
# Function setup_printer
# CommandlineOption: --printer
# Brief: Connect to cups printer server
#
setup_printer() {
    #
    # - Default CUPS setups create a unix socket /run/cups/cups.sock
    #   as given from 'lpstat -H'.
    #
    # - Sharing this socket and pointing environment variable
    #   CUPS_SERVER to it serves most cases.
    #
    # - Possible CUPS network setups need to allow access from
    #   container, see note below.
    #
    local Cupsserver=

    if ! have_command  lpstat ; then
        note_ttm \
            "|Option --printer: command lpstat not found.
             |  Is cups printer server installed on your system?
             |  Error: Cannot share access to printer."
        Sharecupsmode=""
        return 1
    fi

    case "$Sharecupsmode" in
        auto)
            Sharecupsmode="socket"
            if [ "$Snapsupport" = "yes"      ] ; then Sharecupsmode="tcp" ; fi
            if [ "$Runtime" = "kata-runtime" ] ; then Sharecupsmode="tcp" ; fi
            #if [ "$Runtime" = "sysbox-runc" ] ; then Sharecupsmode="tcp" ; fi
            ;;
    esac

    case "$Sharecupsmode" in
        tcp)
            Cupsserver="$Hostip:631"
            if [ "$g_Network" = "none" ] ; then
                note_ttm \
                    "|Option --printer=tcp does not work without network access.
                     |  Consider to enable option -I, --network."
                check_fallback
                return 1
            fi
            ;;
        socket)
            Cupsserver="$(lpstat -H)" # e.g. /run/cups/cups.sock
            ;;
    esac

    #
    # Why not `if [ "$Sharecupsmode" = tcp ] ; then`
    #
    if grep -q ":" <<< "$Cupsserver" ; then
        #
        # "localhost:631" -> "$Hostip:631"
        #
        case  "$(cut -d: -f1 <<< "$Cupsserver")" in
            "localhost"|"127.0.0.1")
                Cupsserver="$Hostip:$(cut -d: -f2 <<< "$Cupsserver")"
                ;;
        esac
        #
        note_ttm \
            "|Option --printer: Network setup for CUPS detected.
             |  Server address: $Cupsserver
             |  You may need to allow container access in /etc/cups/cupsd.conf, e.g.:
             |
             |Port 631
             |<Location />
             |  # Allow remote access...
             |  Order allow,deny
             |  Allow 172.17.0.*
             |  Allow 172.20.0.*
             |  Allow 127.0.0.1
             |</Location>
             |
             |Also you need to allow network access for each printer in a CUPS GUI."
        #
    fi

    if [ -n "$Cupsserver" ] ; then
        store_runoption_env "CUPS_SERVER=$Cupsserver"
    fi

    if [ -e "$Cupsserver" ] ; then
        # ^ It is a file-system (non--abstract) socket
        #
        if [ "$(dirname "$Cupsserver")" = "/run/cups" ]
        then store_runoption_volume "/run/cups"   # share "/run/cups"
        else store_runoption_volume "$Cupsserver" # Only share the socket
        fi
    fi

  return 0
}

#
# function setup_sound_alsa() : option --alsa: share sound devices
#
setup_sound_alsa() {
    #
    # Sound with ALSA is directly supported by the kernel and only
    # needs to share devices in /dev/snd.
    #
    # libasound2 in image is recommended.
    #
    # The desired sound card can be specified with environment
    # variable ALSA_CARD. See card name in 'aplay -l'.
    #
    # Further documentation at
    # https://github.com/mviereck/x11docker/wiki/Container-sound:-ALSA-or-Pulseaudio

    warning_ttm \
        "|Option --alsa: ALSA sound degrades container isolation.
         |Sharing device files in /dev/snd, container gains access to sound hardware.
         |Container applications can catch audio output and microphone input."
    #

    if [ "$Alsacard" ] ; then store_runoption_env "ALSA_CARD=$Alsacard" ; fi

    if pgrep pulseaudio >/dev/null ; then
        note_ttm \
            "|Option --alsa: It seems that pulseaudio is running
             |  on your host. Pulseaudio can interfere with ALSA sound.
             |  Host sound may not work while container is playing sound and vice versa.
             |  Alternative: with pulseaudio on host and in image, use option --pulseaudio."
    fi

    if [ -d /dev/snd ] ; then
        store_runoption_volume "/dev/snd"
     else
         warning_ttm \
             "|Option --alsa: /dev/snd not found.
              |  Sound support not possible."
         #
         check_fallback
         Sharealsa="no"
         return 1
    fi

    Containerusergroups="$Containerusergroups audio"

  return 0
}

#
# Function: setup_sound_pipewire
# CommandlineOption:  --pipewire
#
# Brief: pipewire sound in container
#
setup_sound_pipewire() {

    local Pipewiresocket Pipewirescript

    have_command  pw-container  || {
        note_ttm "|Option --pipewire: Command pw-container not found.
                  |  Is pipewire installed on your system?
                  |  Fallback: Disabling option --pipewire
                  |  You can try options --pulseaudio or --alsa instead."
        #
        check_fallback
        Sharepipewire="no"
        return 1
    }

    warning_ttm \
        "|Option --pipewire allows container applications
         |  to catch your audio output and microphone input."
    #

    # Create and share restricted pipewire socket
    Pipewirescript="$Cachefolder/pw-script"
    trim_to_bar \
        "|#! /bin/bash
         |# Helper script to get socket path.
         |# Reading output of pw-container directly somehow not possible.
         |
         |echo \$PIPEWIRE_REMOTE >$Cachefolder/PIPEWIRE_REMOTE
         |while :; do
         |  sleep 1000
         |done
         |" >"$Pipewirescript"

    unpriv "pw-container 'bash $Pipewirescript'" &
    storepid $! "pw-container"

    Pipewiresocket="$(cat "$Cachefolder/PIPEWIRE_REMOTE")"
    Pipewiresocket="/$(echo "$Pipewiresocket" | cut -d/ -f2-)"
    store_runoption_env "PIPEWIRE_REMOTE=$Pipewiresocket"
    store_runoption_volume "$Pipewiresocket"

    # Share pulseaudio socket created by pipewire
    if have_command pactl  ; then
        Pipewirepulseaudiosocket="$(unpriv "env LC_ALL=C pactl info" 2>/dev/null)"
        Pipewirepulseaudiosocket="/$(grep "Server String" <<< "$Pipewirepulseaudiosocket" | cut -d/ -f2-)"
        if [ -z "$Pipewirepulseaudiosocket" ] ; then
            if [ -e "/run/user/$Hostuseruid/pulse/native" ] ; then
                Pipewirepulseaudiosocket="/run/user/$Hostuseruid/pulse/native"
            fi
        fi
    fi

    if [ -z "$Pipewirepulseaudiosocket" ] ; then
        note_ttm "|Option --pipewire: Did not find pulseaudio socket.
                  |  Are 'pipewire-module-pulse' and 'pactl' installed?
                  |  Fallback: Not sharing pipewire pulseaudio scoket."
    fi
}

# Function: setup_sound_pulseaudio
# CommandlineOption:  --pulseaudio
#
# Brief: set up pulseaudio connection
#
setup_sound_pulseaudio() {
    #
    # Allowing container access to Pulseaudio on host can be done with
    # a shared socket or over TCP.
    #
    # Sharing host user socket in XDG_RUNTIME_DIR fails since
    # Pulseaudio v12.0.
    #
    # Instead, a new socket is created with pactl.
    #
    # TCP module is created after container startup to authenticate it
    # with container IP.
    #
    # Detailed documentation at:
    # https://github.com/mviereck/x11docker/wiki/Container-sound:-ALSA-or-Pulseaudio
    #
    # g $Pulseaudiomode =tcp or =socket or =host: Connect over tcp or
    #                                             with shared socket
    #
    # g  $Pulseaudioport    TCP port
    #
    local Lowerport=""
    local Upperport=""
    local Setcookie=""

    if ! have_command pactl ; then
        note_ttm "|Option --pulseaudio: pactl not found.
                  |  Is pulseaudio installed and running on your host system?
                  |  Fallback: Disabling option --pulseaudio.
                  |  You can try options --pipewire or --alsa instead."
        check_fallback
        Pulseaudiomode=""
        return 1
    fi

    if [ -z "$Pulseaudiomode" ] ; then
        Pulseaudiomode="socket"
    fi

    if [ "$Pulseaudiomode" = "auto" ] ; then
        Pulseaudiomode="socket"
        #
        # Adjust, only if "auto"
        #
        if    [ "$g_Containerusername" != "$Hostuser" ] \
           || [ "$Runtime" = "kata-runtime" ]     \
           || [ "$Runtime" = "sysbox-runc" ]      \
           || [ "$Snapsupport" = "yes" ]          \
           ||  unpriv 'LC_ALL=C pactl info | grep -q "User Name: pulse"' \
           ;
        then
            Pulseaudiomode="tcp"
        fi
        #
        if [ "$Pulseaudiomode" = "tcp" ] ; then
            note "Option --pulseaudio: Enabling TCP mode"
        fi
    fi

    if [ "$Pulseaudiomode" = "tcp" ] && [ "$g_Network" = "none" ] ; then
        note_ttm \
            "|Option --pulseaudio: Without option -I, --network
             |  pulseaudio sound over TCP is not possible but needed in your setup.
             |  Fallback: Disabling option --pulseaudio."
        #
        Pulseaudiomode=""
        check_fallback
        return 1
    fi

    warning_ttm \
        "|Option --pulseaudio allows container applications
         |  to catch your audio output and microphone input."
    #

    case "$Pulseaudiomode" in
        socket|tcp)
            if grep -q -i "PipeWire" <<< "$(unpriv "pactl info")" ; then
                note_ttm \
                    "|Option --pulseaudio: Found pipewire sound server.
                     |  If pulseaudio sound fails, you can try
                     |  --pipewire, --pulseaudio=tcp or --pulseaudio=host instead."
            fi
            ;;
    esac

    case "$Pulseaudiomode" in
        socket)
            # Create pulseaudio socket
            Pulseaudiomoduleid="$(
                unpriv "$(
                    trim_to_mark "|pactl load-module
                                  : module-native-protocol-unix
                                  : socket='$Pulseaudiosocket' 2>&1 ||:"
                )"
            )"
            # Pulseaudiomoduleid="$(
            #   unpriv "pactl load-module libpipewire-module-protocol-native socket='$Pulseaudiosocket' 2>&1 ||:"
            # )" # fails with pipewire

            if isint "$Pulseaudiomoduleid" ; then
                storeinfo_add_kv_sh "pulseaudiomoduleid=$Pulseaudiomoduleid"
                store_runoption_env "PULSE_SERVER=unix:$(convertpath share "$Pulseaudiosocket")"
                Setcookie="yes"
            else
                note_ttm \
                    "|Option --pulseaudio: command pactl failed with output:
                     |  '$Pulseaudiomoduleid'
                     |  Is pulseaudio running at all on your host?
                     |  Fallback: Disabling option --pulseaudio.
                     |  You can try options --pipewire or --alsa instead."
                check_fallback
                Pulseaudiomode=""
                return 1
            fi

            trim_to_bar \
                "|# Connect to host pulseaudio server using mounted UNIX socket
                 |default-server = unix:$(convertpath share "$Pulseaudiosocket")
                 |# Prevent a server running in container
                 |autospawn = no
                 |daemon-binary = /bin/true
                 |# Prevent use of shared memory
                 |enable-shm = false
                 |" >> "$Pulseaudioconf"
            verbose "Generated pulseaudio client.conf:${NEWLINE}$(nl -ba < "$Pulseaudioconf")"
            ;;

        tcp)
            read -r Lowerport Upperport < /proc/sys/net/ipv4/ip_local_port_range 2>/dev/null
            [ "$Lowerport" ] || Lowerport=33000
            [ "$Upperport" ] || Upperport=60000
            while : ; do
                # Choose a random port number
                Pulseaudioport="$(shuf -i "${Lowerport}-${Upperport}" -n1)"
                # Break if the port number is not in use
                ss -lpn | grep -q ":$Pulseaudioport " || break
            done

            if [ -e "$Hostuserhome/.config/pulse/cookie" ] ; then
                cp "$Hostuserhome/.config/pulse/cookie" "$Pulseaudiocookie"
            else
                note_ttm "|Option --pulseaudio: Did not find cookie
                          |  $Hostuserhome/.config/pulse/cookie"
            fi

            store_runoption_env "PULSE_SERVER=tcp:$Hostip:$Pulseaudioport"
            Setcookie="yes"
            ;;

        host)
            Pulseaudiosocket="$(
                unpriv "env LC_ALL=C pactl info" \
                | grep 'Server String'           \
                | rev_cut -d' ' -f1
            )"
            store_runoption_env "PULSE_SERVER=unix:/tmp/pulseaudio.socket.host"
            Setcookie="yes"
            ;;
    esac # "$Pulseaudiomode"

    if [ "$Setcookie" = "yes" ] ; then
        if [ -e "$Hostuserhome/.config/pulse/cookie" ] ; then
            cp  "$Hostuserhome/.config/pulse/cookie" "$Pulseaudiocookie"
            store_runoption_env "PULSE_COOKIE=$(convertpath share "$Pulseaudiocookie")"
        else
            note_ttm "|Option --pulseaudio: Did not find cookie
                      |  $Hostuserhome/.config/pulse/cookie"
        fi
  fi

  return 0
} # setup_sound_pulseaudio()

#
# Function setup_vaapi
# CommandlineOption:  --gpu
#
# Brief: setup for VAAPI and VDPAU video decoding acceleration
#
setup_vaapi() {
    local Line

    # Support for prime-run / discrete NVIDIA card #394
    if [ -n "$__NV_PRIME_RENDER_OFFLOAD" ] ; then
        DRI_PRIME="1"
        store_runoption_env "__NV_PRIME_RENDER_OFFLOAD=$__NV_PRIME_RENDER_OFFLOAD"
    fi
    if [ -n "$__VK_LAYER_NV_optimus" ] ; then
        DRI_PRIME="1"
        store_runoption_env "__VK_LAYER_NV_optimus=$__VK_LAYER_NV_optimus"
    fi
    if [ -n "$__GLX_VENDOR_LIBRARY_NAME" ] ; then
        DRI_PRIME="1"
        store_runoption_env "__GLX_VENDOR_LIBRARY_NAME=$__GLX_VENDOR_LIBRARY_NAME"
    fi


    # VA-API and VDPAU #443
    # Infos at https://wiki.archlinux.org/title/Hardware_video_acceleration

    # Check VA-API driver on host
    if [ -z "${LIBVA_DRIVER_NAME:-}" ] ; then
        #
        # `vainfo 2>&1` includes
        # "libva info: Trying to open /usr/lib/x86_64-linux-gnu/dri/i965_drv_video.so"
        # We want to extract the "i965" part.
        #
        # LIBVA_DRIVER_NAME="$(xtool "vainfo 2>&1 | grep drv_video.so | rev_cut -d/ -f1 " || : )"
        # LIBVA_DRIVER_NAME="${LIBVA_DRIVER_NAME%"_drv_video.so"}"
        #
        Line="$(xtool "vainfo 2>&1 | grep drv_video.so " || : )"
        LIBVA_DRIVER_NAME="$( basename "${Line}" "_drv_video.so" )"
    fi

    # Guess driver (LIBVA_DRIVER_NAME) based on kernel modules if
    #       vainfo is not available
    #
    # FIXME: Are we looking into the 'Kernel modules:' lines for the
    #        *driver* name? Or we are looking into the 'Kernel driver in use:'
    #        lines?
    #
    if [ -z "$LIBVA_DRIVER_NAME" ] ; then
        if   lspci -k | grep -q -e amdgpu -e radeon ; then
            LIBVA_DRIVER_NAME="${LIBVA_DRIVER_NAME:-radeonsi}"
        elif lspci -k | grep -q nouveau           ; then
            LIBVA_DRIVER_NAME="${LIBVA_DRIVER_NAME:-nouveau}"
        elif lspci -k | grep -q nvidia            ; then
            LIBVA_DRIVER_NAME="${LIBVA_DRIVER_NAME:-nvidia}"
            #
            note_ttm \
                "|Option --gpu: Enabling VA-API video decoding support
                 |  with NVIDIA NVDECODE. If you want to use NVIDIA VDPAU instead,
                 |  please run x11docker with '--env LIBVA_DRIVER_NAME=vdpau'
                 |  or set the variable globally with 'export LIBVA_DRIVER_NAME=vdpau'."
            #
        elif lspci -k | grep -q i915 &&  [ -z "${DRI_PRIME:-}" ] ; then
            LIBVA_DRIVER_NAME="${LIBVA_DRIVER_NAME:-i965}"
            note_ttm \
                "|Option --gpu: Enabling VA-API intel driver i965.
                 |  If you want to use the newer iHD intel driver instead,
                 |  please run x11docker with '--env LIBVA_DRIVER_NAME=iHD'
                 |  or set the variable globally with 'export LIBVA_DRIVER_NAME=iHD'."
        fi
    fi

    case "${LIBVA_DRIVER_NAME:-}" in
        radeonsi|r600) VDPAU_DRIVER="${VDPAU_DRIVER:-radeonsi}" ;;
        i965|iHD)      VDPAU_DRIVER="${VDPAU_DRIVER:-va_gl}"    ;;
        nouveau)       VDPAU_DRIVER="${VDPAU_DRIVER:-nouveau}"  ;;
        nvidia|vdpau)  VDPAU_DRIVER="${VDPAU_DRIVER:-nvidia}"   ;;
        "")
            note_ttm \
                "|Option --gpu: Could not estimate drivers for VA-API and VDPAU
                 |  video decoding acceleration support. This will likely fail in container."
            ;;
    esac

    # Save the results using store_runoption_env
    if [ -n "${LIBVA_DRIVER_NAME:-}" ] ; then
        store_runoption_env "LIBVA_DRIVER_NAME=${LIBVA_DRIVER_NAME}"
    fi
    if [ -n "${VDPAU_DRIVER:-}" ] ; then
        store_runoption_env "VDPAU_DRIVER=${VDPAU_DRIVER}"
    fi
    if [ -n "${DRI_PRIME:-}" ] ; then
        store_runoption_env "DRI_PRIME=${DRI_PRIME}"
    fi

    return 0
}

# Function: setup_webcam
# CommandlineOption: --webcam
# Brief: share webcam devices
setup_webcam() {
    # Webcam devices appear as /dev/video* files.
    # Unprivileged users need to be in group video.
    # (This works only if webcam is plugged in before container starts.
    # Hotplug support would have to be different.)
    local Webcamdevice

    if [ "$Sharewebcam" = "yes" ] ; then
        warning_ttm \
            "|Option --webcam: Container applications might look
             |  at you and also might take screenshots of your Desktop."
    fi

    while read -r Webcamdevice ; do
        store_runoption_volume "$Webcamdevice"
    done < <(  find /dev/video* -maxdepth 0 2>/dev/null \
                   || note_ttm "|Option --webcam: No webcam devices /dev/video* found.
                                |  Webcam in container will fail."
            )

    Containerusergroups="$Containerusergroups video"

    # At least cheese and gnome-ring need some device information from udev.
    store_runoption_volume "/run/udev/data:ro"
    return 0
}

