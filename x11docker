  Cookie="$(xauth -n -i -f "${XAUTHORITY:-}" nlist "$DISPLAY" 2>/dev/null | sed -e "s/^..../ffff/")"
  echo "$Cookie" | xauth -n -i -f "$HOME/Xauthority.host" nmerge -
  truncate -s0 "${XAUTHORITY:-}"
  cat "$HOME/Xauthority.host" >> "${XAUTHORITY:-}"
}
