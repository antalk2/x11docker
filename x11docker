# Group: special_jobs_of_x11docker
#
# Function: buildimage
# Usage: buildimage  Imagename
# Brief: Build image from x11docker repository Dockerfile
#
# CommandlineOption: --build: build image from x11docker repository Dockerfile
#
buildimage() {
    # Build image $1 from x11docker repository
    #
    local Wwwpath Buildpath local_Imagename  flat_Imagename
    #
    # Check image name, prepend 'x11docker/' is missing
    local_Imagename="${1:-}"
    if ! grep -q "x11docker" <<< "$local_Imagename" ; then
        local_Imagename="x11docker/$local_Imagename"
    fi
    flat_Imagename="$(tr / - <<< "$local_Imagename")"
    #
    # remote and local paths
    #
    Wwwpath="https://raw.githubusercontent.com/mviereck/dockerfile-${flat_Imagename}/master"
    Buildpath="${HOME:-/tmp}/x11docker-build-$(unspecialstring "$local_Imagename")"
    #
    # How could this fail? We have just injected "dockerfile-" and "x11docker-".
    # Well, assume "$1" was "xxx-x11docker". Then we did not prepend "x11docker/",
    # and ended up with "[...]dockerfile-xxx-x11docker[...]"
    #
    if ! grep -q  "dockerfile-x11docker-" <<< "$Wwwpath" ; then
        error_ttm  \
            "|Option --build: x11docker only supports building of
             |  images provided at x11docker repository https://github.com/mviereck"
    fi
    #
    mkdir -p "$Buildpath"
    cd "$Buildpath" || error "Could not cd to Buildpath"

    if ! download ; then
        error "Option --build: Please install 'curl' or 'wget' to allow a download"
    fi
    #
    note "Download of $Wwwpath/Dockerfile"
    if ! download "$Wwwpath/Dockerfile" "$Buildpath/Dockerfile"  ; then
        error_ttm \
               "|Option --build: Did not find a Dockerfile for $local_Imagename
                |  at $Wwwpath
                |  Option --build only supports Dockerfiles from https://github.com/mviereck.
                |  For other sources please download Dockerfile and use 'docker build'."
    fi
    #
    if [ "$local_Imagename" = "x11docker/xserver" ] ; then
        note "Download of $Wwwpath/XlibNoSHM.c"
        if ! download "$Wwwpath/XlibNoSHM.c" "$Buildpath/XlibNoSHM.c"  ; then
            error "Option --build: Downloading XlibNoSHM.c failed."
        fi
    fi
    #
    note "Building $local_Imagename"
    if ! unpriv_backend "$g_Backendbin build -t $local_Imagename $Buildpath" ; then
        error "Option --build: Building image '$local_Imagename' failed."
    fi
    #
    cd "${HOME:-/tmp}"  || error "Could not cd to HOME or /tmp"
    rm -rf "$Buildpath"
    return 0
}

# Function: cleanup
# Usage: cleanup
# CommandlineOption: --cleanup
#
# Brief: Check for non-removed containers and left cache files.
#
# - Cleans x11docker cache and removes running and stopped x11docker
#   containers.
# - Does not change --home folders.
#
cleanup() {
    
    local Orphanedcontainers=""
    local Orphanedfolders=""
    local Line=""
    local Containerinspect Containerid

    # global g_BackendKind
    note_ttm \
        "|x11docker will check for orphaned containers from earlier sessions
         |  for current --backend=$g_BackendKind
         |  This can happen if docker was not closed successfully.
         |  x11docker will look for those containers and will clean up x11docker cache.
         |  Caution: any currently running x11docker sessions will be terminated, too."

    # global Cachebasefolder
    cd "$Cachebasefolder" || error "Could not cd to cache folder '$Cachebasefolder'."

    # get Orphanedfolders
    if grep -q -- "\.cache/x11docker" <<< "$Cachebasefolder" ; then
        Orphanedfolders="$(
            find "$Cachebasefolder" \
                  -mindepth 1       \
                  -maxdepth 1       \
                  -type d           \
            | sed "s%$Cachebasefolder/%%"
        )"
    fi

    # get Orphanedcontainers
    case "$g_BackendKind" in
        docker|podman|nerdctl)
            #
            # Container names from "docker ps -a"
            Orphanedcontainers="$(
                 unpriv_backend "$g_Backendbin ps -a"  \
                 | grep x11docker_X                  \
                 | rev_cut -d' ' -f1
            )"
            #
            # Make Orphanedcontainers  space-separated
            #
            # shellcheck disable=SC2086 # (info): Double quote to
            # prevent globbing and word splitting. We do want word splitting here.
            #
            Orphanedcontainers="$(env IFS='' echo $Orphanedcontainers)"

            # check for double entries name/id, check for already non-existing containers
            for Line in $Orphanedcontainers; do
                #
                Containerinspect="$(unpriv_backend "$g_Backendbin inspect '$Line'" 2>/dev/null)"
                if [ -n "$Containerinspect" ] ; then
                    # Get longHexId
                    Containerid="$(parse_inspect "$Containerinspect" "Id")"
                    #
                    # Replace the original identifier with the longHexId in Orphanedcontainers
                    # shellcheck disable=SC2001 # (style): See if you can use ${variable//search/replace} instead.
                    Orphanedcontainers="$(sed "s%$Line%$Containerid%" <<< "$Orphanedcontainers")"
                    true
                else
                    # Remove original identifier from Orphanedcontainers
                    # shellcheck disable=SC2001 # (style): See if you can use ${variable//search/replace} instead.
                    Orphanedcontainers="$(sed "s/$Line//" <<< "$Orphanedcontainers")"
                fi
            done
            Orphanedcontainers="$(sort <<< "$Orphanedcontainers" | uniq)"
            ;;
    esac

    if [ -z "$Orphanedcontainers$Orphanedfolders" ] ; then
        note "No orphaned containers or cache files found. good luck!"
    else
        note "Found orphaned containers:${NEWLINE}$Orphanedcontainers"
        note "Found orphaned folders in $Cachebasefolder:${NEWLINE}$Orphanedfolders"

        for Line in $Orphanedfolders ; do
            if     [   -d "$Cachebasefolder/$Line/share"                  ] \
                && [ ! -s "$Cachebasefolder/$Line/share/timetosaygoodbye" ] ; then
                #
                note_ttm  \
                    "|Found possibly active container for cache dir $Line.
                     |  Will summon it to terminate itself."
                #
                echo timetosaygoodbye >> "$Cachebasefolder/$Line/share/timetosaygoodbye"
            fi
        done

        if [ -n "$Orphanedfolders" ] ; then
            sleep 3
        fi

        if [ -n "$Orphanedcontainers" ] ; then
            note "Removing containers with: $g_Backendbin rm -f $Orphanedcontainers"
            unpriv_backend "$g_Backendbin rm -f $Orphanedcontainers" 2>&1
        fi

        if [ -n "$Orphanedfolders" ] ; then
            note "Removing cache files with: rm -R -f $Orphanedfolders"
            #
            # shellcheck disable=SC2086 # (info): Double quote to
            #      prevent globbing and word splitting.
            #      Word splitting is ecpected here.
            rm -R -f $Orphanedfolders 2>&1
        fi
    fi

    # remove internal networks
    case "$g_BackendKind" in
        docker|podman|nerdctl)
            for Line in $(unpriv_backend "$g_Backendbin network ls" | grep x11docker_X); do
                note "Removing internal network $Line"
                unpriv_backend "$g_Backendbin network rm $(awk '{print $1}' <<< "$Line")"
            done
            ;;
    esac

    Logfile=""

    note "Removing remaining files with: rm -Rf -v \"$Cachebasefolder\"/*"
    rm -Rf -v "${Cachebasefolder:-NONSENSE}"/*

    note "Removing cache base folder with: rmdir -v \"$Cachebasefolder\""
    cd  || error "cd (without argument) failed"  # Leave Cachebasefolder

    if [ "$(basename "$Cachebasefolder")" = x11docker ] ; then
        rmdir -v "$Cachebasefolder"
    else
        warning_ttm \
            "|Did not succeed in removing cache folder
             |  '$Cachebasefolder'
             |  Please run 'x11docker --cleanup' as root."
    fi

    case "$g_BackendKind" in
        docker)
            if ! unpriv_backend "$g_Backendbin info" >/dev/null 2>/dev/null ; then
                warning_ttm \
                    "|Could not check for $g_BackendKind containers.
                     |  Please run 'x11docker --cleanup' as root
                     |  to make sure that no orphaned containers are left."
            fi
            ;;
    esac

    note "Cleanup ready."
}


# Function: create_launcher
# Usage: create_launcher
#
# CommandlineOption: --launcher
# Brief: Create application launcher on desktop
#
create_launcher() {
    local Name=""
    local cleaned_Name=""
    local Parsedoptions_in_line
    local commandline

    if ! have_command  xdg-desktop-icon ; then
        error_ttm \
            "|Command 'xdg-desktop-icon' not found.
             |  x11docker needs it to place the new icon on your desktop.
             |  Please install xdg-utils"
    fi

    note_ttm "|Will create a new application launcher icon on your desktop.
              |  If you move the new file to:
              |
              |    $Hostuserhome/.local/share/applications
              |
              |  it will appear in your applications menu."

    Name="$Codename"
    [ "$Codename" = "xonly" ] && Name="$( echo "$Xserver" | tr -d '-' )"
    Name="${Name% }"

    # -r   do not allow backslashes to escape any characters
    # -e   use Readline to obtain the line
    # -p   PROMPT
    # -i   initial_text
    #
    read -re                                                                \
         -p "Please choose a name for your application launcher:${NEWLINE}" \
         -i "$Name"                                                         \
         Name
  
    if [ -z "$Name" ] ; then
        # Abort on empty answer (?)
        return 1 ### FIXME: check for valid file name / invalid chars?
    fi

    cleaned_Name="$(echo "$Name" | tr -c '[:alpha:][:digit:][:blank:]' ' ' )"
    
    # Remove our options from the command line.
    # The rest will be used when launching.
    #
    Parsedoptions_global="${Parsedoptions_global//--launcher/}"
    Parsedoptions_global="${Parsedoptions_global//--starter/}"

    Parsedoptions_in_line="$( echo "${Parsedoptions_global}" | tr "\n" " " )"
    commandline="x11docker $Parsedoptions_in_line"
    if [ -z "$(command -v x11docker)" ] ; then
        # x11docker not in path. Use $0 instead.
        commandline="$(myrealpath "$0") $Parsedoptions_in_line"
    fi
    
    mkfile "$Cachefolder/$Name.desktop"
    {
        trim_to_bar \
            "|#!/usr/bin/xdg-open
             |[Desktop Entry]
             |# x11docker desktop file
             |Type=Application
             |Name=$Name
             |Exec=$commandline
             |Icon=x11docker
             |Comment=
             |Categories=System
             |Keywords=docker x11docker ${cleaned_Name}
             |TryExec=$commandline
             |"
    } >> "$Cachefolder/$Name.desktop"

    # Install on the desktop of the current user.
    unpriv "xdg-desktop-icon install --novendor '$Cachefolder/$Name.desktop'"
}

# Function: CHANGELOG_md_get_Releaseversion
# Usage: CHANGELOG_md_get_Releaseversion CHANGELOG_md
# Argument:
#   CHANGELOG_md : path to downloaded "CHANGELOG.md"
#
# Brief: Get version of the latest release from downloaded "CHANGELOG.md"
#
CHANGELOG_md_get_Releaseversion() {
    local CHANGELOG_md="$1"
    #
    # Release lines look like this:
    #
    # "## [7.8.0](https://github.com/mviereck/x11docker/releases/tag/v7.8.0) - 2026-01-17"
    #
    #  They are in latest-first order, but there may be a line like:
    # "## [Unreleased]"
    #  We want to ignore that.
    #
    local release_line_ERE='^## \[([^]]+)\].*' # relaxed version, only assumes
    #   that the version number does not contain ']'
    #   Will yield the version number as \\1
    #
    # A stricter version could be:
    # release_line_ERE='^## \[([0-9.]+)\]\([^)]+\)[ -]+([0-9-]+).*$'
    #                          \\1 : version_number
    #                                      \\2 URL to download from
    #                                                  \\3 release date
    #
    # shellcheck disable=SC2002 # (style): Useless cat.
    Releaseversion="v$(
                       cat "${CHANGELOG_md}"                \
                       | grep -E -e  "${release_line_ERE}"  \
                       | grep -v Unreleased                 \
                       | head -n1                           \
                       | sed -E -e "s|${release_line_ERE}|\\1|"
                       )"
    #
    echo "${Releaseversion}"
}

# Function: installer
#
# Usage: installer installer_option
#
# Argument:
#    installer_option:
#
#       --install, --update, --update-master, --remove: Installer for x11docker
#      
#       --install:
#         - copies x11docker to /usr/local/bin
#         - installs icon in /usr/share/icons
#         - creates x11docker.desktop file in /usr/share/applications
#      
#       --update:
#         - download and install latest release from github, regard
#           existing installation location
#      
#       --update-master:
#         - download and install latest master version from github,
#           regard existing installation location
#      
#       --remove
#         - remove installed files
#
installer() {

    ### FIXME: (--update)
    ### maybe not install additional files if x11docker is owned by user
    #
    local installer_option="${1:-}"
    #
    local Key1="" Key2="" Oldversion="" Newversion="" Format="" Prefix
    local codeload_url_prefix=""
    local raw_url_prefix=""
    local colorize_diff_patterns
    local release_url_pattern
    local the_unpacked_dir=""
    local the_old_version_is_beta="no"

    Prefix="/usr/local"

    case "${installer_option}" in
        --remove-oldprefix)
            # Set Prefix to its old value
            Prefix="/usr"
            ;;
        *)
            # Check if x11docker is present under the old prefix.
            # Warn if so.
            if [ -x "/usr/bin/x11docker" ] ; then
                warning_ttm \
                    "|Option ${installer_option}: Detected x11docker installation in /usr/bin
                     |  Since version 7.6.0 x11docker defaults to ${Prefix}/bin instead.
                     |  If this was a custom installation without your package manager,
                     |  you can remove the old installation as root with:
                     |rm    /usr/bin/x11docker
                     |rm -R /usr/share/doc/x11docker
                     |rm    /usr/share/man/man1/x11docker.1.gz
                     |  or with x11docker option --remove-oldprefix"
            fi
            ;;
    esac


    if [ "$Startuser" != "root" ]                               \
    && word_is_not_in "${Winsubsystem:-EMPTY}" "CYGWIN MSYS2"   \
    && [ "$Installerarg" != "diff" ]                            ;
    then
        error_ttm "|Must run as root to install
                   :, update or remove x11docker system wide."
        return 1
    fi

    # Preparing
    case "${installer_option}" in
        --install)
            if [ ! -f "./x11docker" ]   ; then
                error_ttm "|File x11docker not found in current folder.
                           |  Try 'x11docker --update' instead."
                return 1
            fi

            if [ -x "${Prefix}/bin/x11docker" ] ; then
                warning_ttm \
                    "|x11docker seems to be installed already
                     |  at ${Prefix}/bin/x11docker.
                     |  Will overwrite existing installation.
                     |  Consider to use option '--update' or '--update-master' instead."
            fi
            ;;
    
        --update|--update-master)
            if [ -x "${Prefix}/bin/x11docker" ] ; then
                Oldversion="$(${Prefix}/bin/x11docker --version)"
                note_ttm "|Current installed version: x11docker $Oldversion
                          |  at ${Prefix}/bin/x11docker"
            else
                Oldversion=""
            fi

            # Ensure "/tmp/x11docker-install" exists and is an empty
            # directory.
            if [ -d       "/tmp/x11docker-install" ] ; then  rm -R "/tmp/x11docker-install" ; fi
            if ! mkdir -p "/tmp/x11docker-install"   ; then
                error "Could not create /tmp/x11docker-install."
                return 1
            fi
            #
            # Now "/tmp/x11docker-install" is empty.
            if ! cd    "/tmp/x11docker-install" ; then
                error "Could not cd to /tmp/x11docker-install."
                return 1
            fi
        
            if ! download ; then
                error_ttm \
                    "|Neither wget nor curl found. Need 'wget' or 'curl' for download.
                     |Please install wget or curl."
                return 1
            fi

            if   have_command  tar   ; then  Format="tar.gz"
            elif have_command  unzip ; then  Format="zip"
            else
                error "Cannot extract archive. Please install 'unzip' or 'tar'."
                return 1
            fi
            
            codeload_url_prefix="https://codeload.github.com/mviereck/x11docker"
            raw_url_prefix="https://raw.githubusercontent.com/mviereck/x11docker"
            case "${installer_option}" in

                --update-master)
                    note "Downloading latest x11docker master version from github."
                    #
                    if ! download                                \
                         "${codeload_url_prefix}/$Format/master" \
                         "x11docker-update.$Format"              ;
                    then
                        error "Failed to download x11docker from github."
                        return 1
                    fi
                    ;;

                --update)
                    if ! download                                \
                         "${raw_url_prefix}/master/CHANGELOG.md" \
                         "CHANGELOG.md"                          ;
                    then
                        error "Failed to download CHANGELOG.md from github."
                        return 1
                    fi
                    #
                    Releaseversion="$( CHANGELOG_md_get_Releaseversion "CHANGELOG.md" )"
                    #
                    note "Downloading latest x11docker release $Releaseversion from github."
                    if ! download "${codeload_url_prefix}/$Format/$Releaseversion" "x11docker-update.$Format" ;
                    then
                        error "Failed to download x11docker from github."
                        return 1
                    fi
                    ;;
            esac

            note "Extracting $Format archive."
            case "$Format" in
                zip)    unzip   "x11docker-update.$Format" ;;
                tar.gz) tar xzf "x11docker-update.$Format" ;;
            esac || {
                error "Failed to extract $Format archive."
                return 1
            }
            echo ""
            #
            # Note: we are in "/tmp/x11docker-install".
            #
            # The only subdirectory comes from unpacking the archive.
            # It is the single directory line (ls -l | grep drwx)
            # Assuming no space in its name, the name is the last word in that line.
            #
            # SC2010 (warning): Don't use ls | grep.
            # the_unpacked_dir="$( ls -l | grep drwx | rev_cut -d' ' -f1 )"
            #
            the_unpacked_dir="$( find . -maxdepth 1 -type d -name 'x11docker*'  -exec basename {} \; )"
            if ! cd "/tmp/x11docker-install/${the_unpacked_dir:-MISSING}"
            then
                error "Could not cd to /tmp/x11docker-update/${the_unpacked_dir:-MISSING}"
                return 1
            fi
            ;;
    esac # Preparing.
    # We are in "/tmp/x11docker-install/${the_unpacked_dir}"

    # New version number
    case "${installer_option}" in
        --install|--update|--update-master)
            ## For example: "7.8.1-beta"
            Newversion="$(bash "$(pwd)/x11docker" --version)"
            ;;
    esac

    #
    # Changelog excerpt
    # =================
    {
        #
        # Note: Key1 and Key2 are address patterns for a `sed` call below.
        #
        #   Will print from a line matching Key1, to the line before
        #   one matching Key2.
        #
        # Release URLs match this pattern as a sed address.
        # Setting Key2 to this means: "till the next release line"
        release_url_pattern="https:\/\/github.com\/mviereck\/x11docker\/releases"
        #
        if echo "$Oldversion" | grep -q beta ;
        then the_old_version_is_beta=yes
        else the_old_version_is_beta=no
        fi
        #
        case "${installer_option}" in
            --update)
                Key1="\[${Newversion}\]"
                
                if [ -n "$Oldversion"                    ] \
                && [ "${the_old_version_is_beta}" != yes ] \
                &&  [ "$Newversion" != "$Oldversion"     ] ;
                then Key2="\[${Oldversion}\]"
                else Key2="${release_url_pattern}"
                fi
                #
                if [ "${the_old_version_is_beta}" = yes ] ; then
                    note_ttm \
                        "|You are switching from master branch (beta version) to a stable release.
                         |  To get latest master beta version, use option --update-master instead"
                elif [ "$Newversion" = "$Oldversion" ] ; then
                    note_ttm \
                        "|Version $Newversion was already installed before this update.
                         |  If you want the latest beta version from master branch, use --update-master."
                fi
                ;;

            --update-master)
                Key1="\[Unreleased\]"
                if [ -n "$Oldversion"                    ] \
                && [ "${the_old_version_is_beta}" != yes ] ;
                then Key2="\[${Oldversion}\]"
                else Key2="${release_url_pattern}"
                fi
                ;;
        esac

        case "${installer_option}" in
            --update|--update-master)
                note "Excerpt of x11docker changelog:${NEWLINE}$(
                   sed -n "/${Key1}/,/${Key2}/p" "CHANGELOG.md" | head -n-1
               )"
              ;;
        esac
    } # Changelog excerpt

    #
    # Show diff of old x11docker and new x11docker
    #
    if [ "$Installerarg" = "diff" ] ; then
        case "${installer_option}" in
            --update|--update-master)
                colorize_diff_patterns="$(trim_to_mark \
                       "|s/^+.*/${Colgreenbg}\0${Colnorm}/
                        :; s/^-.*/${Colredbg}\0${Colnorm}/
                        :; s/^@.*/${Coluline}\0${Colnorm}/"
                        )"
                #
                note "$( printf "%s\n%s\n%s"                                                    \
                           "Difference of installed version to new version:"                    \
                           "  $ diff -u -s -Z '$(command -v x11docker)' '$(pwd)/x11docker'"     \
                           "$(  diff -u -s -Z "$(command -v x11docker)" "$(pwd)/x11docker" 2>&1 \
                               | sed "${colorize_diff_patterns}"
                            )"
                      )"
                #
                ;;
        esac
    fi

    # Doing
    if [ -z "$Installerarg" ] ; then
        case "${installer_option}" in

            --install|--update|--update-master)
                #
                note "Installing x11docker to ${Prefix}/bin"
                cp "x11docker" "${Prefix}/bin/" || {
                    error "Could not copy x11docker to ${Prefix}/bin"
                    return 1
                }
                chmod 755 "${Prefix}/bin/x11docker" || {
                    error "Could not set executable bit on x11docker"
                    return 1
                }
                chown "root:root" "${Prefix}/bin/x11docker" || {
                    warning "Could not set ownership 'root:root' to '${Prefix}/bin/x11docker'"
                }
                
                note "Installing icon for x11docker with xdg-icon-resource"
                if ! xdg-icon-resource install               \
                     --context apps --novendor --mode system \
                     --size 64                               \
                     "$(pwd)/x11docker.png" "x11docker" ;
                then
                    note_ttm "|Could not install icon for x11docker.
                              |  Is 'xdg-icon-resource' (xdg-utils) installed on your system?"
                fi

                note_ttm "|Storing README.md, CHANGELOG.md and LICENSE.txt in
                          |  ${Prefix}/share/doc/x11docker"
                #
                if ! mkdir -p "${Prefix}/share/doc/x11docker" ; then
                    note "Error while creating /usr/share/doc/x11docker"
                else
                    cp "README.md"    "${Prefix}/share/doc/x11docker/"
                    cp "CHANGELOG.md" "${Prefix}/share/doc/x11docker/"
                    cp "LICENSE.txt"  "${Prefix}/share/doc/x11docker/"
                fi

                note "Storing man page in ${Prefix}/share/man/man1/x11docker.1.gz"
                if ! have_command  gzip  ; then
                    note "Error storing man page: gzip not found. "
                else
                    gzip -c "x11docker.man" > "${Prefix}/share/man/man1/x11docker.1.gz" \
                        || note "Error storing man page."
                fi

                note "Installed x11docker version $Newversion"
                ;;

            --remove|--remove-oldprefix)
                
                note "Removing x11docker from your system."
                if [ "${installer_option}" = "--remove" ] && [ -n "$g_Backendbin" ] ; then
                    note "Running --cleanup"
                    cleanup
                fi
      
                if [ -x   "${Prefix}/bin/x11docker"   ] ; then
                    rm -v "${Prefix}/bin/x11docker"
                fi
                if [ -e      "${Prefix}/share/doc/x11docker" ] ; then
                    rm -v -R "${Prefix}/share/doc/x11docker"
                fi
                if [ -e      "${Prefix}/share/man/man1/x11docker.1.gz" ] ; then
                    rm -v    "${Prefix}/share/man/man1/x11docker.1.gz"
                fi
                if [ "${installer_option}" = "--remove" ] ; then
                    xdg-icon-resource uninstall --size 64 "x11docker" || true
                fi
                
                note_ttm "|Will not remove files in your home folder.
                          |  There might be files left in \$HOME/.local/share/x11docker
                          |  The symbolic link \$HOME/x11docker might exist, too.
                          |  The cache folder \$HOME/.cache/x11docker should be removed already."
                ;;
        esac
    fi

    # Cleanup
    case "${installer_option}" in
        --update|--update-master)
            note "Removing downloaded temporary files."
            cd ~ || error "cd ~ FAILED in installer()"
            rm -R "/tmp/x11docker-install"
            ;;
    esac
    note "Ready."
}

# Function: mkpasswd
# Usage: mkpasswd  Password
#
# Brief: Create a salted password suitable for /etc/shadow, and put it
#        into Containeruserpassword
#
# Argument:
#   Password
#
# Globals:
#    Containeruserpassword : output goes here
#
mkpasswd() {
    local Password Salt perlScript

    Password="${1:-}"

    if ! have_command perl ; then
        error_ttm \
          "|Option --password: command 'perl' not found.
           |  perl is needed to generate an encrypted password."
        #
        return 1
    fi

    Salt="$(LC_ALL=C base64 <<< "$RANDOM" | cut -c1-2)" # 2 characters

    # shellcheck disable=SC2016 # (info): Expressions don't expand in single quotes.
    #                             Good. We do not want them to in perlScript.
    perlScript="$(trim_to_mark \
               '| my $Salt     = shift;
                : my $Password = shift;
                : print crypt( $Password, "\$6\$".$Salt."\$" )'
               )"

    Password=$(perl -le           \
                    "$perlScript" \
                    "$Salt"       \
                    "$Password"
            )

    # Store result in global variable:
    Containeruserpassword="$Password"
}

# Function: set_password
# Usage: set_password Password
# Brief: Set container user password
#
# CommandlineOption: --password
#
# Argument:
#   Password : the password, or INTERACTIVE
#
# - calls mkpasswd
# - Created Passwordfile
#
# Globals:
#    Passwordfile
#    Containeruserpassword
#
set_password() {
  local Password

  Password="${1:-}"

  if [ "$Password" = "INTERACTIVE" ] ; then
      read -rs -p "$(trim_to_bar \
          "|Please type in a new container user password
           |that will be set for host user '$(id -u -n)'. (chars are invisible): "
           )" \
           Password
      #
      echo ""
      if [ -z "$Password" ] ; then
          error "Input empty, password not changed."
          return 1
      fi
  fi

  mkpasswd "$Password" # Sets $Containeruserpassword

  mkdir -p "$(dirname "$Passwordfile")" \
      || error "Failed to create $(dirname "$Passwordfile")"

  echo "$Containeruserpassword" > "$Passwordfile"
  chmod 600                       "$Passwordfile"
  note "Option --password: Password changed, exiting."
  return 0
}

