#
# Function:  mygetent
#
# Brief: /usr/bin/getent with a fallback implementation
#
# Argument:
#   "$1" is "group" or "passwd"
#
# Used-as:
#    `mygetent group video`
#    `mygetent group input`
#    `mygetent group render`
#    `mygetent group weston-launch`
#
#    `mygetent passwd "$Containeruser"`
#
# Description:
#   Print the line corresponding to "$2" from "/etc/$1", or print nothing
#
# return: 0 on success (found line)
#         nonzero on failure (no corresponding line or other error)
#
# If /usr/bin/getent is used (man getent)
#
# EXIT STATUS
#       One of the following exit values can be returned by getent:
#
#       0      Command completed successfully.
#       1      Missing arguments, or database unknown.
#       2      One or more supplied key could not be found in the database.
#       3      Enumeration not supported on this database.
#
#
mygetent() {                    # custom getent command
    # fixes #477 #496
    if have_command getent ; then
        getent "$1" "$2"
    else
        grep "^${2:-NOENTRY}:" < "/etc/${1:-NOFILESPECIFIED}"
    fi
}

