# Group: makecookie
#
# Function: makecookie
#
# Brief:  bake a cookie
#
# /usr/bin/mcookie : mcookie generates a 128-bit random
#                    hexadecimal number for use with the X
#                    authority system.
#
#  $RANDOM : Bash has a built-in variable called $RANDOM that
#            generates a pseudorandom integer between 0 and 32767
#            each time it is called.
#
#            That is 15 random bits. We need 32*4 = 16*2*4
#
makecookie_v1() {
    mcookie 2>/dev/null
}
makecookie_v2() {
    if [ -e /dev/urandom ] && have_command md5sum ; then
        #
        # md5sum might not cover the possible range from a 16-byte input.
        # Use more bytes.
        head -c 160 /dev/urandom | md5sum | cut -b 1-32
        true
    else
        false
    fi
}
makecookie_v3() {
    # SC3028 (error): In dash, RANDOM is not supported.
    # shellcheck disable=SC3028 # (error): In dash, RANDOM is not supported.
    if [ "$RANDOM" ] && [ "$RANDOM" !=  "$RANDOM" ] ; then
        #
        printf "%02x" $(( RANDOM % 256 )) $(( RANDOM % 256 )) $(( RANDOM % 256 )) $(( RANDOM % 256 ))
        printf "%02x" $(( RANDOM % 256 )) $(( RANDOM % 256 )) $(( RANDOM % 256 )) $(( RANDOM % 256 ))
        printf "%02x" $(( RANDOM % 256 )) $(( RANDOM % 256 )) $(( RANDOM % 256 )) $(( RANDOM % 256 ))
        printf "%02x" $(( RANDOM % 256 )) $(( RANDOM % 256 )) $(( RANDOM % 256 )) $(( RANDOM % 256 ))
        printf "\n"
        #
        true
    else
        false
    fi
}
makecookie() {
    #
    # mcookie 2>/dev/null || echo $RANDOM$RANDOM$RANDOM$RANDOM$RANDOM$RANDOM | cut -b1-32
    #
    makecookie_v1 || makecookie_v2 || makecookie_v3
    #
}
