# Function: convertpath_split_Readwritemode
#
# Usage: convertpath_split_Readwritemode Readwritemode_out Path_out  Path
#
# Argument:
#   Readwritemode_out : name of variable to write Readwritemode to
#
#   Path_out : Name of output variable for Path
#
#   Path : input
#
# On return:
#    If the last 3 characters of Path starts with ":",
#    then Readwritemode_out is these 3 characters,
#    and these are removed from Path_out.
#
# otherwise Readwritemode_out=":rw"
#
# Globals:
#    FDstderr # via warning()
#
convertpath_split_Readwritemode() {
    ##
    ## Note: Local name for namerefs has to differ from the name
    ## passed in.  Here we use the prefix `x1_` for this reason.
    ##
    declare -n x1_Readwritemode_out="$1"
    declare -n x1_Path_out="$2"
    local Path_in="$3"
    #
    if [ "${Path_in: -3:1}" = ":" ] ; then
        x1_Readwritemode_out="${Path_in: -3}"
        x1_Path_out="${Path_in:0:-3}"
    else
        x1_Readwritemode_out=":rw"
        x1_Path_out="$Path_in"
    fi
    #
    # error for unexpected suffix value
    #
    case "$x1_Readwritemode_out" in
        ":ro"|":rw") return 0 ;;
        *)
            warning_ttm \
                "|convertpath_split_Readwritemode:
                 |   Path='$Path_in' has ':..' suffix '${x1_Readwritemode_out}',
                 |   that is neither ':ro', nor ':rw'
                 |   Note: NOT removing suffix and emitting Readwritemode=':rw'"
            #
            x1_Readwritemode_out=":rw"
            x1_Path_out="$Path_in"
            return 1
            ;;
    esac
}

# Function: convertpath_split_Drive
#
# Usage: 
#    local Drive
#    local Path
#    convertpath_split_Drive "Drive" "Path" "${Path}"
#
# Path may be /c/path2
#          or C:/path2
#          or /path2
#
# Out: Drive: "c" or ""
#      Path: /path2
#
# Argument:
#   "Drive": Name of output variable for drive letter
#   "Path" : Name of output variable for Path
#   "${Path}" : input. The path to split.
#
convertpath_split_Drive() {
    declare -n x1_Drive_out="$1"
    declare -n x1_Path_out="$2"
    local Path_in="$3"
    #
    ## Separate drive prefix,  '/c/'  or 'C:/' .
    if [ "$(cut -c1,3 <<< "${Path_in}/")" = "//" ] ; then
        # Given format is /c/xxx
        x1_Drive_out="${Path_in:1:1}"               # c
        x1_Drive_out="${x1_Drive_out,}" # change drive to lowercase
        x1_Path_out="${Path_in:2}"                  # /xxx
        # x1_Path_out="${Path_in:-"/"}" # << we already had "/" at (1-based) character 3
    elif [ "$(cut -c2 <<< "$Path_in")" = ":" ] ; then
        # Given format is C:/xxx
        x1_Drive_out="${Path_in:0:1}"               # C
        x1_Drive_out="${x1_Drive_out,}" # change drive to lowercase
        x1_Path_out="${Path_in:2}"                  # /xxx
        # We only tested "^.[:]" here, so Path may be empty.
        # If Path is empty, change it to "/"
        x1_Path_out="${x1_Path_out:-"/"}"
    else
        x1_Drive_out=""
        x1_Path_out="${Path_in}"
    fi
    #
}



