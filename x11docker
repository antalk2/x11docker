# Function: mkfile
# Usage: mkfile  path
# Usage: mkfile  path mode
#
# Brief: Create file path=$1 owned by "$Hostuser:$Hostusergid"
#
# Argument:
#    path : which file to create
#    mode : for chmod, defaults to 644
#
#  Example: mkfile $path
#  Example: mkfile $path 666
#
# return: 0 on success
#         1 on error
# 
mkfile() {
  :> "${1:-}"                   || return 1 # create as empty
  chown "$Hostuser"    "${1:-}" || return 1
  chgrp "$Hostusergid" "${1:-}" || return 1
  #
  chmod 644            "${1:-}" || return 1 # default mode
  [ -n "${2:-}" ] && { 
    chmod "${2:-}" "${1:-}"     || return 1 # supplied mode
  }
  return 0
}

#
# Function: mkfolder
# Usage: mkfolder path mode=755 )
# Brief: Create folder "path" owned by $Hostuser
#
# Argument:
#    path : which folder to create
#    mode: for chmod, default=755
#
# Description:
#  - path must be an  absolute unix path
#  - Each part in the directory chain created gets `chmod mode`
#
#  return: 1 if failed
#          0 on success.
#
# Examples:
#
#  mkfolder "$Hostuserhome/.config/compiz-1/compizconfig"
#  mkfolder "$Persistanthomevolume"
#  mkfolder "$Hostuserhome"
#  mkfolder "$Localsharedir"
#  mkfolder "$XDG_RUNTIME_DIR" 0700
#  ...
#
mkfolder() {
    local Step
    local Path=""
    local Return=""
    local pieces
    #
    # Work recursively
    #
    # Only use the nonempty pieces. Thwirs away the empty piece from
    # before the first "/"
    #
    # FIXME: /home/user/../user2/../user3
    #
    pieces="$(tr '/' '\n' <<< "${1:-}" | grep .)"
    for Step in $pieces ; do
        Path="$Path/$Step" # path in $1 must be absolute
        if [ ! -d "$Path" ] ; then
            unpriv "mkdir -p  '$Path'"  || Return=1
            chmod "${2:-755}" "$Path"   || Return=1
        fi
        if [ -n "$Return" ] ; then break ; fi
    done
    return ${Return:-0}
    #unpriv "mkdir -p  '${1:-}'"   || return 1
}


# Function: 
# Usage: myrealpath path
# Brief: Real path of a possible symlink
#
# Description:
#  - call realpath if available
#  - Otherwise
#      - warning() if path is a symlink
#      - echo $path
#
# Q: why "$*" instead of "$1"
# Note: Only used with a single argument.
#
myrealpath() {
    # No args is a failure
    [ -z "$*" ] && return 1
    # If have realpath, use that.
    if have_command realpath  ; then
        realpath "$*"
    else
        # Otherwise complain if it is a symlink
        if [ -h "$*" ] ; then
            warning_ttm \
                "|  Could not check for symbolic links.
                 |  Please install 'realpath' (package 'coreutils'),
                 |  or provide real file path instead of symbolic link path.
                 |  Possible symbolic link: $*"
        fi
        #
        # and emit the path unmodified
        echo "$*"   ### FIXME: Maybe workaround with ls
        return 1
    fi
}


# Function waitforlogentry_sh
# Usage: waitforlogentry_sh application logfile keyword error_keywords [time_to_wait]
# Brief: wait until keyword appears in logfile
#
# Argument:
#   application
#   logfile : file to read
#   keyword : success if keyword is found in logfile
#   error_keywords : failure if any of these is found in logfile
#   time_to_wait : seconds, default=60. Can be "infinity" for a very long wait
#
# Description:
#  - Wait for keyword ($3) in logfile ($2) of application ($1)
#  - error() on timeout and error_keywords in logfile
#  - return success if found keyword in logfile
#  - return failure (1) if rocknroll return non-zero (Timetosaygoodbye)
#
#  Uses linearly increasing sleep times: we are just waiting for
#  "ready" entries, not watching long-running processes for a long
#  time.
#
# Examples:
#
#  waitforlogentry_sh "start_xcontainer()" "$Xinitlogfile"     "X server container is ready"
#  waitforlogentry_sh containerrc          \$Storeinfofile      containerrootrc=ready  ''                      infinity
#  waitforlogentry_sh "start_compositor()" "$Compositorlogfile" "$Compositorkeyword"   "$Compositorerrorcodes"
#  waitforlogentry_sh tailstdout           "$Storeinfofile"      "x11docker=ready"      ""                     infinity
#  waitforlogentry_sh 'start_container()'   $Xinitlogfile        'xinitrc is ready'     "$Xiniterrorcodes"
#  waitforlogentry_sh xpra                  $Xinitlogfile        "xinitrc is ready"     ""                     infinity
#
waitforlogentry_sh() {

    local application="${1:-}"  # $1 is the application we are waiting
                                # for to be ready

    local logfile="${2:-}"      # $2 points to logfile

    local keyword="${3:-}"      # $3 keyword to wait for (May contain
                                # space, used as a "grep -q" pattern)

    local Errorkeys="${4:-}"    # $4 possible error keywords.
                                # Empty or extended regexp.
                                # Used in 'grep -i -E "$Errorkeys"'

    local TimeToWait="${5:-60}" # $5 time to wait in seconds or
                                # infinity. default: 60

    if [ "$TimeToWait" = "infinity" ] ; then
        TimeToWait=32000 ; # 8.888 hours. 32400 would be 9 hours.
    fi

    local StartTime CurrentTime ElapsedTime

    # SleepTime is approx linearly increasing on repeats
    local Count=0 SleepTime

    local Errorkey
    local Error=
    local logfile_basename
    logfile_basename="$(basename "${logfile}")"

    StartTime="$(date +%s || true)"
    StartTime="${StartTime:-0}"

    debugnote_ttm "|waitforlogentry_sh(): ${application}:
                   : Waiting for logentry \"${keyword}\" in ${logfile_basename}"

    while ! grep -q "${keyword}" <"${logfile}" ; do
        Count="$(( Count + 1 ))"

        CurrentTime="$(date +%s || true)"
        CurrentTime="${CurrentTime:-0}"
        ElapsedTime="$(( CurrentTime - StartTime ))"

        SleepTime="$(( Count / 10 ))"
        if [ "$SleepTime" = "0" ] ; then  SleepTime="0.5" ; fi

        mysleep "$SleepTime"

        ## Report after 10 sec of waiting.
        if [ "$ElapsedTime" -gt "10" ] ; then
            debugnote_ttm  \
                "|waitforlogentry_sh(): ${application}:
                 : Waiting since ${ElapsedTime}s
                 : for log entry \"${keyword}\" in ${logfile_basename}"
        fi

        # error if TimeToWait seconds have elapsed
        if [ "$ElapsedTime" -gt "$TimeToWait" ] ; then
            error "$(trim_to_mark \
                   "|waitforlogentry_sh(): ${application}:
                    : Timeout waiting for entry \"${keyword}\" in ${logfile_basename}
                    |  Last lines of ${logfile_basename}:"
                    )${NEWLINE}$(tail -n15 "${logfile}")"
        fi

        # error if Errorkeys matches to content of logfile
        if [ "$Errorkeys" ] ; then
            Errorkey="$(grep -i -E "$Errorkeys" <"${logfile}")" || true
            #
            if [ -n "$Errorkey" ] ; then
                error "$(trim_to_bar \
                       "|waitforlogentry_sh(): ${application}: Found error message in logfile:
                        |  <'$Errorkey'>
                        |
                        |  Context in logfile ${logfile_basename}:"
                        )${NEWLINE}$( grep -C7 "$Errorkey" "${logfile}" )"
                # ---
            fi
        fi

        # break loop on Timetosaygoodbye
        if ! rocknroll ; then
            debugnote_ttm \
                "|waitforlogentry_sh(): ${application}:
                 : Stopped waiting for ${keyword} in ${logfile_basename}
                 : due to terminating signal."
            Error=1
            break
        fi
    done
    #
    # Early return due to Timetosaygoodbye
    if [ "$Error" ] ; then
        return 1
    fi
    #
    # Normal return, found keyword
    debugnote_ttm "|waitforlogentry_sh(): ${application}:
                   : Found log entry \"${keyword}\" in ${logfile_basename}."
    return 0
}

#
# Function: writeaccess( useruid, folderPath )
# Usage: writeaccess useruid  folderPath
# Brief: Try to tell if useruid could write in folderPath
#
# writeaccess 1000 test1 ; echo $?
#
#
# Examples:
#
#   writeaccess "$Containeruseruid" "$Persistanthomevolume" # (ex1)
#   writeaccess "$Hostuseruid"      "$Cachebasefolder"      # (ex2)
#
#  Q: Would it not be simpler to use something like `unpriv [ -w $path_to_filder ]` ?
#
#  A: Since `unpriv` changes to "$Hostuser" if necessary, this
#     probably covers the case in (ex2).
#     Hostuser can be set by --hostuser
#
#     Concerning (ex1):   "$Containeruser" defaults to Hostuser,
#      this is covered by unpriv.
#
#     For a non-default (Containeruser, --user): we are asking if a
#     user inside the container can write a directory (probably outside).
#     Probably depends on: (1) the user running docker, (2) mapping, is it readonly?
#     (3) relation of  Containeruser inside and ...
#
#     For a reliable answer it might be more practical to ask it from
#     within the container.
#
#
# https://linux.die.net/man/5/acl
#
# ACCESS CHECK ALGORITHM
#
#        A process may request read, write, or execute/search
#        access to a file object protected by an ACL. The access
#        check algorithm determines whether access to the object
#        will be granted.
#
#        1.  If the effective user ID of the process matches the
#            user ID of the file object owner, then
#
#                   if the ACL_USER_OBJ entry contains the
#                   requested permissions, access is granted, else
#                   access is denied.
#
#        2.  else if the effective user ID of the process matches
#            the qualifier of any entry of type ACL_USER, then
#
#                   if the matching ACL_USER entry and the
#                   ACL_MASK entry contain the requested
#                   permissions, access is granted, else access is
#                   denied.
#
#        3.  else if the effective group ID or any of the
#            supplementary group IDs of the process match the file
#            group or the qualifier of any entry of type ACL_GROUP,
#            then
#
#                   if the ACL contains an ACL_MASK entry, then
#
#                         if the ACL_MASK entry and any of the
#                         matching ACL_GROUP_OBJ or ACL_GROUP
#                         entries contain the requested
#                         permissions, access is granted,
#                         else access is denied.
#
#                   else (note that there can be no ACL_GROUP
#                         entries without an ACL_MASK entry)
#
#                         if the ACL_GROUP_OBJ entry contains the
#                         requested permissions, access is
#                         granted, else access is denied.
#
#        4.  else if the ACL_OTHER entry contains the requested
#            permissions, access is granted.
#
#        5.   else access is denied.
#
#
#
writeaccess() {                 # check if useruid $1 has write access to folder $2
    local userid="${1:-}"
    local dirpath="${2:-}"
    local dirVals=
    local dir_owner_name=
    local dir_group_name=
    local dir_perm_flags=
    local dir_owner_uid=
    local dir_is_user_writable=
    local dir_is_group_writable=
    local dir_is_other_writable=
    local IFS=
    local acl_user_entry=
    local acl_mask_entry=
    #
    local userid_group_names=
    local userid_has_dirs_group=
    #
    local userid_group_id_re=
    local userid_acl_group_id_entries=
    #
    local userid_has_acl_groups=
    local n_permits=
    #
    #
    # verbose true or false
    # local verbose=false
    #
    #
    #
    # %U     user name of owner
    # %G     group name of owner
    # %A     permission bits and file type in human readable form
    #
    # Example: stat -Lc "%U      %G      %A"  /tmp
    #     prints "root	root	drwxrwxrwt"
    #
    IFS=$'\t' read -r -a dirVals < <(stat -Lc "%U	%G	%A" "${dirpath}")
    dir_owner_name="${dirVals[0]}"
    dir_group_name="${dirVals[1]}"
    dir_perm_flags="${dirVals[2]}"
    dir_owner_uid="$(id -u "$dir_owner_name")"
    #
    dir_is_user_writable=$(  [ "${dir_perm_flags:2:1}" == "w" ] ; exitcode_yes_or_no )
    dir_is_group_writable=$( [ "${dir_perm_flags:5:1}" == "w" ] ; exitcode_yes_or_no )
    dir_is_other_writable=$( [ "${dir_perm_flags:8:1}" == "w" ] ; exitcode_yes_or_no )
    #
    #
    #    if $verbose ; then
    #        echo "dir_owner_name='$dir_owner_name' dir_owner_uid='$dir_owner_uid'"
    #        echo "dir_group_name='$dir_group_name'"
    #        echo "dir_perm_flags='$dir_perm_flags'"
    #        echo "dir_is_user_writable='$dir_is_user_writable'"
    #        echo "dir_is_group_writable='$dir_is_group_writable'"
    #        echo "dir_is_other_writable='$dir_is_other_writable'"
    #    fi
    #
    # (1) If user matches, return owner-has-write-permission
    if [ "${dir_owner_uid}" = "${userid}" ] ; then
        # if $verbose; then echo "user-matches"; fi
        [ "${dir_is_user_writable}" == "yes" ] && return 0 || return 1
    fi
    #
    # (2) If userid "$1" has ACL entry, use the effective permission from that.
    acl_user_entry="$(getfacl -pn "${dirpath}" | grep "user:${userid}:")"
    if [ -n "$acl_user_entry" ] ; then
        #        if $verbose ; then
        #            echo "ACL user_entry='$acl_user_entry'";
        #        fi
        [ "w" = "$(echo "$acl_user_entry" | rev | cut -c2)" ] && return 0 || return 1
    fi
    #
    acl_mask_entry="$(getfacl -pn "${dirpath}" | grep "mask::")"
    #    if $verbose ; then
    #        if [ -n "$acl_mask_entry" ] ; then
    #            echo "ACL mask entry: '$acl_mask_entry'"
    #        else
    #            echo "ACL mask entry: NA"
    #        fi
    #    fi
    #
    # (3) If any group of the user matches the group of the directory or
    #     a group-ACL
    #
    #     (3a) If ACL has MASK: return (allowed-by-MASK && (allowed by
    #             matching ACL_GROUP_OBJ or any matching ACL_GROUP)
    #     (3b) or (no MASK) return (allowed by matching ACL_GROUP_OBJ)
    #
    # If user has group membership, return group-has-write-permission
    #    - This ignores ACL_MASK and ACL group permissions
    #
    # userid_group_names : group names surrounded and separated with ':'
    userid_group_names=":$(id -Gn "${userid}" 2>/dev/null | sed -e 's| |:|g' ):"
    ##
    if [[ "${userid_group_names[*]}" =~ :${dir_group_name}: ]] ; then
       userid_has_dirs_group=yes
    else
       userid_has_dirs_group=no
    fi
    
    # if $verbose; then echo "userid_has_dirs_group=$userid_has_dirs_group"; fi
    #
    #
    # ACL group:GID: entries for userid
    userid_group_id_re="^group:\\($(  id -G  "${userid}" 2>/dev/null | sed -e 's/ /\\|/g' )\\):"
    userid_acl_group_id_entries="$(getfacl -pn "${dirpath}" | grep -e "${userid_group_id_re}")"
    # if $verbose; then
    #    echo "userid_group_id_re='$userid_group_id_re'"
    #    echo "userid_acl_group_id_entries=$userid_acl_group_id_entries"
    # fi
    #
    # if [ -n "${userid_acl_group_id_entries}" ] ; then
    #     userid_has_acl_groups=yes
    # else
    #     userid_has_acl_groups=no
    # fi
    #
    userid_has_acl_groups=$( [ -n "${userid_acl_group_id_entries}" ]; exitcode_yes_or_no )
    #
    if [ "${userid_has_dirs_group}" = "yes" ] || [ "${userid_has_acl_groups}" = "yes" ] ; then
        # if $verbose; then echo "Have matching group"; fi
        if [ -n "$acl_mask_entry" ] ; then
            # if $verbose; then echo "Have acl_mask_entry=$acl_mask_entry"; fi
            if [ "w" = "$(echo "$acl_mask_entry" | rev | cut -c2)" ] ; then
                # if $verbose; then echo "acl_mask_entry allows 'w'"; fi
                #
                if     [ "${userid_has_dirs_group}" = "yes" ]  \
                   &&  [ "${dir_is_group_writable}" = "yes" ]  ; then
                    return 0
                fi
                #
                if [ "${userid_has_acl_groups}" = "yes" ] ; then
                    # if $verbose; then echo "Does any group ACL permit w?"; fi
                    n_permits="$(echo "${userid_acl_group_id_entries}" | rev | cut -c2 | grep -c w)"
                    # if $verbose; then echo "n_permits=$n_permits"; fi
                    if [ "${n_permits}" != "0" ] ; then
                        return 0
                    fi
                fi
                #
                return 1
                #
            else
                # if $verbose; then echo "acl_mask_entry disallows 'w'"; fi
                return 1
            fi
        else
            # if $verbose; then echo "No acl_mask_entry (and thus no group ACLs)"; fi
            if    [ "${userid_has_dirs_group}" = "yes"  ]  \
               && [ "${dir_is_group_writable}" = "yes"  ]  ; then
                return 0
            else
                return 1
            fi
        fi
    fi
    #
    #
    # (4) writable by others?
    if [ "${dir_is_other_writable}" = "yes" ] ; then return 0 ; fi
    #
    # (5)  else access is denied.
    return 1
}

